---
import Layout from '../layouts/Layout.astro';

const title = "Elmira Stove Works Appliance Repair Los Angeles | Northstar & Antique Series Specialists";
const description = "Expert Elmira Stove Works repair in Los Angeles. Northstar retro refrigerators, Antique series ranges, Fireview wood cookstoves, Model 1895 microwave. Chrome trim protocol. Same-day service. Call (626) 376-4458.";
const phone = "(626) 376-4458";
const phoneRaw = "6263764458";
---

<Layout title={title} description={description}>

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "HomeAndConstructionBusiness",
  "name": "Same Day Appliance Repair — Elmira Stove Works Specialist",
  "url": "https://samedayappliance.repair/brand-elmira-stove-works-appliance-repair/",
  "telephone": "+16263764458",
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Los Angeles",
    "addressRegion": "CA",
    "postalCode": "90001",
    "addressCountry": "US"
  },
  "areaServed": ["Los Angeles County", "Orange County", "Ventura County"],
  "priceRange": "$$",
  "openingHours": "Mo-Sa 08:00-20:00",
  "hasOfferCatalog": {
    "@type": "OfferCatalog",
    "name": "Elmira Stove Works Repair Services",
    "itemListElement": [
      {"@type":"Offer","itemOffered":{"@type":"Service","name":"Elmira Northstar Refrigerator Repair"}},
      {"@type":"Offer","itemOffered":{"@type":"Service","name":"Elmira Antique Range Repair"}},
      {"@type":"Offer","itemOffered":{"@type":"Service","name":"Elmira Fireview Wood Cookstove Service"}},
      {"@type":"Offer","itemOffered":{"@type":"Service","name":"Elmira Model 1895 Microwave Repair"}},
      {"@type":"Offer","itemOffered":{"@type":"Service","name":"Elmira Chrome Trim Service"}},
      {"@type":"Offer","itemOffered":{"@type":"Service","name":"Elmira Antique Dishwasher Repair"}}
    ]
  }
}
</script>

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "How much does Elmira Stove Works appliance repair cost in Los Angeles?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Most Elmira repairs run $165–$520. Common fixes like a Northstar refrigerator sealed system service, igniter on an Antique range, or microwave inverter are on the lower end. Control board replacement or chrome trim restoration runs higher. Diagnostic fee is $89, waived when you proceed. Parts sourced through Elmira directly from Ontario — US availability varies by component. Written flat-rate estimate before work begins."
      }
    },
    {
      "@type": "Question",
      "name": "Where are Elmira Stove Works appliances made?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Elmira Stove Works appliances are made in Elmira, Ontario, Canada — the company was founded in 1975 in the same Mennonite community town the brand is named after. It's a small, family-owned Canadian manufacturer specializing in retro-styled appliances with modern engineering inside. Parts come directly from the Elmira, Ontario facility."
      }
    },
    {
      "@type": "Question",
      "name": "Does the Northstar refrigerator require special service?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The Northstar refrigerator uses a standard modern compressor and sealed system inside a custom 1950s-inspired retro shell. From a mechanical standpoint, it diagnoses like any modern refrigerator — compressor, evaporator fan, defrost system, temperature sensor. The differences are in the exterior: the chrome trim requires non-abrasive service protocols, and the distinctive rounded door uses custom hinges specific to Elmira's design. We service the mechanical components using standard modern refrigerator diagnostics while protecting the retro exterior throughout."
      }
    },
    {
      "@type": "Question",
      "name": "Can you service the Elmira Fireview wood cookstove?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes. The Elmira Fireview is a wood-burning cookstove with a large glass viewing door — unique among Elmira's product line. Service focuses on the glass door seal (creosote buildup affects seal integrity), the door hinge and latch system, and the firebox components. Fireview glass door replacement and seal service are the most common Fireview calls. Note: Fireview installation in LA requires appropriate flue permits and clearance compliance — we can assess the installation at the service call."
      }
    },
    {
      "@type": "Question",
      "name": "Why does Elmira chrome trim require special cleaning during service?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Elmira's Northstar and Antique series use decorative chrome trim on handles, knobs, and accent elements. Chrome is a plated finish — it scratches with abrasive cleaners and oxidizes with acid-based products. We use non-abrasive cleaning agents and chrome-appropriate polish during any Elmira service call. Scratched chrome cannot be restored without replating; we protect it from damage rather than creating a problem that requires professional repair."
      }
    }
  ]
}
</script>

<style>
  :root {
    --red: #C8102E;
    --black: #0a0a0a;
    --gray: #f5f5f5;
    --border: #e2e2e2;
    --text: #1a1a1a;
    --muted: #6b6b6b;
  }
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body { font-family: 'Barlow', 'Inter', system-ui, sans-serif; color: var(--text); }

  .top-bar { background: var(--red); padding: 8px 24px; display: flex; justify-content: space-between; align-items: center; font-size: 13px; color: #fff; }
  .top-bar a { color: #fff; text-decoration: none; font-weight: 700; }

  .hero { background: var(--black); padding: 72px 24px 64px; color: #fff; }
  .hero-inner { max-width: 1100px; margin: 0 auto; display: grid; grid-template-columns: 1fr 420px; gap: 48px; align-items: center; }
  .hero-eyebrow { font-size: 11px; font-weight: 700; letter-spacing: 0.15em; text-transform: uppercase; color: var(--red); margin-bottom: 16px; }
  .hero-title { font-size: clamp(32px, 5vw, 52px); font-weight: 900; line-height: 1.05; text-transform: uppercase; letter-spacing: -0.02em; margin-bottom: 20px; }
  .hero-title span { color: var(--red); }
  .hero-sub { font-size: 17px; line-height: 1.6; color: #aaa; margin-bottom: 32px; max-width: 540px; }
  .hero-cta-group { display: flex; gap: 16px; flex-wrap: wrap; }
  .btn-primary { display: inline-block; background: var(--red); color: #fff; padding: 14px 28px; font-size: 15px; font-weight: 700; text-decoration: none; letter-spacing: 0.04em; text-transform: uppercase; }
  .btn-secondary { display: inline-block; border: 1px solid #555; color: #ccc; padding: 14px 28px; font-size: 15px; font-weight: 600; text-decoration: none; letter-spacing: 0.04em; text-transform: uppercase; }
  .hero-badge-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
  .hero-badge { background: #161616; border: 1px solid #2a2a2a; padding: 16px 18px; }
  .badge-num { font-size: 22px; font-weight: 900; color: var(--red); line-height: 1; margin-bottom: 4px; }
  .badge-label { font-size: 12px; color: #888; text-transform: uppercase; letter-spacing: 0.08em; }

  .trust-bar { background: var(--red); padding: 14px 24px; }
  .trust-bar-inner { max-width: 1100px; margin: 0 auto; display: flex; justify-content: space-between; flex-wrap: wrap; gap: 8px; }
  .trust-item { color: #fff; font-size: 13px; font-weight: 600; letter-spacing: 0.04em; text-transform: uppercase; }
  .trust-item::before { content: "✓ "; }

  .section { padding: 64px 24px; }
  .section-gray { background: var(--gray); }
  .section-black { background: var(--black); color: #fff; }
  .section-inner { max-width: 1100px; margin: 0 auto; }
  .section-num { font-size: 11px; font-weight: 700; letter-spacing: 0.15em; text-transform: uppercase; color: var(--red); margin-bottom: 8px; }
  .section-title { font-size: clamp(24px, 3.5vw, 36px); font-weight: 900; text-transform: uppercase; letter-spacing: -0.01em; margin-bottom: 20px; }
  .section-black .section-title { color: #fff; }
  .section-lead { font-size: 17px; line-height: 1.7; color: var(--muted); max-width: 760px; margin-bottom: 40px; }
  .section-black .section-lead { color: #999; }

  .products-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 1px; background: #2a2a2a; border: 1px solid #2a2a2a; margin-top: 28px; }
  .product-card { background: #161616; padding: 22px 20px; }
  .product-card.featured { border-top: 2px solid var(--red); }
  .product-badge { font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; color: var(--red); margin-bottom: 8px; }
  .product-name { font-size: 16px; font-weight: 900; text-transform: uppercase; color: #fff; margin-bottom: 8px; }
  .product-desc { font-size: 12px; color: #666; line-height: 1.65; }

  .tip-block { border-left: 3px solid var(--red); background: #fff8f8; padding: 18px 20px; margin: 32px 0; max-width: 760px; }
  .tip-label { font-size: 10px; font-weight: 800; text-transform: uppercase; letter-spacing: 0.15em; color: var(--red); margin-bottom: 6px; }
  .tip-text { font-size: 14px; line-height: 1.65; color: var(--text); }
  .tip-chrome { border-color: #888; background: #f8f8f8; }
  .tip-chrome .tip-label { color: #555; }
  .tip-canada { border-color: #c8820a; background: #fff8f0; }
  .tip-canada .tip-label { color: #c8820a; }

  .services-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 1px; background: var(--border); border: 1px solid var(--border); }
  .service-card { background: #fff; padding: 28px 24px; }
  .service-icon { font-size: 28px; margin-bottom: 12px; }
  .service-name { font-size: 16px; font-weight: 800; text-transform: uppercase; letter-spacing: 0.04em; margin-bottom: 10px; color: var(--text); }
  .service-desc { font-size: 14px; line-height: 1.65; color: var(--muted); margin-bottom: 12px; }
  .service-issues { font-size: 12px; color: var(--red); font-weight: 600; text-transform: uppercase; letter-spacing: 0.06em; }

  .features-2col { display: grid; grid-template-columns: 1fr 1fr; gap: 48px; align-items: start; }
  .features-list { list-style: none; }
  .features-list li { padding: 14px 0; border-bottom: 1px solid #2a2a2a; font-size: 15px; color: #ccc; display: flex; gap: 12px; }
  .features-list li::before { content: "→"; color: var(--red); flex-shrink: 0; }

  .problems-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(260px, 1fr)); gap: 16px; margin-top: 32px; }
  .problem-card { border: 1px solid var(--border); background: #fff; padding: 20px; }
  .problem-title { font-size: 14px; font-weight: 800; text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 8px; color: var(--text); }
  .problem-cause { font-size: 13px; color: var(--muted); line-height: 1.6; margin-bottom: 10px; }
  .problem-tag { display: inline-block; font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; padding: 3px 8px; color: #fff; }
  .tag-northstar { background: #2a5ea5; }
  .tag-antique { background: #c8820a; }
  .tag-chrome { background: #555; }
  .tag-common { background: var(--red); }

  .pricing-table { width: 100%; border-collapse: collapse; margin-top: 24px; }
  .pricing-table th { background: var(--text); color: #fff; text-align: left; padding: 12px 16px; font-size: 12px; text-transform: uppercase; letter-spacing: 0.08em; }
  .pricing-table td { padding: 14px 16px; border-bottom: 1px solid var(--border); font-size: 14px; }
  .pricing-table tr:last-child td { border-bottom: none; }
  .pricing-table tr:nth-child(even) td { background: var(--gray); }
  .price-range { font-weight: 700; color: var(--red); }

  .why-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: 24px; margin-top: 32px; }
  .why-card { border-left: 3px solid var(--red); padding: 20px; background: #fff; }
  .why-icon { font-size: 24px; margin-bottom: 10px; }
  .why-title { font-size: 14px; font-weight: 800; text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 8px; }
  .why-desc { font-size: 13px; color: var(--muted); line-height: 1.6; }

  .reviews-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 20px; margin-top: 32px; }
  .review-card { background: #fff; border: 1px solid var(--border); padding: 24px; }
  .review-stars { color: var(--red); font-size: 18px; margin-bottom: 10px; }
  .review-text { font-size: 14px; line-height: 1.7; color: var(--text); margin-bottom: 14px; }
  .review-author { font-size: 12px; font-weight: 700; text-transform: uppercase; color: var(--muted); }

  .repairs-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 1px; background: var(--border); border: 1px solid var(--border); margin-top: 32px; }
  .repair-item { background: #fff; padding: 24px; }
  .repair-appliance { font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; color: var(--red); margin-bottom: 6px; }
  .repair-issue { font-size: 15px; font-weight: 800; color: var(--text); margin-bottom: 8px; }
  .repair-detail { font-size: 13px; color: var(--muted); line-height: 1.6; }
  .repair-meta { margin-top: 12px; font-size: 12px; font-weight: 600; color: #aaa; text-transform: uppercase; letter-spacing: 0.06em; }

  .faq-list { margin-top: 32px; }
  .faq-item { border-bottom: 1px solid var(--border); padding: 20px 0; }
  .faq-q { font-size: 16px; font-weight: 800; color: var(--text); margin-bottom: 10px; }
  .faq-a { font-size: 14px; line-height: 1.7; color: var(--muted); max-width: 760px; }

  .nearby-grid { display: flex; flex-wrap: wrap; gap: 8px; margin-top: 20px; }
  .nearby-chip { background: var(--gray); border: 1px solid var(--border); padding: 8px 14px; font-size: 13px; color: var(--muted); text-decoration: none; font-weight: 600; }
  .nearby-chip:hover { border-color: var(--red); color: var(--red); }

  .bottom-cta { background: var(--black); padding: 72px 24px; text-align: center; color: #fff; }
  .bottom-cta-title { font-size: clamp(28px, 4vw, 44px); font-weight: 900; text-transform: uppercase; letter-spacing: -0.01em; margin-bottom: 12px; }
  .bottom-cta-title span { color: var(--red); }
  .bottom-cta-sub { font-size: 17px; color: #888; margin-bottom: 32px; }
  .cta-phone-large { display: inline-block; font-size: clamp(28px, 4vw, 42px); font-weight: 900; color: #fff; text-decoration: none; letter-spacing: -0.01em; margin-bottom: 24px; border-bottom: 2px solid var(--red); padding-bottom: 4px; }

  @media (max-width: 768px) {
    .hero-inner { grid-template-columns: 1fr; }
    .hero-badge-grid { grid-template-columns: 1fr 1fr; }
    .features-2col { grid-template-columns: 1fr; }
    .products-grid { grid-template-columns: 1fr; }
    .trust-bar-inner { flex-direction: column; gap: 6px; }
  }
</style>

<div class="top-bar">
  <span>Mon–Sat 8am–8pm · Los Angeles &amp; Southern California</span>
  <a href={`tel:${phoneRaw}`}>{phone}</a>
</div>

<section class="hero">
  <div class="hero-inner">
    <div>
      <div class="hero-eyebrow">Elmira Stove Works Repair — Los Angeles</div>
      <h1 class="hero-title">
        Elmira Repair.<br/>
        <span>Northstar. Antique.</span><br/>
        Elmira, Ontario, 1975.
      </h1>
      <p class="hero-sub">
        Elmira Stove Works has been making retro-styled appliances with modern engineering in Elmira, Ontario since 1975. The Northstar refrigerator looks like 1955 but runs a modern compressor. The Antique range channels the diner kitchen aesthetic with real cooking performance. Chrome trim that needs specific care. Same day across LA.
      </p>
      <div class="hero-cta-group">
        <a href={`tel:${phoneRaw}`} class="btn-primary">Call {phone}</a>
        <a href="/book/" class="btn-secondary">Book Online</a>
      </div>
    </div>
    <div class="hero-badge-grid">
      <div class="hero-badge">
        <div class="badge-num">Same</div>
        <div class="badge-label">Day Service</div>
      </div>
      <div class="hero-badge">
        <div class="badge-num">OEM</div>
        <div class="badge-label">Elmira Parts</div>
      </div>
      <div class="hero-badge">
        <div class="badge-num">90-Day</div>
        <div class="badge-label">Warranty</div>
      </div>
      <div class="hero-badge">
        <div class="badge-num">$89</div>
        <div class="badge-label">Diagnostic Fee</div>
      </div>
    </div>
  </div>
</section>

<div class="trust-bar">
  <div class="trust-bar-inner">
    <span class="trust-item">Licensed &amp; Insured · CSLB #1138898</span>
    <span class="trust-item">Northstar Refrigerator Specialists</span>
    <span class="trust-item">Chrome Trim Protocol</span>
    <span class="trust-item">Antique &amp; Fireview Service</span>
    <span class="trust-item">Flat-Rate Written Estimate</span>
  </div>
</div>

<section class="section">
  <div class="section-inner">
    <div class="section-num">01 — About Elmira Stove Works</div>
    <h2 class="section-title">Elmira, Ontario, Canada. Retro Exterior. Modern Engineering. Since 1975.</h2>
    <p class="section-lead">
      Elmira Stove Works was founded in 1975 in Elmira, Ontario — a small town in the heart of Ontario's Mennonite country, roughly an hour west of Toronto. The company carved out a distinctive niche: appliances that look exactly like they came from a 1950s American diner kitchen, but run the modern engineering components that make them reliable, efficient, and serviceable today. A Northstar refrigerator looks like something from a Coca-Cola advertisement, but its sealed system, compressor, and defrost components are fully contemporary.
    </p>
    <p class="section-lead">
      In Los Angeles, Elmira has found its audience in the neighborhoods that celebrate mid-century American aesthetics: Silver Lake and Echo Park where "diner kitchen" is a deliberate design direction, Echo Park Craftsman renovations, and the Atwater Village and Los Feliz homes whose owners want retro without compromise on performance. Elmira owners know exactly what they have and why they chose it — their appliances deserve technicians who understand the retro-exterior / modern-internals principle that defines the brand.
    </p>

    <div class="products-grid">
      <div class="product-card featured">
        <div class="product-badge">Flagship Retro Refrigerator</div>
        <div class="product-name">Northstar Series</div>
        <div class="product-desc">1950s-inspired refrigerators with rounded retro body, chrome trim, period-correct styling, and full-size modern refrigerator internals. Available in multiple colors with chrome accent details. The signature Elmira product — immediately recognizable in any kitchen. Modern sealed system inside; chrome-trimmed retro shell outside. Diagnoses like a contemporary refrigerator.</div>
      </div>
      <div class="product-card">
        <div class="product-badge">Retro Kitchen Suite</div>
        <div class="product-name">Antique Series</div>
        <div class="product-desc">A complete 1950s-inspired cooking suite — ranges, wall ovens, microwaves, and dishwashers with the same retro aesthetic as the Northstar. The Antique range brings rounded chrome-accented styling to a full cooking range with modern gas or electric performance. The Model 1895 microwave (2.2 cu ft, 1200W, inverter technology) matches the suite perfectly.</div>
      </div>
      <div class="product-card">
        <div class="product-badge">Wood-Burning Cookstove</div>
        <div class="product-name">Fireview Series</div>
        <div class="product-desc">Elmira's wood-burning cookstove with a large glass viewing door — a unique product in the Elmira lineup and in the residential appliance market generally. Traditional wood cookstove functionality with the drama of a visible firebox. The glass door seal and viewing window are the primary service focus.</div>
      </div>
      <div class="product-card">
        <div class="product-badge">Retro Microwave</div>
        <div class="product-name">Model 1895 Microwave</div>
        <div class="product-desc">Elmira's retro-styled microwave — 2.2 cubic feet, 1200W output with inverter technology for even cooking power. 10 power levels, turbo-defrost, and five-stage programmable cooking in a period-correct rounded housing that coordinates with the Antique kitchen suite. The inverter board is the primary service component.</div>
      </div>
    </div>

    <div class="tip-block tip-chrome" style="margin-top:32px">
      <div class="tip-label">✨ Chrome Trim — Why It Requires Specific Service Care</div>
      <div class="tip-text">Elmira's Northstar and Antique series feature decorative chrome trim on handles, knob surrounds, and accent strips — a key element of the 1950s aesthetic. Chrome is electroplated, not solid metal: it's a thin layer of chromium over a base metal. Abrasive cleaners scratch through the chrome layer and into the base metal beneath, creating rust-prone spots that cannot be reversed without replating. Acid-based degreasers (citrus cleaners, vinegar solutions) etch the chrome surface and dull the finish. We use only non-abrasive chrome-safe cleaning agents on Elmira appliances and apply protective covers to all chrome during service. Scratched or pitted chrome on Elmira requires professional chrome restoration or replating — which we prevent by doing it right the first time.</div>
    </div>
  </div>
</section>

<section class="section section-gray">
  <div class="section-inner">
    <div class="section-num">02 — Services</div>
    <h2 class="section-title">Every Elmira Stove Works Appliance We Service</h2>
    <p class="section-lead">All Elmira models — Northstar, Antique, Fireview, Model 1895 — same-day across Los Angeles County.</p>

    <div class="services-grid">
      <div class="service-card">
        <div class="service-icon">❄️</div>
        <div class="service-name">Northstar Refrigerator Repair</div>
        <div class="service-desc">The Northstar refrigerator is the most mechanically straightforward Elmira appliance: modern refrigerator components in a custom retro shell. The sealed system (compressor, condenser, evaporator), defrost system, temperature control, evaporator fan, and door gaskets are all contemporary components that diagnose with standard modern refrigerator protocol. The chrome trim, custom door hinges for the rounded door, and retro door gasket profile are the Northstar-specific service considerations. We service all Northstar mechanical components using modern refrigerator diagnostics while protecting the retro exterior throughout every call.</div>
        <div class="service-issues">Common: not cooling · compressor · defrost system · evaporator fan · temperature sensor · door gasket (custom profile) · chrome door handle · condenser service · ice maker (if fitted)</div>
      </div>

      <div class="service-card">
        <div class="service-icon">🔥</div>
        <div class="service-name">Antique Range Repair</div>
        <div class="service-desc">The Elmira Antique range brings the retro aesthetic to a full cooking range — gas or electric configurations with modern burner and oven systems inside the period-correct rounded chrome-accented housing. Gas Antique ranges use standard residential gas valves and igniters; electric configurations use standard elements and controls. The chrome trim, rounded enamel body panels, and retro knob aesthetics are the Elmira-specific service considerations. The decorative knobs on Antique ranges sometimes have modern electronic controls beneath a retro exterior — turning the knob moves the aesthetic while the actual control is electronic.</div>
        <div class="service-issues">Common: igniter failure · oven temperature drift · burner not lighting · gas valve · oven element · temperature sensor · retro knob to electronic control interface · chrome trim care · enamel body protection</div>
      </div>

      <div class="service-card">
        <div class="service-icon">🪵</div>
        <div class="service-name">Fireview Wood Cookstove Service</div>
        <div class="service-desc">The Elmira Fireview is unique: a wood-burning cookstove with a large glass viewing door that makes the fire visible as a design element. The glass door seal is the primary service focus — creosote accumulation from wood smoke degrades the ceramic fiber gasket over time, reducing the seal integrity. The viewing glass itself can develop stress cracks from thermal cycling. The door hinge and latch system must withstand repeated temperature cycling. Also: Fireview installations in LA require proper flue permits and chimney clearance — we assess installation compliance at every Fireview service call.</div>
        <div class="service-issues">Common: glass door seal degradation · ceramic fiber gasket · door glass stress fracture · door hinge thermal wear · latch adjustment · firebox maintenance · flue draw assessment · LA installation compliance</div>
      </div>

      <div class="service-card">
        <div class="service-icon">📟</div>
        <div class="service-name">Model 1895 Microwave Repair</div>
        <div class="service-desc">The Elmira Model 1895 microwave uses inverter technology — a variable-power delivery system that provides more even cooking than traditional pulse-power microwaves. The inverter board is the most common failure component: when it fails, the microwave either doesn't heat or heats only at full power (the inverter is bypassed). We diagnose the inverter board before any magnetron assessment — inverter board failure is far more common than magnetron failure on inverter microwaves. The retro housing requires chrome-safe cleaning throughout service.</div>
        <div class="service-issues">Common: inverter board failure · not heating · heating at full power only · control panel · turntable motor · door latch · door switch · display fault · chrome housing care</div>
      </div>

      <div class="service-card">
        <div class="service-icon">🍽️</div>
