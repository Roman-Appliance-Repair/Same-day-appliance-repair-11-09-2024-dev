---
import Layout from '../layouts/Layout.astro';

const title = "JennAir Appliance Repair Los Angeles | RISE & NOIR Specialists";
const description = "Expert JennAir appliance repair in Los Angeles. Certified technicians for RISE™ and NOIR™ collections — ranges, ovens, refrigerators, dishwashers & more. Same-day service, OEM parts, 90-day warranty. Call (626) 376-4458.";
const phone = "(626) 376-4458";
const phoneRaw = "6263764458";
---

<Layout title={title} description={description}>

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "HomeAndConstructionBusiness",
  "name": "Same Day Appliance Repair — JennAir Specialist",
  "url": "https://samedayappliance.repair/brand-jennair-appliance-repair/",
  "telephone": "+16263764458",
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Los Angeles",
    "addressRegion": "CA",
    "postalCode": "90001",
    "addressCountry": "US"
  },
  "areaServed": ["Los Angeles County", "Orange County", "Ventura County"],
  "priceRange": "$$",
  "openingHours": "Mo-Sa 08:00-20:00",
  "hasOfferCatalog": {
    "@type": "OfferCatalog",
    "name": "JennAir Repair Services",
    "itemListElement": [
      {"@type":"Offer","itemOffered":{"@type":"Service","name":"JennAir Range Repair"}},
      {"@type":"Offer","itemOffered":{"@type":"Service","name":"JennAir Wall Oven Repair"}},
      {"@type":"Offer","itemOffered":{"@type":"Service","name":"JennAir Refrigerator Repair"}},
      {"@type":"Offer","itemOffered":{"@type":"Service","name":"JennAir Dishwasher Repair"}},
      {"@type":"Offer","itemOffered":{"@type":"Service","name":"JennAir Cooktop Repair"}},
      {"@type":"Offer","itemOffered":{"@type":"Service","name":"JennAir NOIR Collection Repair"}}
    ]
  }
}
</script>

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "How much does JennAir appliance repair cost in Los Angeles?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Most JennAir repairs run $175–$600. Common fixes like an igniter replacement, door gasket, or temperature sensor are $175–$320. Control board work or dual-fan convection system repairs run higher. Diagnostic fee is $89, waived when you proceed. Written flat-rate estimate before work begins."
      }
    },
    {
      "@type": "Question",
      "name": "Do you service both JennAir RISE and NOIR collections?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes — both collections across all appliance types. RISE™ professional-style ranges with 25,000 BTU brass burners, and NOIR™ minimalist black-glass appliances with Obsidian interiors and cinematic lighting. Both use the Whirlpool platform for core components, with collection-specific finishes and electronics that require careful handling during service."
      }
    },
    {
      "@type": "Question",
      "name": "Can you repair JennAir NOIR appliances without scratching the black glass finish?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes. JennAir NOIR's black glass panels and Obsidian interior surfaces are significantly more scratch-sensitive than standard stainless steel. We use non-abrasive protective covers and avoid any contact between tools and the NOIR finish during service. We treat NOIR appliance calls with the same care as panel-ready installations."
      }
    },
    {
      "@type": "Question",
      "name": "Is JennAir part of Whirlpool?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes — JennAir is part of Whirlpool Corporation, alongside KitchenAid, Maytag, and Amana. Current JennAir appliances use the Whirlpool platform for core components. This means excellent parts availability and fast diagnosis — our deep KitchenAid and Whirlpool experience applies directly to JennAir repair."
      }
    },
    {
      "@type": "Question",
      "name": "What is JennAir's Culinary Center and how does it fail?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The JennAir Culinary Center is the touchscreen control interface on RISE and NOIR appliances that integrates recipe guidance, temperature management, and smart home connectivity. The most common failure: touch panel delamination or unresponsive zones after moisture exposure from cooking steam. We diagnose the panel vs. the control board behind it before recommending replacement — the panel itself is the most common fault."
      }
    },
    {
      "@type": "Question",
      "name": "How does JennAir's downdraft ventilation system fail?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "JennAir invented downdraft ventilation in 1961 — it remains a signature feature on many of their cooktops and ranges. Common failures: the downdraft blower motor loses efficiency, the lift mechanism sticks or fails to retract, or the grease filter becomes restricted. We service the complete downdraft assembly — motor, lift mechanism, filter, and duct connection."
      }
    }
  ]
}
</script>

<style>
  :root {
    --red: #C8102E;
    --black: #0a0a0a;
    --gray: #f5f5f5;
    --border: #e2e2e2;
    --text: #1a1a1a;
    --muted: #6b6b6b;
  }
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body { font-family: 'Barlow', 'Inter', system-ui, sans-serif; color: var(--text); }

  .top-bar { background: var(--red); padding: 8px 24px; display: flex; justify-content: space-between; align-items: center; font-size: 13px; color: #fff; }
  .top-bar a { color: #fff; text-decoration: none; font-weight: 700; }

  .hero { background: var(--black); padding: 72px 24px 64px; color: #fff; }
  .hero-inner { max-width: 1100px; margin: 0 auto; display: grid; grid-template-columns: 1fr 420px; gap: 48px; align-items: center; }
  .hero-eyebrow { font-size: 11px; font-weight: 700; letter-spacing: 0.15em; text-transform: uppercase; color: var(--red); margin-bottom: 16px; }
  .hero-title { font-size: clamp(32px, 5vw, 52px); font-weight: 900; line-height: 1.05; text-transform: uppercase; letter-spacing: -0.02em; margin-bottom: 20px; }
  .hero-title span { color: var(--red); }
  .hero-sub { font-size: 17px; line-height: 1.6; color: #aaa; margin-bottom: 32px; max-width: 540px; }
  .hero-cta-group { display: flex; gap: 16px; flex-wrap: wrap; }
  .btn-primary { display: inline-block; background: var(--red); color: #fff; padding: 14px 28px; font-size: 15px; font-weight: 700; text-decoration: none; letter-spacing: 0.04em; text-transform: uppercase; }
  .btn-secondary { display: inline-block; border: 1px solid #555; color: #ccc; padding: 14px 28px; font-size: 15px; font-weight: 600; text-decoration: none; letter-spacing: 0.04em; text-transform: uppercase; }
  .hero-badge-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
  .hero-badge { background: #161616; border: 1px solid #2a2a2a; padding: 16px 18px; }
  .badge-num { font-size: 28px; font-weight: 900; color: var(--red); line-height: 1; margin-bottom: 4px; }
  .badge-label { font-size: 12px; color: #888; text-transform: uppercase; letter-spacing: 0.08em; }

  .trust-bar { background: var(--red); padding: 14px 24px; }
  .trust-bar-inner { max-width: 1100px; margin: 0 auto; display: flex; justify-content: space-between; flex-wrap: wrap; gap: 8px; }
  .trust-item { color: #fff; font-size: 13px; font-weight: 600; letter-spacing: 0.04em; text-transform: uppercase; }
  .trust-item::before { content: "✓ "; }

  .section { padding: 64px 24px; }
  .section-gray { background: var(--gray); }
  .section-black { background: var(--black); color: #fff; }
  .section-inner { max-width: 1100px; margin: 0 auto; }
  .section-num { font-size: 11px; font-weight: 700; letter-spacing: 0.15em; text-transform: uppercase; color: var(--red); margin-bottom: 8px; }
  .section-title { font-size: clamp(24px, 3.5vw, 36px); font-weight: 900; text-transform: uppercase; letter-spacing: -0.01em; margin-bottom: 20px; }
  .section-black .section-title { color: #fff; }
  .section-lead { font-size: 17px; line-height: 1.7; color: var(--muted); max-width: 760px; margin-bottom: 40px; }
  .section-black .section-lead { color: #999; }

  /* Collection cards */
  .collection-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1px; background: #2a2a2a; border: 1px solid #2a2a2a; margin-top: 28px; }
  .collection-card { background: #161616; padding: 28px 24px; }
  .collection-name { font-size: 22px; font-weight: 900; text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 6px; }
  .rise-name { color: #c8a040; }
  .noir-name { color: #aaa; }
  .collection-tagline { font-size: 12px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.12em; color: var(--red); margin-bottom: 14px; }
  .collection-desc { font-size: 14px; color: #888; line-height: 1.65; margin-bottom: 16px; }
  .collection-features { list-style: none; }
  .collection-features li { font-size: 13px; color: #666; padding: 5px 0; border-bottom: 1px solid #222; }
  .collection-features li::before { content: "· "; color: var(--red); }

  .tip-block { border-left: 3px solid var(--red); background: #fff8f8; padding: 18px 20px; margin: 32px 0; max-width: 760px; }
  .tip-label { font-size: 10px; font-weight: 800; text-transform: uppercase; letter-spacing: 0.15em; color: var(--red); margin-bottom: 6px; }
  .tip-text { font-size: 14px; line-height: 1.65; color: var(--text); }
  .tip-blue { border-color: #3a7bd5; background: #f0f7ff; }
  .tip-blue .tip-label { color: #3a7bd5; }
  .tip-noir { border-color: #555; background: #f8f8f8; }
  .tip-noir .tip-label { color: #333; }

  .services-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 1px; background: var(--border); border: 1px solid var(--border); }
  .service-card { background: #fff; padding: 28px 24px; }
  .service-icon { font-size: 28px; margin-bottom: 12px; }
  .service-name { font-size: 16px; font-weight: 800; text-transform: uppercase; letter-spacing: 0.04em; margin-bottom: 10px; color: var(--text); }
  .service-desc { font-size: 14px; line-height: 1.65; color: var(--muted); margin-bottom: 12px; }
  .service-issues { font-size: 12px; color: var(--red); font-weight: 600; text-transform: uppercase; letter-spacing: 0.06em; }

  .features-2col { display: grid; grid-template-columns: 1fr 1fr; gap: 48px; align-items: start; }
  .features-list { list-style: none; }
  .features-list li { padding: 14px 0; border-bottom: 1px solid #2a2a2a; font-size: 15px; color: #ccc; display: flex; gap: 12px; }
  .features-list li::before { content: "→"; color: var(--red); flex-shrink: 0; }

  .problems-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(260px, 1fr)); gap: 16px; margin-top: 32px; }
  .problem-card { border: 1px solid var(--border); background: #fff; padding: 20px; }
  .problem-title { font-size: 14px; font-weight: 800; text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 8px; color: var(--text); }
  .problem-cause { font-size: 13px; color: var(--muted); line-height: 1.6; margin-bottom: 10px; }
  .problem-tag { display: inline-block; font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; padding: 3px 8px; color: #fff; }
  .tag-common { background: var(--red); }
  .tag-noir { background: #333; }
  .tag-rise { background: #8b6914; }
  .tag-la { background: #2a5ea5; }

  .pricing-table { width: 100%; border-collapse: collapse; margin-top: 24px; }
  .pricing-table th { background: var(--text); color: #fff; text-align: left; padding: 12px 16px; font-size: 12px; text-transform: uppercase; letter-spacing: 0.08em; }
  .pricing-table td { padding: 14px 16px; border-bottom: 1px solid var(--border); font-size: 14px; }
  .pricing-table tr:last-child td { border-bottom: none; }
  .pricing-table tr:nth-child(even) td { background: var(--gray); }
  .price-range { font-weight: 700; color: var(--red); }

  .why-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: 24px; margin-top: 32px; }
  .why-card { border-left: 3px solid var(--red); padding: 20px; background: #fff; }
  .why-icon { font-size: 24px; margin-bottom: 10px; }
  .why-title { font-size: 14px; font-weight: 800; text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 8px; }
  .why-desc { font-size: 13px; color: var(--muted); line-height: 1.6; }

  .reviews-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 20px; margin-top: 32px; }
  .review-card { background: #fff; border: 1px solid var(--border); padding: 24px; }
  .review-stars { color: var(--red); font-size: 18px; margin-bottom: 10px; }
  .review-text { font-size: 14px; line-height: 1.7; color: var(--text); margin-bottom: 14px; }
  .review-author { font-size: 12px; font-weight: 700; text-transform: uppercase; color: var(--muted); }

  .repairs-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 1px; background: var(--border); border: 1px solid var(--border); margin-top: 32px; }
  .repair-item { background: #fff; padding: 24px; }
  .repair-appliance { font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; color: var(--red); margin-bottom: 6px; }
  .repair-issue { font-size: 15px; font-weight: 800; color: var(--text); margin-bottom: 8px; }
  .repair-detail { font-size: 13px; color: var(--muted); line-height: 1.6; }
  .repair-meta { margin-top: 12px; font-size: 12px; font-weight: 600; color: #aaa; text-transform: uppercase; letter-spacing: 0.06em; }

  .faq-list { margin-top: 32px; }
  .faq-item { border-bottom: 1px solid var(--border); padding: 20px 0; }
  .faq-q { font-size: 16px; font-weight: 800; color: var(--text); margin-bottom: 10px; }
  .faq-a { font-size: 14px; line-height: 1.7; color: var(--muted); max-width: 760px; }

  .nearby-grid { display: flex; flex-wrap: wrap; gap: 8px; margin-top: 20px; }
  .nearby-chip { background: var(--gray); border: 1px solid var(--border); padding: 8px 14px; font-size: 13px; color: var(--muted); text-decoration: none; font-weight: 600; }
  .nearby-chip:hover { border-color: var(--red); color: var(--red); }

  .bottom-cta { background: var(--black); padding: 72px 24px; text-align: center; color: #fff; }
  .bottom-cta-title { font-size: clamp(28px, 4vw, 44px); font-weight: 900; text-transform: uppercase; letter-spacing: -0.01em; margin-bottom: 12px; }
  .bottom-cta-title span { color: var(--red); }
  .bottom-cta-sub { font-size: 17px; color: #888; margin-bottom: 32px; }
  .cta-phone-large { display: inline-block; font-size: clamp(28px, 4vw, 42px); font-weight: 900; color: #fff; text-decoration: none; letter-spacing: -0.01em; margin-bottom: 24px; border-bottom: 2px solid var(--red); padding-bottom: 4px; }

  @media (max-width: 768px) {
    .hero-inner { grid-template-columns: 1fr; }
    .hero-badge-grid { grid-template-columns: 1fr 1fr; }
    .features-2col { grid-template-columns: 1fr; }
    .collection-grid { grid-template-columns: 1fr; }
    .trust-bar-inner { flex-direction: column; gap: 6px; }
  }
</style>

<!-- TOP BAR -->
<div class="top-bar">
  <span>Mon–Sat 8am–8pm · Los Angeles &amp; Southern California</span>
  <a href={`tel:${phoneRaw}`}>{phone}</a>
</div>

<!-- HERO -->
<section class="hero">
  <div class="hero-inner">
    <div>
      <div class="hero-eyebrow">JennAir Appliance Repair — Los Angeles</div>
      <h1 class="hero-title">
        JennAir Repair.<br/>
        <span>RISE™ &amp; NOIR™.</span><br/>
        Both Collections.
      </h1>
      <p class="hero-sub">
        JennAir calls it "rebel luxury" — RISE for professional power with 25,000 BTU brass burners, NOIR for minimalist black-glass design with Obsidian interiors and cinematic lighting. We service both collections, same day, with the care that black glass demands and the platform knowledge that Whirlpool makes possible.
      </p>
      <div class="hero-cta-group">
        <a href={`tel:${phoneRaw}`} class="btn-primary">Call {phone}</a>
        <a href="/book/" class="btn-secondary">Book Online</a>
      </div>
    </div>
    <div class="hero-badge-grid">
      <div class="hero-badge">
        <div class="badge-num">Same</div>
        <div class="badge-label">Day Service</div>
      </div>
      <div class="hero-badge">
        <div class="badge-num">OEM</div>
        <div class="badge-label">JennAir Parts</div>
      </div>
      <div class="hero-badge">
        <div class="badge-num">90-Day</div>
        <div class="badge-label">Warranty</div>
      </div>
      <div class="hero-badge">
        <div class="badge-num">$89</div>
        <div class="badge-label">Diagnostic Fee</div>
      </div>
    </div>
  </div>
</section>

<!-- TRUST BAR -->
<div class="trust-bar">
  <div class="trust-bar-inner">
    <span class="trust-item">Licensed &amp; Insured · CSLB #1138898</span>
    <span class="trust-item">RISE™ &amp; NOIR™ Specialists</span>
    <span class="trust-item">Genuine JennAir OEM Parts</span>
    <span class="trust-item">NOIR Black Glass — No Scratch Protocol</span>
    <span class="trust-item">Flat-Rate Written Estimate</span>
  </div>
</div>

<!-- 01 — RISE & NOIR -->
<section class="section">
  <div class="section-inner">
    <div class="section-num">01 — The Collections</div>
    <h2 class="section-title">RISE™ and NOIR™ — Two Expressions of "Rebel Luxury"</h2>
    <p class="section-lead">
      JennAir rebranded around 2018 with a bold identity: "rebel luxury." The brand split its lineup into two distinct design expressions, each with its own aesthetic logic and specific technologies. Understanding which collection you have is the first step in any JennAir service call — the components, finishes, and diagnostic approach differ between them.
    </p>

    <div class="collection-grid">
      <div class="collection-card">
        <div class="collection-name rise-name">RISE™</div>
        <div class="collection-tagline">Professional Power · Bold Industrial Design</div>
        <div class="collection-desc">RISE takes JennAir's professional heritage and makes it visible. Brushed stainless, prominent hardware, 25,000 BTU brass burners, the Culinary Center touchscreen, and V2™ Vertical Dual-Fan convection. This is the collection for homeowners who want a professional kitchen aesthetic with actual professional performance.</div>
        <ul class="collection-features">
          <li>25,000 BTU brass burners — highest in class</li>
          <li>V2™ Vertical Dual-Fan convection system</li>
          <li>JennAir Culinary Center touchscreen</li>
          <li>30", 36", 48" professional-style ranges</li>
          <li>Built-in column refrigerators</li>
          <li>Downdraft ventilation integration</li>
        </ul>
      </div>
      <div class="collection-card">
        <div class="collection-name noir-name">NOIR™</div>
        <div class="collection-tagline">Minimalist Black Glass · Hidden Hardware</div>
        <div class="collection-desc">NOIR eliminates visible hardware in favor of seamless black glass surfaces, Obsidian interiors, and cinematic LED lighting inside refrigerators and dishwashers. Same high-performance components as RISE, hidden behind a design language that prioritizes visual integration over professional aesthetics.</div>
        <ul class="collection-features">
          <li>Black glass panel surfaces throughout</li>
          <li>Obsidian interior finish — oven and dishwasher</li>
          <li>Cinematic LED lighting — refrigerator and dishwasher</li>
          <li>Hidden touch controls</li>
          <li>38 dBA ultra-quiet dishwasher</li>
          <li>Panel-ready integration options</li>
        </ul>
      </div>
    </div>

    <div class="tip-block tip-noir" style="margin-top:32px">
      <div class="tip-label">⬛ NOIR Black Glass — Our Service Protocol</div>
      <div class="tip-text">JennAir NOIR's black glass panels and Obsidian interior surfaces scratch at contact pressure that stainless steel would shrug off. We apply non-abrasive protective covers to all adjacent surfaces before any service work on NOIR appliances. Tools never contact the glass or Obsidian finish directly. Reinstallation is verified visually before the job is considered complete. This isn't special treatment — it's the minimum standard for NOIR service.</div>
    </div>
  </div>
</section>

<!-- 02 — SERVICES -->
<section class="section section-gray">
  <div class="section-inner">
    <div class="section-num">02 — Services</div>
    <h2 class="section-title">Every JennAir Appliance We Service</h2>
    <p class="section-lead">All RISE™ and NOIR™ models across all appliance categories. Same-day availability across Los Angeles County.</p>

    <div class="services-grid">
      <div class="service-card">
        <div class="service-icon">🔥</div>
        <div class="service-name">Range &amp; Cooktop Repair</div>
        <div class="service-desc">RISE gas, dual-fuel, and induction ranges (30", 36", 48") and NOIR equivalents. The 25,000 BTU brass burners on RISE require specific OEM igniters — the higher BTU output creates different thermal stress on igniter ceramics than standard burners. We also service JennAir's signature downdraft cooktops, a technology JennAir invented in 1961.</div>
        <div class="service-issues">Common: brass burner igniter failure · oven temperature off · V2 convection fan · downdraft motor · touch panel unresponsive · control board · door gasket · dual-fuel ignition</div>
      </div>

      <div class="service-card">
        <div class="service-icon">🌡️</div>
        <div class="service-name">Wall Oven Repair</div>
        <div class="service-desc">RISE and NOIR single, double, and combination wall ovens with V2™ Vertical Dual-Fan convection. The dual-fan system moves more air volume than single-fan convection — when one fan fails, baking results become uneven in a pattern that's easy to misdiagnose as a heating element issue. We test each fan independently.</div>
        <div class="service-issues">Common: V2 convection fan failure · uneven baking · temperature sensor · door gasket · Obsidian interior damage (NOIR) · self-clean fault · control board · steam oven circuit</div>
      </div>

      <div class="service-card">
        <div class="service-icon">❄️</div>
        <div class="service-name">Refrigerator Repair</div>
        <div class="service-desc">RISE and NOIR built-in column refrigerators, French door models, and under-counter beverage centers. NOIR models include cinematic LED lighting that owners notice immediately when it fails — a minor component but a visible one. Column refrigerators are panel-ready; service requires protective handling of the integrated panel system.</div>
        <div class="service-issues">Common: not cooling · ice maker failure · cinematic lighting (NOIR) · temperature fluctuation · door gasket · compressor · control board · water dispenser · condenser service</div>
      </div>

      <div class="service-card">
        <div class="service-icon">🍽️</div>
        <div class="service-name">Dishwasher Repair</div>
        <div class="service-desc">RISE and NOIR dishwashers — the NOIR model is among the quietest at 38 dBA, with Obsidian racks and interior and cinematic lighting. Any noise on a NOIR dishwasher is immediately obvious to the owner. We service the wash pump, drain system, door latch, and NOIR-specific Obsidian rack system without surface damage.</div>
        <div class="service-issues">Common: not draining · not cleaning · noise (immediately noticeable at 38 dBA) · Obsidian rack damage · door latch · control board · water inlet · heating element</div>
      </div>

      <div class="service-card">
        <div class="service-icon">📱</div>
        <div class="service-name">Culinary Center &amp; Controls</div>
        <div class="service-desc">JennAir's Culinary Center is the touchscreen interface that integrates recipe guidance, precise temperature management, and smart home connectivity across RISE and NOIR appliances. Touch panel delamination or unresponsive zones — often caused by cooking steam condensation behind the glass — are among the most common JennAir service calls we receive.</div>
        <div class="service-issues">Common: unresponsive touch zones · screen delamination · Wi-Fi connectivity loss · software error codes · display not turning on · panel separation</div>
      </div>

      <div class="service-card">
        <div class="service-icon">💨</div>
        <div class="service-name">Downdraft &amp; Ventilation Repair</div>
        <div class="service-desc">JennAir invented downdraft ventilation in 1961 — it remains a signature product. The retractable downdraft system on JennAir cooktops and ranges lifts from behind the cooking surface to capture smoke and steam at the source. The lift mechanism and blower motor are the most common failure points. We service both, plus the overhead hood systems on RISE and NOIR.</div>
        <div class="service-issues">Common: downdraft motor failure · lift mechanism stuck · won't retract · filter restriction · overhead hood motor · speed selector · lighting</div>
      </div>
    </div>

