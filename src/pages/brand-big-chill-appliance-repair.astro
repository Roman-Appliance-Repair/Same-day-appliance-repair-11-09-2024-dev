---
import Layout from '../layouts/Layout.astro';

const title = "Big Chill Appliance Repair Los Angeles | Retro Range & Refrigerator Specialists";
const description = "Expert Big Chill appliance repair in Los Angeles. Classic & Pro series — retro styling with GE-sourced internals, 37+ custom colors, powder coat care. Boulder, Colorado since 2001. Same-day service. Call (626) 376-4458.";
const phone = "(626) 376-4458";
const phoneRaw = "6263764458";
---

<Layout title={title} description={description}>

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "HomeAndConstructionBusiness",
  "name": "Same Day Appliance Repair — Big Chill Specialist",
  "url": "https://samedayappliance.repair/brand-big-chill-appliance-repair/",
  "telephone": "+16263764458",
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Los Angeles",
    "addressRegion": "CA",
    "postalCode": "90001",
    "addressCountry": "US"
  },
  "areaServed": ["Los Angeles County", "Orange County", "Ventura County"],
  "priceRange": "$$",
  "openingHours": "Mo-Sa 08:00-20:00",
  "hasOfferCatalog": {
    "@type": "OfferCatalog",
    "name": "Big Chill Repair Services",
    "itemListElement": [
      {"@type":"Offer","itemOffered":{"@type":"Service","name":"Big Chill Retro Range Repair"}},
      {"@type":"Offer","itemOffered":{"@type":"Service","name":"Big Chill Refrigerator Repair"}},
      {"@type":"Offer","itemOffered":{"@type":"Service","name":"Big Chill Pro Range Repair"}},
      {"@type":"Offer","itemOffered":{"@type":"Service","name":"Big Chill Dishwasher Repair"}},
      {"@type":"Offer","itemOffered":{"@type":"Service","name":"Big Chill Outdoor Appliance Repair"}},
      {"@type":"Offer","itemOffered":{"@type":"Service","name":"Big Chill Powder Coat Finish Service"}}
    ]
  }
}
</script>

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "How much does Big Chill appliance repair cost in Los Angeles?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Most Big Chill repairs run $165–$520. Common fixes like an igniter, temperature sensor, door gasket, or control board are on the lower end. Sealed system or compressor service runs higher. Diagnostic fee is $89, waived when you proceed. Big Chill's GE-sourced internals mean parts are typically available through standard channels. Written flat-rate estimate before work begins."
      }
    },
    {
      "@type": "Question",
      "name": "Where is Big Chill made?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Big Chill was founded in 2001 in Boulder, Colorado by Thom Gillespie and Margaret Carroll. The brand designs its retro-inspired appliances in Boulder and sources its core mechanical components from established US appliance manufacturers — primarily GE for refrigerators and cooking appliances. This gives Big Chill the visual identity of a boutique retro brand with the mechanical reliability and parts availability of a major domestic manufacturer."
      }
    },
    {
      "@type": "Question",
      "name": "Does the Big Chill refrigerator use special components?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "No — Big Chill refrigerators use GE-sourced mechanical components inside the custom retro shell. The compressor, sealed system, defrost components, and temperature controls are GE platform parts with broad US availability. The retro exterior elements (custom powder coat finish, rounded door styling, chrome accents) require careful handling during service, but the mechanical diagnosis follows standard modern refrigerator protocol."
      }
    },
    {
      "@type": "Question",
      "name": "What is the difference between Big Chill Classic and Big Chill Pro?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The Big Chill Classic is the original retro-styled line — rounded 1950s-inspired body with a curated color palette and chrome accents. The Big Chill Pro takes the same retro aesthetic with a more professional cooking specification — higher BTU burners, larger oven capacity, and commercial-inspired design details alongside the signature color options. Both series use GE-sourced core components. Service protocols are identical."
      }
    },
    {
      "@type": "Question",
      "name": "How do you protect Big Chill's custom powder coat colors during service?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Big Chill's custom powder coat finish — one of the brand's signature features, available in 37+ colors — requires non-abrasive cleaning agents throughout service. Powder coat is a baked-on paint finish that resists scratching better than liquid paint but is still vulnerable to abrasive cleaners that cut through the surface coat. We apply protective covers to all Big Chill powder coat surfaces before service and use only non-abrasive, pH-neutral cleaning agents during any work that involves the appliance exterior."
      }
    }
  ]
}
</script>

<style>
  :root {
    --red: #C8102E;
    --black: #0a0a0a;
    --gray: #f5f5f5;
    --border: #e2e2e2;
    --text: #1a1a1a;
    --muted: #6b6b6b;
  }
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body { font-family: 'Barlow', 'Inter', system-ui, sans-serif; color: var(--text); }

  .top-bar { background: var(--red); padding: 8px 24px; display: flex; justify-content: space-between; align-items: center; font-size: 13px; color: #fff; }
  .top-bar a { color: #fff; text-decoration: none; font-weight: 700; }

  .hero { background: var(--black); padding: 72px 24px 64px; color: #fff; }
  .hero-inner { max-width: 1100px; margin: 0 auto; display: grid; grid-template-columns: 1fr 420px; gap: 48px; align-items: center; }
  .hero-eyebrow { font-size: 11px; font-weight: 700; letter-spacing: 0.15em; text-transform: uppercase; color: var(--red); margin-bottom: 16px; }
  .hero-title { font-size: clamp(32px, 5vw, 52px); font-weight: 900; line-height: 1.05; text-transform: uppercase; letter-spacing: -0.02em; margin-bottom: 20px; }
  .hero-title span { color: var(--red); }
  .hero-sub { font-size: 17px; line-height: 1.6; color: #aaa; margin-bottom: 32px; max-width: 540px; }
  .hero-cta-group { display: flex; gap: 16px; flex-wrap: wrap; }
  .btn-primary { display: inline-block; background: var(--red); color: #fff; padding: 14px 28px; font-size: 15px; font-weight: 700; text-decoration: none; letter-spacing: 0.04em; text-transform: uppercase; }
  .btn-secondary { display: inline-block; border: 1px solid #555; color: #ccc; padding: 14px 28px; font-size: 15px; font-weight: 600; text-decoration: none; letter-spacing: 0.04em; text-transform: uppercase; }
  .hero-badge-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
  .hero-badge { background: #161616; border: 1px solid #2a2a2a; padding: 16px 18px; }
  .badge-num { font-size: 22px; font-weight: 900; color: var(--red); line-height: 1; margin-bottom: 4px; }
  .badge-label { font-size: 12px; color: #888; text-transform: uppercase; letter-spacing: 0.08em; }

  .trust-bar { background: var(--red); padding: 14px 24px; }
  .trust-bar-inner { max-width: 1100px; margin: 0 auto; display: flex; justify-content: space-between; flex-wrap: wrap; gap: 8px; }
  .trust-item { color: #fff; font-size: 13px; font-weight: 600; letter-spacing: 0.04em; text-transform: uppercase; }
  .trust-item::before { content: "✓ "; }

  .section { padding: 64px 24px; }
  .section-gray { background: var(--gray); }
  .section-black { background: var(--black); color: #fff; }
  .section-inner { max-width: 1100px; margin: 0 auto; }
  .section-num { font-size: 11px; font-weight: 700; letter-spacing: 0.15em; text-transform: uppercase; color: var(--red); margin-bottom: 8px; }
  .section-title { font-size: clamp(24px, 3.5vw, 36px); font-weight: 900; text-transform: uppercase; letter-spacing: -0.01em; margin-bottom: 20px; }
  .section-black .section-title { color: #fff; }
  .section-lead { font-size: 17px; line-height: 1.7; color: var(--muted); max-width: 760px; margin-bottom: 40px; }
  .section-black .section-lead { color: #999; }

  .products-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1px; background: #2a2a2a; border: 1px solid #2a2a2a; margin-top: 28px; }
  .product-card { background: #161616; padding: 20px 18px; }
  .product-badge { font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; color: var(--red); margin-bottom: 8px; }
  .product-name { font-size: 15px; font-weight: 900; text-transform: uppercase; color: #fff; margin-bottom: 8px; }
  .product-desc { font-size: 12px; color: #666; line-height: 1.6; }

  .tip-block { border-left: 3px solid var(--red); background: #fff8f8; padding: 18px 20px; margin: 32px 0; max-width: 760px; }
  .tip-label { font-size: 10px; font-weight: 800; text-transform: uppercase; letter-spacing: 0.15em; color: var(--red); margin-bottom: 6px; }
  .tip-text { font-size: 14px; line-height: 1.65; color: var(--text); }
  .tip-ge { border-color: #2a5ea5; background: #f0f7ff; }
  .tip-ge .tip-label { color: #2a5ea5; }
  .tip-color { border-color: #c8820a; background: #fff8f0; }
  .tip-color .tip-label { color: #c8820a; }

  .services-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 1px; background: var(--border); border: 1px solid var(--border); }
  .service-card { background: #fff; padding: 28px 24px; }
  .service-icon { font-size: 28px; margin-bottom: 12px; }
  .service-name { font-size: 16px; font-weight: 800; text-transform: uppercase; letter-spacing: 0.04em; margin-bottom: 10px; color: var(--text); }
  .service-desc { font-size: 14px; line-height: 1.65; color: var(--muted); margin-bottom: 12px; }
  .service-issues { font-size: 12px; color: var(--red); font-weight: 600; text-transform: uppercase; letter-spacing: 0.06em; }

  .features-2col { display: grid; grid-template-columns: 1fr 1fr; gap: 48px; align-items: start; }
  .features-list { list-style: none; }
  .features-list li { padding: 14px 0; border-bottom: 1px solid #2a2a2a; font-size: 15px; color: #ccc; display: flex; gap: 12px; }
  .features-list li::before { content: "→"; color: var(--red); flex-shrink: 0; }

  .problems-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(260px, 1fr)); gap: 16px; margin-top: 32px; }
  .problem-card { border: 1px solid var(--border); background: #fff; padding: 20px; }
  .problem-title { font-size: 14px; font-weight: 800; text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 8px; color: var(--text); }
  .problem-cause { font-size: 13px; color: var(--muted); line-height: 1.6; margin-bottom: 10px; }
  .problem-tag { display: inline-block; font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; padding: 3px 8px; color: #fff; }
  .tag-fridge { background: #2a5ea5; }
  .tag-range { background: #c8820a; }
  .tag-finish { background: #555; }
  .tag-common { background: var(--red); }

  .pricing-table { width: 100%; border-collapse: collapse; margin-top: 24px; }
  .pricing-table th { background: var(--text); color: #fff; text-align: left; padding: 12px 16px; font-size: 12px; text-transform: uppercase; letter-spacing: 0.08em; }
  .pricing-table td { padding: 14px 16px; border-bottom: 1px solid var(--border); font-size: 14px; }
  .pricing-table tr:last-child td { border-bottom: none; }
  .pricing-table tr:nth-child(even) td { background: var(--gray); }
  .price-range { font-weight: 700; color: var(--red); }

  .why-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: 24px; margin-top: 32px; }
  .why-card { border-left: 3px solid var(--red); padding: 20px; background: #fff; }
  .why-icon { font-size: 24px; margin-bottom: 10px; }
  .why-title { font-size: 14px; font-weight: 800; text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 8px; }
  .why-desc { font-size: 13px; color: var(--muted); line-height: 1.6; }

  .reviews-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 20px; margin-top: 32px; }
  .review-card { background: #fff; border: 1px solid var(--border); padding: 24px; }
  .review-stars { color: var(--red); font-size: 18px; margin-bottom: 10px; }
  .review-text { font-size: 14px; line-height: 1.7; color: var(--text); margin-bottom: 14px; }
  .review-author { font-size: 12px; font-weight: 700; text-transform: uppercase; color: var(--muted); }

  .repairs-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 1px; background: var(--border); border: 1px solid var(--border); margin-top: 32px; }
  .repair-item { background: #fff; padding: 24px; }
  .repair-appliance { font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; color: var(--red); margin-bottom: 6px; }
  .repair-issue { font-size: 15px; font-weight: 800; color: var(--text); margin-bottom: 8px; }
  .repair-detail { font-size: 13px; color: var(--muted); line-height: 1.6; }
  .repair-meta { margin-top: 12px; font-size: 12px; font-weight: 600; color: #aaa; text-transform: uppercase; letter-spacing: 0.06em; }

  .faq-list { margin-top: 32px; }
  .faq-item { border-bottom: 1px solid var(--border); padding: 20px 0; }
  .faq-q { font-size: 16px; font-weight: 800; color: var(--text); margin-bottom: 10px; }
  .faq-a { font-size: 14px; line-height: 1.7; color: var(--muted); max-width: 760px; }

  .nearby-grid { display: flex; flex-wrap: wrap; gap: 8px; margin-top: 20px; }
  .nearby-chip { background: var(--gray); border: 1px solid var(--border); padding: 8px 14px; font-size: 13px; color: var(--muted); text-decoration: none; font-weight: 600; }
  .nearby-chip:hover { border-color: var(--red); color: var(--red); }

  .bottom-cta { background: var(--black); padding: 72px 24px; text-align: center; color: #fff; }
  .bottom-cta-title { font-size: clamp(28px, 4vw, 44px); font-weight: 900; text-transform: uppercase; letter-spacing: -0.01em; margin-bottom: 12px; }
  .bottom-cta-title span { color: var(--red); }
  .bottom-cta-sub { font-size: 17px; color: #888; margin-bottom: 32px; }
  .cta-phone-large { display: inline-block; font-size: clamp(28px, 4vw, 42px); font-weight: 900; color: #fff; text-decoration: none; letter-spacing: -0.01em; margin-bottom: 24px; border-bottom: 2px solid var(--red); padding-bottom: 4px; }

  @media (max-width: 768px) {
    .hero-inner { grid-template-columns: 1fr; }
    .hero-badge-grid { grid-template-columns: 1fr 1fr; }
    .features-2col { grid-template-columns: 1fr; }
    .products-grid { grid-template-columns: 1fr; }
    .trust-bar-inner { flex-direction: column; gap: 6px; }
  }
</style>

<div class="top-bar">
  <span>Mon–Sat 8am–8pm · Los Angeles &amp; Southern California</span>
  <a href={`tel:${phoneRaw}`}>{phone}</a>
</div>

<section class="hero">
  <div class="hero-inner">
    <div>
      <div class="hero-eyebrow">Big Chill Appliance Repair — Los Angeles</div>
      <h1 class="hero-title">
        Big Chill Repair.<br/>
        <span>Classic. Pro. 37+ Colors.</span><br/>
        Boulder, Colorado, 2001.
      </h1>
      <p class="hero-sub">
        Big Chill has been making the most color-forward retro kitchen appliances in America since 2001. The Classic and Pro series bring 1950s-inspired styling with GE-sourced mechanical internals — modern reliability behind the custom powder coat finish. Same-day across LA.
      </p>
      <div class="hero-cta-group">
        <a href={`tel:${phoneRaw}`} class="btn-primary">Call {phone}</a>
        <a href="/book/" class="btn-secondary">Book Online</a>
      </div>
    </div>
    <div class="hero-badge-grid">
      <div class="hero-badge">
        <div class="badge-num">Same</div>
        <div class="badge-label">Day Service</div>
      </div>
      <div class="hero-badge">
        <div class="badge-num">GE</div>
        <div class="badge-label">Platform Parts</div>
      </div>
      <div class="hero-badge">
        <div class="badge-num">90-Day</div>
        <div class="badge-label">Warranty</div>
      </div>
      <div class="hero-badge">
        <div class="badge-num">$89</div>
        <div class="badge-label">Diagnostic Fee</div>
      </div>
    </div>
  </div>
</section>

<div class="trust-bar">
  <div class="trust-bar-inner">
    <span class="trust-item">Licensed &amp; Insured · CSLB #1138898</span>
    <span class="trust-item">Big Chill Classic &amp; Pro Service</span>
    <span class="trust-item">GE Platform Diagnostics</span>
    <span class="trust-item">Powder Coat Finish Protocol</span>
    <span class="trust-item">Flat-Rate Written Estimate</span>
  </div>
</div>

<section class="section">
  <div class="section-inner">
    <div class="section-num">01 — About Big Chill</div>
    <h2 class="section-title">Boulder, Colorado. 37+ Custom Colors. GE Internals. Since 2001.</h2>
    <p class="section-lead">
      Big Chill was founded in 2001 in Boulder, Colorado by Thom Gillespie and Margaret Carroll — a husband and wife team who wanted the 1950s kitchen aesthetic without the 1950s appliance reliability problems. Their solution: design retro-inspired appliances with wide-ranging custom color options and power the interiors with modern GE-sourced components. The result is a brand that offers 37+ custom powder coat colors (more than any other retro appliance brand), the visual warmth of a mid-century kitchen, and the mechanical reliability of a major US manufacturer's platform underneath.
    </p>
    <p class="section-lead">
      In Los Angeles, Big Chill has found a devoted following in the mid-century modern homes, Craftsman renovations, and design-forward apartments of Silver Lake, Los Feliz, Echo Park, and Atwater Village. Big Chill owners have typically spent significant time selecting a specific color from the brand's broad palette — Cherry Red, Peacock Blue, Avocado, Mint, Black, and dozens of others — and they expect service that respects that choice as much as the mechanical component beneath.
    </p>

    <div class="products-grid">
      <div class="product-card">
        <div class="product-badge">Original · Most Popular</div>
        <div class="product-name">Big Chill Classic</div>
        <div class="product-desc">Big Chill's original line — 1950s-inspired styling in 30" and 36" ranges, retro refrigerators, dishwashers, and microwaves. Rounded body lines, chrome accents, and 37+ custom powder coat colors. GE-sourced mechanical components. The appliance that established Big Chill's identity in the retro market.</div>
      </div>
      <div class="product-card">
        <div class="product-badge">Professional Performance</div>
        <div class="product-name">Big Chill Pro</div>
        <div class="product-desc">Big Chill's professional-grade line — the same retro aesthetic with higher-output burners, larger oven cavities, and commercial-inspired design details. Available in the full color palette. GE-sourced internals with an elevated performance specification for serious cooking households.</div>
      </div>
      <div class="product-card">
        <div class="product-badge">Outdoor</div>
        <div class="product-name">Big Chill Outdoor</div>
        <div class="product-desc">Big Chill's outdoor appliance line — refrigerators and keg coolers in weatherproof construction with the brand's signature retro styling. Designed for outdoor kitchens and entertaining spaces. LA's year-round outdoor living culture makes these popular in Malibu, Pacific Palisades, and Bel Air outdoor kitchen installations.</div>
      </div>
    </div>

    <div class="tip-block tip-ge" style="margin-top:32px">
      <div class="tip-label">⚡ GE Platform Internals — What It Means for Service</div>
      <div class="tip-text">Big Chill's decision to use GE-sourced mechanical components is the most practically important fact about the brand for service purposes. GE is the largest US appliance manufacturer with the broadest domestic parts distribution network. When a Big Chill refrigerator's defrost heater fails, or a Big Chill range's igniter degrades, or a Big Chill dishwasher's pump needs replacement — these are GE platform components available through the same extensive US supply chain that serves all GE appliances. Parts that would take weeks to source from an independent manufacturer are available within 24–48 hours through GE's parts channel. This is Big Chill's biggest practical service advantage over pure boutique retro brands.</div>
    </div>
  </div>
</section>

<section class="section section-gray">
  <div class="section-inner">
    <div class="section-num">02 — Services</div>
    <h2 class="section-title">Every Big Chill Appliance We Service</h2>
    <p class="section-lead">All Big Chill models — Classic, Pro, Outdoor — same-day across Los Angeles County.</p>

    <div class="services-grid">
      <div class="service-card">
        <div class="service-icon">🔥</div>
        <div class="service-name">Big Chill Range Repair</div>
        <div class="service-desc">Big Chill Classic and Pro gas and electric ranges — 30" and 36" configurations. The gas ranges use GE-platform sealed burners with ceramic igniters. The electric ranges use GE-platform bake and broil elements with convection fan option. Diagnosis follows GE range protocol — which means fast, accurate diagnosis from familiar architecture. The powder coat exterior requires protection throughout every service call.</div>
        <div class="service-issues">Common: igniter failure · oven temperature drift · burner not lighting · gas valve · oven element · temperature sensor · convection fan · door gasket · control board · powder coat protection throughout</div>
      </div>

      <div class="service-card">
        <div class="service-icon">❄️</div>
        <div class="service-name">Big Chill Refrigerator Repair</div>
        <div class="service-desc">Big Chill retro refrigerators — top freezer and French door configurations in the signature retro-inspired styling. GE-sourced sealed system, compressor, defrost components, temperature controls, and door gaskets. Diagnosis is modern GE refrigerator diagnosis — familiar platform, broad parts availability. Custom door hinge architecture for the retro body requires Elmira-style specific sourcing for cosmetic hardware. Coastal LA salt air can accelerate condenser coil oxidation on outdoor-adjacent installations.</div>
        <div class="service-issues">Common: not cooling · compressor · defrost system · evaporator fan · temperature sensor · door gasket · condenser service · ice maker · water dispenser · coastal condenser oxidation</div>
      </div>

      <div class="service-card">
        <div class="service-icon">🎨</div>
        <div class="service-name">Powder Coat Finish Care</div>
        <div class="service-desc">Big Chill's defining feature — available in 37+ custom powder coat colors from Cherry Red and Peacock Blue to Avocado, Mint, and dozens of custom options — requires specific care during service. Powder coat is a baked-on polymer finish: tougher than liquid paint but still vulnerable to abrasive cleaners that cut into the surface layer, and to acid-based agents that etch the finish. We use only non-abrasive, pH-neutral cleaning agents on Big Chill exteriors and apply microfiber protective covers before any service work begins.</div>
        <div class="service-issues">Powder coat protection on every service call. Non-abrasive, pH-neutral cleaning only. Microfiber covers on all colored surfaces before work begins. Damage assessment and touch-up referral for previous service damage.</div>
      </div>

      <div class="service-card">
        <div class="service-icon">🍽️</div>
        <div class="service-name">Big Chill Dishwasher Repair</div>
        <div class="service-desc">Big Chill dishwashers — integrated with the retro kitchen suite aesthetic, using GE-platform wash system components. LA hard water at 250–400 ppm accelerates spray arm scale accumulation. We address scale simultaneously with any component failure on Big Chill dishwasher calls, and advise on descaling frequency calibrated for LA water hardness rather than the standard US average.</div>
        <div class="service-issues">Common: not draining · spray arm scale (LA hard water) · pump motor · door latch · control board · water inlet · door gasket · LA water service · powder coat panel protection</div>
      </div>

      <div class="service-card">
        <div class="service-icon">🌿</div>
        <div class="service-name">Big Chill Outdoor Appliance Repair</div>
        <div class="service-desc">Big Chill outdoor refrigerators and keg coolers — weatherproof construction for outdoor kitchen installations. LA's coastal proximity affects outdoor appliances differently than indoor units: salt air accelerates condenser coil oxidation and compressor corrosion at properties within a few miles of the ocean. We service Big Chill outdoor appliances with awareness of the specific weathering patterns at LA coastal and canyon installations.</div>
        <div class="service-issues">Common: not cooling · condenser oxidation (coastal) · door seal · compressor · temperature inconsistency · keg pressure system · outdoor UV finish condition</div>
      </div>

      <div class="service-card">
        <div class="service-icon">📟</div>
        <div class="service-name">Big Chill Microwave Repair</div>
        <div class="service-desc">Big Chill over-range and countertop microwaves in the retro styling. GE-platform magnetron, control board, and door switch assembly. The retro housing requires powder coat care throughout service. Common failures follow GE microwave diagnostic patterns: door switch failure (most common cause of "doesn't work" calls), turntable motor, and magnetron (less common). We diagnose door switches before magnetron assessment — door switch failure is 10× more common.</div>
        <div class="service-issues">Common: door switch failure · not heating · turntable not turning · control panel · display fault · magnetron · powder coat housing protection · charcoal filter service</div>
      </div>
    </div>

