---
import Layout from '../layouts/Layout.astro';

const title = "Miele Appliance Repair Los Angeles | Same Day Service";
const description = "Expert Miele appliance repair in Los Angeles. Certified technicians for washers, dishwashers, ovens, refrigerators & coffee machines. Same-day service, genuine Miele OEM parts, 90-day warranty. Call (626) 376-4458.";
const phone = "(626) 376-4458";
const phoneRaw = "6263764458";
---

<Layout title={title} description={description}>

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "HomeAndConstructionBusiness",
  "name": "Same Day Appliance Repair — Miele Specialist",
  "image": "https://samedayappliance.repair/images/logo.png",
  "url": "https://samedayappliance.repair/brand-miele-appliance-repair/",
  "telephone": "+16263764458",
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Los Angeles",
    "addressRegion": "CA",
    "postalCode": "90001",
    "addressCountry": "US"
  },
  "areaServed": ["Los Angeles County", "Orange County", "Ventura County"],
  "priceRange": "$$",
  "openingHours": "Mo-Sa 08:00-20:00",
  "hasOfferCatalog": {
    "@type": "OfferCatalog",
    "name": "Miele Repair Services",
    "itemListElement": [
      {"@type":"Offer","itemOffered":{"@type":"Service","name":"Miele Washing Machine Repair"}},
      {"@type":"Offer","itemOffered":{"@type":"Service","name":"Miele Dishwasher Repair"}},
      {"@type":"Offer","itemOffered":{"@type":"Service","name":"Miele Dryer Repair"}},
      {"@type":"Offer","itemOffered":{"@type":"Service","name":"Miele Refrigerator Repair"}},
      {"@type":"Offer","itemOffered":{"@type":"Service","name":"Miele Oven Repair"}},
      {"@type":"Offer","itemOffered":{"@type":"Service","name":"Miele Coffee Machine Repair"}}
    ]
  }
}
</script>

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "How much does Miele appliance repair cost in Los Angeles?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Most Miele repairs run $175–$600. Washing machine drum bearing or carbon brush replacement is mid-range; control board work runs higher. Diagnostic fee is $89, waived when you proceed with repair. We provide a flat-rate written estimate before any work begins."
      }
    },
    {
      "@type": "Question",
      "name": "Do you repair Miele coffee machines?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes. We repair Miele CM and CVA series built-in coffee systems — descaling, milk system cleaning, brew unit replacement, grinder issues, and error code diagnosis. This is a specialized repair that many general appliance companies decline. We carry common brew unit and milk system parts on the truck."
      }
    },
    {
      "@type": "Question",
      "name": "Why does my Miele appliance show an error code in Los Angeles?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Los Angeles hard water is the most common culprit for Miele error codes — particularly F53 (intake/drain fault) on dishwashers and washing machines, and scale-related errors on coffee machines and steam ovens. LA water hardness runs 250–400 ppm, well above Miele's recommended threshold. We diagnose using Miele's diagnostic software to read fault history, not just the current error."
      }
    },
    {
      "@type": "Question",
      "name": "Is it worth repairing a Miele washer or dishwasher vs replacing it?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Almost always yes. Miele designs their washing machines and dishwashers to run 20 years / 10,000 operating hours. A Miele washer costs $1,800–$3,500 new. If your machine is under 15 years old and the repair is under 40% of replacement cost, repair is the clear choice. We give you that honest number on-site."
      }
    },
    {
      "@type": "Question",
      "name": "How often should Miele appliances be serviced in LA?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Annual preventive maintenance is smart in Los Angeles. Hard water scale builds up in dishwashers, washing machines, and steam ovens faster here than in most US cities. Coastal homes also see accelerated wear on external seals and condenser components. Annual service extends Miele's already long lifespan significantly."
      }
    },
    {
      "@type": "Question",
      "name": "Do you use genuine Miele OEM parts?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes, always. Miele appliances are engineered to tight tolerances — drum bearings, door seals, brew units, and control boards are model-specific. Generic parts rarely fit correctly and can void your remaining Miele warranty. We stock common Miele parts on every truck and source less common components within 1–2 business days."
      }
    }
  ]
}
</script>

<style>
  :root {
    --red: #C8102E;
    --black: #0a0a0a;
    --gray: #f5f5f5;
    --border: #e2e2e2;
    --text: #1a1a1a;
    --muted: #6b6b6b;
  }
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body { font-family: 'Barlow', 'Inter', system-ui, sans-serif; color: var(--text); }

  .top-bar { background: var(--red); padding: 8px 24px; display: flex; justify-content: space-between; align-items: center; font-size: 13px; color: #fff; }
  .top-bar a { color: #fff; text-decoration: none; font-weight: 700; }

  .hero { background: var(--black); padding: 72px 24px 64px; color: #fff; }
  .hero-inner { max-width: 1100px; margin: 0 auto; display: grid; grid-template-columns: 1fr 420px; gap: 48px; align-items: center; }
  .hero-eyebrow { font-size: 11px; font-weight: 700; letter-spacing: 0.15em; text-transform: uppercase; color: var(--red); margin-bottom: 16px; }
  .hero-title { font-size: clamp(32px, 5vw, 52px); font-weight: 900; line-height: 1.05; text-transform: uppercase; letter-spacing: -0.02em; margin-bottom: 20px; }
  .hero-title span { color: var(--red); }
  .hero-sub { font-size: 17px; line-height: 1.6; color: #aaa; margin-bottom: 32px; max-width: 540px; }
  .hero-cta-group { display: flex; gap: 16px; flex-wrap: wrap; }
  .btn-primary { display: inline-block; background: var(--red); color: #fff; padding: 14px 28px; font-size: 15px; font-weight: 700; text-decoration: none; letter-spacing: 0.04em; text-transform: uppercase; }
  .btn-secondary { display: inline-block; border: 1px solid #555; color: #ccc; padding: 14px 28px; font-size: 15px; font-weight: 600; text-decoration: none; letter-spacing: 0.04em; text-transform: uppercase; }
  .hero-badge-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
  .hero-badge { background: #161616; border: 1px solid #2a2a2a; padding: 16px 18px; }
  .badge-num { font-size: 28px; font-weight: 900; color: var(--red); line-height: 1; margin-bottom: 4px; }
  .badge-label { font-size: 12px; color: #888; text-transform: uppercase; letter-spacing: 0.08em; }

  .trust-bar { background: var(--red); padding: 14px 24px; }
  .trust-bar-inner { max-width: 1100px; margin: 0 auto; display: flex; justify-content: space-between; flex-wrap: wrap; gap: 8px; }
  .trust-item { color: #fff; font-size: 13px; font-weight: 600; letter-spacing: 0.04em; text-transform: uppercase; }
  .trust-item::before { content: "✓ "; }

  .section { padding: 64px 24px; }
  .section-gray { background: var(--gray); }
  .section-black { background: var(--black); color: #fff; }
  .section-inner { max-width: 1100px; margin: 0 auto; }
  .section-num { font-size: 11px; font-weight: 700; letter-spacing: 0.15em; text-transform: uppercase; color: var(--red); margin-bottom: 8px; }
  .section-title { font-size: clamp(24px, 3.5vw, 36px); font-weight: 900; text-transform: uppercase; letter-spacing: -0.01em; margin-bottom: 20px; }
  .section-black .section-title { color: #fff; }
  .section-lead { font-size: 17px; line-height: 1.7; color: var(--muted); max-width: 760px; margin-bottom: 40px; }
  .section-black .section-lead { color: #999; }

  .services-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 1px; background: var(--border); border: 1px solid var(--border); }
  .service-card { background: #fff; padding: 28px 24px; }
  .service-icon { font-size: 28px; margin-bottom: 12px; }
  .service-name { font-size: 16px; font-weight: 800; text-transform: uppercase; letter-spacing: 0.04em; margin-bottom: 10px; color: var(--text); }
  .service-desc { font-size: 14px; line-height: 1.65; color: var(--muted); margin-bottom: 12px; }
  .service-issues { font-size: 12px; color: var(--red); font-weight: 600; text-transform: uppercase; letter-spacing: 0.06em; }

  .tip-block { border-left: 3px solid var(--red); background: #fff8f8; padding: 18px 20px; margin: 32px 0; max-width: 760px; }
  .tip-label { font-size: 10px; font-weight: 800; text-transform: uppercase; letter-spacing: 0.15em; color: var(--red); margin-bottom: 6px; }
  .tip-text { font-size: 14px; line-height: 1.65; color: var(--text); }
  .tip-water { border-color: #3a7bd5; background: #f0f7ff; }
  .tip-water .tip-label { color: #3a7bd5; }

  .features-2col { display: grid; grid-template-columns: 1fr 1fr; gap: 48px; align-items: start; }
  .features-list { list-style: none; }
  .features-list li { padding: 14px 0; border-bottom: 1px solid #2a2a2a; font-size: 15px; color: #ccc; display: flex; gap: 12px; }
  .features-list li::before { content: "→"; color: var(--red); flex-shrink: 0; }

  .appliance-chips { display: flex; flex-wrap: wrap; gap: 10px; margin-top: 24px; }
  .appliance-chip { background: #161616; border: 1px solid #2a2a2a; color: #ccc; padding: 8px 16px; font-size: 13px; font-weight: 600; letter-spacing: 0.04em; text-transform: uppercase; }

  /* Error code table */
  .error-table { width: 100%; border-collapse: collapse; margin-top: 24px; }
  .error-table th { background: #1a1a1a; color: #fff; text-align: left; padding: 12px 16px; font-size: 12px; text-transform: uppercase; letter-spacing: 0.08em; }
  .error-table td { padding: 12px 16px; border-bottom: 1px solid #2a2a2a; font-size: 14px; color: #ccc; }
  .error-table tr:last-child td { border-bottom: none; }
  .error-code { font-family: monospace; font-weight: 700; color: var(--red); font-size: 15px; }
  .error-cause { color: #aaa; }

  .problems-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(260px, 1fr)); gap: 16px; margin-top: 32px; }
  .problem-card { border: 1px solid var(--border); background: #fff; padding: 20px; }
  .problem-title { font-size: 14px; font-weight: 800; text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 8px; color: var(--text); }
  .problem-cause { font-size: 13px; color: var(--muted); line-height: 1.6; margin-bottom: 10px; }
  .problem-tag { display: inline-block; font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; padding: 3px 8px; color: #fff; }
  .tag-common { background: var(--red); }
  .tag-la { background: #2a5ea5; }

  .pricing-table { width: 100%; border-collapse: collapse; margin-top: 24px; }
  .pricing-table th { background: var(--text); color: #fff; text-align: left; padding: 12px 16px; font-size: 12px; text-transform: uppercase; letter-spacing: 0.08em; }
  .pricing-table td { padding: 14px 16px; border-bottom: 1px solid var(--border); font-size: 14px; }
  .pricing-table tr:last-child td { border-bottom: none; }
  .pricing-table tr:nth-child(even) td { background: var(--gray); }
  .price-range { font-weight: 700; color: var(--red); }

  .why-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: 24px; margin-top: 32px; }
  .why-card { border-left: 3px solid var(--red); padding: 20px; background: #fff; }
  .why-icon { font-size: 24px; margin-bottom: 10px; }
  .why-title { font-size: 14px; font-weight: 800; text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 8px; }
  .why-desc { font-size: 13px; color: var(--muted); line-height: 1.6; }

  .reviews-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 20px; margin-top: 32px; }
  .review-card { background: #fff; border: 1px solid var(--border); padding: 24px; }
  .review-stars { color: var(--red); font-size: 18px; margin-bottom: 10px; }
  .review-text { font-size: 14px; line-height: 1.7; color: var(--text); margin-bottom: 14px; }
  .review-author { font-size: 12px; font-weight: 700; text-transform: uppercase; color: var(--muted); }

  .repairs-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 1px; background: var(--border); border: 1px solid var(--border); margin-top: 32px; }
  .repair-item { background: #fff; padding: 24px; }
  .repair-appliance { font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; color: var(--red); margin-bottom: 6px; }
  .repair-issue { font-size: 15px; font-weight: 800; color: var(--text); margin-bottom: 8px; }
  .repair-detail { font-size: 13px; color: var(--muted); line-height: 1.6; }
  .repair-meta { margin-top: 12px; font-size: 12px; font-weight: 600; color: #aaa; text-transform: uppercase; letter-spacing: 0.06em; }

  .faq-list { margin-top: 32px; }
  .faq-item { border-bottom: 1px solid var(--border); padding: 20px 0; }
  .faq-q { font-size: 16px; font-weight: 800; color: var(--text); margin-bottom: 10px; }
  .faq-a { font-size: 14px; line-height: 1.7; color: var(--muted); max-width: 760px; }

  .nearby-grid { display: flex; flex-wrap: wrap; gap: 8px; margin-top: 20px; }
  .nearby-chip { background: var(--gray); border: 1px solid var(--border); padding: 8px 14px; font-size: 13px; color: var(--muted); text-decoration: none; font-weight: 600; }
  .nearby-chip:hover { border-color: var(--red); color: var(--red); }

  .bottom-cta { background: var(--black); padding: 72px 24px; text-align: center; color: #fff; }
  .bottom-cta-title { font-size: clamp(28px, 4vw, 44px); font-weight: 900; text-transform: uppercase; letter-spacing: -0.01em; margin-bottom: 12px; }
  .bottom-cta-title span { color: var(--red); }
  .bottom-cta-sub { font-size: 17px; color: #888; margin-bottom: 32px; }
  .cta-phone-large { display: inline-block; font-size: clamp(28px, 4vw, 42px); font-weight: 900; color: #fff; text-decoration: none; letter-spacing: -0.01em; margin-bottom: 24px; border-bottom: 2px solid var(--red); padding-bottom: 4px; }

  @media (max-width: 768px) {
    .hero-inner { grid-template-columns: 1fr; }
    .hero-badge-grid { grid-template-columns: 1fr 1fr; }
    .features-2col { grid-template-columns: 1fr; }
    .trust-bar-inner { flex-direction: column; gap: 6px; }
  }
</style>

<!-- TOP BAR -->
<div class="top-bar">
  <span>Mon–Sat 8am–8pm · Los Angeles &amp; Southern California</span>
  <a href={`tel:${phoneRaw}`}>{phone}</a>
</div>

<!-- HERO -->
<section class="hero">
  <div class="hero-inner">
    <div>
      <div class="hero-eyebrow">Miele Appliance Repair — Los Angeles</div>
      <h1 class="hero-title">
        Miele Repair.<br/>
        <span>Built to Last.</span><br/>
        Fixed to Last.
      </h1>
      <p class="hero-sub">
        Miele builds washers, dishwashers, and ovens to run 20 years — 10,000 operating hours by their own testing standard. We repair them with genuine OEM parts and Miele diagnostic software, same day across Los Angeles. Including the coffee machines most shops won't touch.
      </p>
      <div class="hero-cta-group">
        <a href={`tel:${phoneRaw}`} class="btn-primary">Call {phone}</a>
        <a href="/book/" class="btn-secondary">Book Online</a>
      </div>
    </div>
    <div class="hero-badge-grid">
      <div class="hero-badge">
        <div class="badge-num">Same</div>
        <div class="badge-label">Day Service</div>
      </div>
      <div class="hero-badge">
        <div class="badge-num">OEM</div>
        <div class="badge-label">Miele Parts</div>
      </div>
      <div class="hero-badge">
        <div class="badge-num">90-Day</div>
        <div class="badge-label">Warranty</div>
      </div>
      <div class="hero-badge">
        <div class="badge-num">$89</div>
        <div class="badge-label">Diagnostic Fee</div>
      </div>
    </div>
  </div>
</section>

<!-- TRUST BAR -->
<div class="trust-bar">
  <div class="trust-bar-inner">
    <span class="trust-item">Licensed &amp; Insured · CSLB #1138898</span>
    <span class="trust-item">Miele Diagnostic Software</span>
    <span class="trust-item">Genuine Miele OEM Parts</span>
    <span class="trust-item">Coffee Machine Specialists</span>
    <span class="trust-item">Flat-Rate Written Estimate</span>
  </div>
</div>

<!-- 01 — ABOUT MIELE -->
<section class="section">
  <div class="section-inner">
    <div class="section-num">01 — About Miele</div>
    <h2 class="section-title">125 Years of German Engineering — and Why It Matters for Repair</h2>
    <p class="section-lead">
      Miele has been making appliances since 1899 — still family owned, still headquartered in Gütersloh, Germany. Their engineering standard is unusual in the appliance world: every washer and dishwasher is tested to 10,000 operating cycles, which translates to roughly 20 years of normal use. That's not a marketing claim — it's a design requirement that drives every component choice they make, from drum bearing tolerances to the grade of stainless steel in the wash chamber.
    </p>
    <p class="section-lead">
      What that means for repair: Miele appliances are worth fixing. A Miele W1 washing machine that's 8 years old likely has 12 more years of life left. A control board replacement or drum bearing job on a machine that cost $2,500 and has a decade of useful life remaining is almost always the right call. We see this calculation on every service call — and we're honest about it when it doesn't work out that way.
    </p>

    <div class="tip-block tip-water">
      <div class="tip-label">💧 Los Angeles Hard Water — The #1 Miele Problem We See</div>
      <div class="tip-text">LA water hardness runs 250–400 ppm depending on your district — far above Miele's 7 gpg recommended threshold. This accelerates limescale buildup in Miele dishwashers, washing machines, steam ovens, and coffee machines. It's the root cause behind most F53 intake/drain errors, premature heating element failure, and coffee machine scaling faults. We account for water hardness on every diagnosis — it changes the repair and the maintenance recommendation.</div>
    </div>
  </div>
</section>

<!-- 02 — SERVICES -->
<section class="section section-gray">
  <div class="section-inner">
    <div class="section-num">02 — Services</div>
    <h2 class="section-title">Every Miele Appliance We Service</h2>
    <p class="section-lead">Same-day availability across Los Angeles County. We stock the most commonly needed Miele parts on every truck.</p>

    <div class="services-grid">
      <div class="service-card">
        <div class="service-icon">🌀</div>
        <div class="service-name">Washing Machine Repair</div>
        <div class="service-desc">All W1, WCI, and WDB series. Front-loaders, compact 24" models, and washer-dryer combos. The Miele W1 is one of the most repairable washers ever made — most failures are mechanical, not electronic, and most parts are available same-day.</div>
        <div class="service-issues">Common: drum bearing failure · carbon brush wear · door seal leak · drain pump blocked · F53 error · not spinning · water not draining</div>
      </div>

      <div class="service-card">
        <div class="service-icon">🍽️</div>
        <div class="service-name">Dishwasher Repair</div>
        <div class="service-desc">All G series including G 7000, G 5000, and older G-series models. Miele dishwashers run exceptionally long but LA hard water creates predictable failure patterns — F53 drain errors and heating element scale buildup are the ones we see most.</div>
        <div class="service-issues">Common: F53 intake/drain error · not draining · not cleaning · water inlet fault · door seal degraded · circulation pump · control board</div>
      </div>

      <div class="service-card">
        <div class="service-icon">☕</div>
        <div class="service-name">Coffee Machine Repair</div>
        <div class="service-desc">Miele CM and CVA series built-in coffee systems — these are specialty repairs that most general appliance companies decline. We service the brew unit, milk system (CoolConnect, AutoSteam), grinder, and descaling system. In LA, hard water scaling is the primary failure mode.</div>
        <div class="service-issues">Common: descaling fault · brew unit clogged · milk system not frothing · grinder failure · error codes · no coffee output · leaking internally</div>
      </div>

      <div class="service-card">
        <div class="service-icon">🌡️</div>
        <div class="service-name">Oven &amp; Steam Oven Repair</div>
        <div class="service-desc">Miele H series wall ovens, steam combination ovens (DG/DGC series), and speed ovens. Steam ovens in LA need annual descaling — the water quality here means the steam generator scales faster than in other markets.</div>
        <div class="service-issues">Common: oven not heating · steam not generating · descaling error · door seal worn · convection fan · temperature sensor · control board fault</div>
      </div>

      <div class="service-card">
        <div class="service-icon">🧺</div>
        <div class="service-name">Dryer Repair</div>
        <div class="service-desc">All T1 heat-pump dryers and vented T series. Miele heat-pump dryers are highly efficient but require specific knowledge to service — the refrigerant circuit and condenser system are different from standard dryer repairs.</div>
        <div class="service-issues">Common: not heating · condenser blocked · drum not turning · door switch failure · heat pump circuit · control board · takes too long to dry</div>
      </div>

      <div class="service-card">
        <div class="service-icon">❄️</div>
        <div class="service-name">Refrigerator &amp; Freezer Repair</div>
        <div class="service-desc">Miele MasterCool, PerfectCool, and integrated refrigeration columns. Built-in Miele refrigeration is designed to integrate with custom cabinetry — service requires care to avoid damaging panel alignment and hinge systems.</div>
        <div class="service-issues">Common: not cooling · temperature fluctuation · ice maker failure · door gasket worn · compressor noise · thermistor failure · condenser coil service</div>
      </div>
    </div>

    <div class="tip-block" style="margin-top:32px">
      <div class="tip-label">☕ Coffee Machine Repair — Why We Specialize</div>
      <div class="tip-text">Miele CM and CVA built-in coffee systems cost $2,500–$5,000. Most general appliance companies won't touch them — the brew unit, milk system, and grinder require Miele-specific knowledge and parts. We've serviced hundreds of these machines across LA. The most common issue in our market: LA hard water scaling the steam circuit and brew unit faster than the machine's auto-descaling program can keep up with. We descale, clean, and recalibrate the full system.</div>
    </div>
  </div>
</section>

<!-- 03 — MIELE TECHNOLOGY & ERROR CODES -->
<section class="section section-black">
  <div class="section-inner">
    <div class="section-num">03 — Diagnostics</div>
    <h2 class="section-title">Miele Fault Codes — What They Actually Mean</h2>
    <p class="section-lead">We read Miele fault history using Miele's diagnostic software, not just the current displayed error. A fault code on screen is often the result — the root cause is usually in the history log. Here are the codes we see most often in LA.</p>

    <table class="error-table">
      <thead>
        <tr>
          <th>Code</th>
          <th>Displayed As</th>
          <th>Most Common LA Root Cause</th>
          <th>What We Do</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td><span class="error-code">F53</span></td>
          <td>Intake/Drain Fault</td>
          <td class="error-cause">Drain pump blocked by limescale or debris; water inlet valve clogged. Hard water accelerates both.</td>
          <td>Drain pump inspection + descale, inlet valve test, pump replacement if needed</td>
        </tr>
        <tr>
          <td><span class="error-code">F24</span></td>
          <td>Heating Fault</td>
          <td class="error-cause">Heating element coated in limescale — common in dishwashers and washing machines in hard-water areas including most of LA.</td>
          <td>Element descale treatment; replacement if element has failed due to scale damage</td>
        </tr>
        <tr>
          <td><span class="error-code">F11</span></td>
          <td>Pump Fault (Washer)</td>
          <td class="error-cause">Drain pump impeller blocked — usually by a forgotten coin, wire, or debris in the pump filter that was never cleared.</td>
          <td>Pump filter cleaning, impeller inspection, pump replacement if seized</td>
        </tr>
        <tr>
          <td><span class="error-code">F138</span></td>
          <td>Motor Fault</td>
          <td class="error-cause">Carbon brush wear on brushed motor models. Miele W1 series uses brushless motors (no brushes), but older T7/W2 series used brushed motors.</td>
          <td>Carbon brush replacement (older models) or motor control board diagnosis (W1)</td>
        </tr>
        <tr>
          <td><span class="error-code">Descale ⚠</span></td>
          <td>Descaling Required (Coffee/Steam)</td>
          <td class="error-cause">Scale buildup in steam circuit or brew unit from hard water. In LA, this triggers 30–50% earlier than Miele's programmed cycle assumes.</td>
          <td>Full descale process, milk system flush, brew unit clean, recalibration</td>
        </tr>
        <tr>
          <td><span class="error-code">F63</span></td>
          <td>Heating Fault (Oven)</td>
          <td class="error-cause">Bake element failure or temperature sensor out of calibration. Combination oven F63 may involve the steam generator circuit.</td>
          <td>Element test and replacement, sensor calibration, steam generator inspection</td>
        </tr>
      </tbody>
    </table>

    <div style="margin-top:32px">
      <div class="features-2col">
