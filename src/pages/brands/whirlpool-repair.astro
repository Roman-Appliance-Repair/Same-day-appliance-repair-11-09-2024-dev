const errorCodes = [
  { code: "F01", appliance: "Washer", meaning: "Main control board failure. Before replacing the board: check the wiring harness connections at the board. Loose connector = F01 that resolves with reseating. If connections are solid, board needs replacement." },
  { code: "F02", appliance: "Washer", meaning: "Drain takes too long — drain pump or filter. Clean the coin trap filter first (behind lower front panel on front-loaders). If filter is clear and OE persists, drain pump impeller is seized or failed." },
  { code: "F05 / F06", appliance: "Washer", meaning: "Door lock error. The lock mechanism isn't registering closed. Usually the door latch assembly has worn. On front-loaders, check door seal bulge blocking the latch first." },
  { code: "F21", appliance: "Washer", meaning: "Long drain — pump or filter. Same diagnosis path as F02. Very common call on Whirlpool front-loaders, almost always the coin trap filter." },
  { code: "Sensing (stuck)", appliance: "Washer (top-load)", meaning: "Washer stuck on sensing cycle and won't start. Most common cause: shift actuator failure (moves tub from agitate to spin). Also possible: lid lock failure. Actuator replacement is the typical fix." },
  { code: "F22", appliance: "Dryer", meaning: "Thermistor (temperature sensor) fault. The sensor monitors drum temperature. Replacement required. Cheap part — usually $20-40 OEM." },
  { code: "d80 / d90 / d95", appliance: "Dryer", meaning: "Vent blockage 80/90/95%. Not a part failure — vent needs cleaning. We check this before replacing any thermal fuse. A new fuse in a restricted vent will blow again." },
