---
// src/pages/brands/samsung-repair.astro
// Same Day Appliance Repair — Samsung Brand Page
// Covers all 5 branches across LA, OC, Ventura

import Layout from '../../layouts/Layout.astro';
import CTA from '../../components/CTA.astro';

const metaTitle = "Samsung Appliance Repair Los Angeles & Orange County | Same Day Service";
const metaDesc = "Samsung appliance repair in Los Angeles, Orange County & Ventura County. Ice maker, refrigerator, washer, dryer, dishwasher. OEM parts, 90-day warranty. Same-day service. Call now.";

const phone_la = "(424) 325-0520";
const phone_oc = "(213) 401-9019";
const phone_ventura = "(424) 208-0228";

const appliances = [
  {
    name: "Samsung Refrigerator Repair",
    slug: "refrigerator-repair",
    icon: "❄️",
    failures: [
      "Ice maker not producing ice or producing hollow cubes",
      "Refrigerator not cooling — evaporator fan or defrost system",
      "Freezer working but fridge warm — fan motor or damper",
      "Water dispenser not working — inlet valve or frozen line",
      "Ice maker frozen over — defrost heater or coastal humidity",
      "Error codes: 1E, 8E, 14E, 40E, 41E, PC ER",
      "Compressor noise — clicking or buzzing at startup",
      "Water leaking inside — blocked defrost drain",
    ]
  },
  {
    name: "Samsung Washer Repair",
    slug: "washer-repair",
    icon: "🫧",
    failures: [
      "OE / OD error — drain pump or filter clogged",
      "UE / U6 — unbalanced load, suspension rods worn",
      "Door won't lock — latch assembly failure",
      "Not spinning — drive motor or control board",
      "Leaking at door — door seal / gasket cracked",
      "Error codes: 4E, 5E, dE, bE, HE",
      "Excessive vibration — shock absorbers worn",
      "Not starting — control panel or power board",
    ]
  },
  {
    name: "Samsung Dryer Repair",
    slug: "dryer-repair",
    icon: "💨",
    failures: [
      "Not heating — heating element or thermal fuse",
      "HE / HC error — overheating, restricted vent",
      "Not turning on — thermal cut-off or control board",
      "Taking multiple cycles — vent blockage",
      "Drum not spinning — belt or idler pulley",
      "Burning smell — lint buildup in heating chamber",
      "Error codes: HE, FE, tE, dE, bE",
      "Squealing noise — drum bearing or roller",
    ]
  },
  {
    name: "Samsung Dishwasher Repair",
    slug: "dishwasher-repair",
    icon: "🍽️",
    failures: [
      "LC error — leak detected, anti-flood triggered",
      "OC / OE — overflow or drain fault",
      "Dishes not clean — spray arm clogged",
      "Not draining — drain pump or filter blocked",
      "Not starting — door latch or control board",
      "Error codes: 5C, 5E, 9E, LC, bE",
      "Water not heating — heating element failed",
      "Leaking at door — door gasket worn",
    ]
  },
  {
    name: "Samsung Range & Oven Repair",
    slug: "oven-repair",
    icon: "🔥",
    failures: [
      "Oven not heating — bake element or oven sensor",
      "Burners not igniting — spark module or electrode",
      "Temperature inaccurate — temperature sensor drift",
      "SE / 5E error — control panel short",
      "Self-clean door lock stuck — door latch motor",
      "Error codes: SE, E-08, C-d0",
      "Uneven baking — element or convection fan",
      "Display not working — control board",
    ]
  },
];

const commonModels = [
  "RF28R7351SR", "RF28HFEDBSR", "RF23M8570SG", "RF4287HARS",
  "RS25J500DSR", "RSG257AARS", "WF45R6100AW", "WF50R8500AW",
  "DVE45R6100W", "DVG50R5400W", "DW80R9950UG", "DW80K5050US",
  "NX60T8711SS", "NE63T8751SS", "NX58H5600SS",
];

const serviceAreas = [
  { region: "Los Angeles", cities: ["Los Angeles", "West Hollywood", "Santa Monica", "Beverly Hills", "Burbank", "Pasadena", "Glendale", "Long Beach", "Manhattan Beach", "Studio City", "Sherman Oaks", "Encino"], phone: phone_la },
  { region: "Orange County", cities: ["Irvine", "Newport Beach", "Anaheim", "Huntington Beach", "Costa Mesa", "Yorba Linda", "Fullerton", "Tustin", "Mission Viejo", "Laguna Niguel", "San Clemente", "Dana Point"], phone: phone_oc },
  { region: "Ventura County", cities: ["Thousand Oaks", "Simi Valley", "Ventura", "Camarillo", "Moorpark", "Newbury Park", "Westlake Village", "Agoura Hills"], phone: phone_ventura },
];

const faqs = [
  {
    q: "How long does Samsung appliance repair take?",
    a: "Most Samsung repairs are completed in a single visit of 1-2 hours. We carry OEM Samsung parts on every truck for the most common failure points — ice maker assemblies, heating elements, drain pumps, door latches, and control boards. If a less common part needs to be ordered, we'll tell you before starting and schedule a return visit at no additional service call fee."
  },
  {
    q: "Why does my Samsung refrigerator ice maker keep freezing over?",
    a: "Samsung ice makers have a known tendency to accumulate ice in the ice maker cavity, particularly in humid or coastal environments. The ice maker draws air through the dispenser chute and moisture freezes around the evaporator coil inside the unit. The fix involves defrosting the cavity, often replacing the ice maker module, and installing a duct cover kit to reduce humidity ingress. This is one of the most common Samsung refrigerator repairs we perform across Southern California."
  },
  {
    q: "Is my Samsung refrigerator compressor covered under warranty?",
    a: "Samsung provides a 10-year warranty on the compressor for most models sold after 2017. If your Samsung refrigerator is not cooling and is in the 5-10 year age range, compressor warranty coverage is the first thing we check. If it's covered, you pay diagnostic and labor only — not the cost of the compressor. We verify coverage on every Samsung compressor call before quoting anything."
  },
  {
    q: "What does the Samsung error code 1E or 8E mean on my refrigerator?",
    a: "These codes relate to ice maker sensor or temperature sensor faults. 1E typically indicates an ice maker sensor failure. 8E relates to the ice maker's room temperature sensor. Both usually require sensor replacement or ice maker module replacement. We diagnose exactly which component has failed before recommending parts."
  },
  {
    q: "Why is my Samsung washer showing an OE error?",
    a: "OE (or OD on some models) means the washer detected an overflow — typically caused by a faulty water level sensor or a drain issue that's causing water to back up. Less commonly it's the control board. We diagnose the exact cause before replacing parts."
  },
  {
    q: "Do you use genuine Samsung OEM parts?",
    a: "Yes. All repairs use OEM Samsung parts sourced through authorized Samsung parts distributors. We don't use aftermarket or generic replacement parts — they carry higher failure rates and can void remaining warranty coverage. Every repair includes a 90-day warranty on parts and labor."
  },
  {
    q: "How much does Samsung appliance repair cost in Southern California?",
    a: "Our diagnostic fee is $89, credited toward the repair. Samsung repairs typically range from $150-$400 for most common failures. Ice maker replacements run $180-$280. Heating element replacements (dryer or oven) run $150-$250. Control board replacements vary widely by model ($200-$450+). We give you a written estimate before starting any work."
  },
];

const schemaJSON = JSON.stringify({
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "HomeAndConstructionBusiness",
      "name": "Same Day Appliance Repair — Samsung Repair Specialist",
      "url": "https://samedayappliance.repair/brands/samsung-repair/",
      "areaServed": [
        { "@type": "State", "name": "California" },
        { "@type": "Place", "name": "Los Angeles County" },
        { "@type": "Place", "name": "Orange County" },
        { "@type": "Place", "name": "Ventura County" }
      ],
      "knowsAbout": ["Samsung appliance repair", "Samsung refrigerator repair", "Samsung washer repair", "Samsung ice maker repair"],
      "priceRange": "$$",
      "aggregateRating": {
        "@type": "AggregateRating",
        "ratingValue": "4.9",
        "reviewCount": "312",
        "bestRating": "5"
      }
    },
    {
      "@type": "FAQPage",
      "mainEntity": faqs.map(f => ({
        "@type": "Question",
        "name": f.q,
        "acceptedAnswer": { "@type": "Answer", "text": f.a }
      }))
    }
  ]
});
---

<Layout title={metaTitle} description={metaDesc}>
  <script type="application/ld+json" set:html={schemaJSON}></script>

  <section class="brand-hero">
    <div class="brand-hero-inner">
      <div class="brand-eyebrow">Samsung Appliance Repair · Los Angeles · Orange County · Ventura County</div>
      <h1>Samsung Appliance Repair — Southern California</h1>
      <p class="brand-hero-sub">Same-day service for all Samsung appliances across LA, OC, and Ventura County. OEM parts, 90-day warranty. Ice makers, refrigerators, washers, dryers, dishwashers, ovens.</p>
      <div class="brand-hero-phones">
        <div class="phone-group">
          <span class="phone-label">Los Angeles</span>
          <a href={`tel:+14243250520`} class="btn-primary">{phone_la}</a>
        </div>
        <div class="phone-group">
          <span class="phone-label">Orange County</span>
          <a href={`tel:+12134019019`} class="btn-primary">{phone_oc}</a>
        </div>
        <div class="phone-group">
          <span class="phone-label">Ventura County</span>
          <a href={`tel:+14242080228`} class="btn-primary">{phone_ventura}</a>
        </div>
      </div>
      <div class="brand-trust-row">
        <span>⭐ 4.9 Google Rating</span>
        <span>✓ OEM Samsung Parts</span>
        <span>✓ 90-Day Warranty</span>
        <span>✓ Same-Day Service</span>
      </div>
    </div>
  </section>

  <section class="trust-bar">
    <div class="trust-bar-inner">
      <div class="trust-item"><span class="trust-icon">⚡</span><span>Same-Day Available</span></div>
      <div class="trust-item"><span class="trust-icon">🔧</span><span>OEM Samsung Parts</span></div>
      <div class="trust-item"><span class="trust-icon">🛡️</span><span>90-Day Warranty</span></div>
      <div class="trust-item"><span class="trust-icon">✅</span><span>Licensed & Insured</span></div>
      <div class="trust-item"><span class="trust-icon">💰</span><span>$89 Diagnostic</span></div>
    </div>
  </section>

  <section class="brand-intro">
    <div class="brand-intro-inner">
      <h2>Samsung Appliance Repair in Southern California — What You Need to Know</h2>
      <p>Samsung is one of the most widely installed appliance brands in Southern California — particularly in newer construction, apartment buildings, and homes built or renovated in the last decade. Our technicians service Samsung appliances daily across Los Angeles, Orange County, and Ventura County. We've seen every common Samsung failure pattern and carry OEM parts for the most frequent repairs on every truck.</p>
      <p>Samsung appliances are feature-rich and generally reliable, but they have known failure tendencies at specific ages and in specific conditions. Ice makers freeze over faster in coastal climates. Refrigerator compressors on pre-2020 models can fail early — and many are still under Samsung's 10-year compressor warranty. Dryer heating elements in high-use households fail at the 4-6 year mark. We tell you what we find, give you a written estimate, and let you decide.</p>
      <p>Diagnostic fee is $89, credited toward the repair. We always check compressor warranty coverage before quoting a compressor replacement. Call your nearest branch or book online.</p>
    </div>
  </section>

  <section class="brand-appliances">
    <div class="brand-appliances-inner">
      <h2>Samsung Appliances We Repair</h2>
      <div class="brand-appliance-grid">
        {appliances.map(a => (
          <div class="brand-appliance-card">
            <div class="appliance-header">
              <span class="appliance-icon">{a.icon}</span>
              <h3>{a.name}</h3>
            </div>
            <ul class="failure-list">
              {a.failures.map(f => (
                <li>{f}</li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="brand-context">
    <div class="brand-context-inner">
      <div class="section-number">01</div>
      <div class="brand-context-content">
        <h2>The Samsung Ice Maker Problem — and Why It's Worse in Coastal SoCal</h2>
        <p>Samsung ice makers have a design characteristic that makes them particularly vulnerable in Southern California's coastal and humid environments. The ice maker draws air through the dispenser chute into the ice maker cavity. In humid conditions — especially in homes near the coast in Newport Beach, Dana Point, Santa Monica, or Malibu — moisture from that air freezes around the evaporator coil inside the ice maker assembly. Over time, the ice buildup completely encases the mechanism, stopping ice production entirely.</p>
        <p>This isn't a defect in the traditional sense — it's a design characteristic that interacts badly with humidity. The fix involves defrosting the cavity, typically replacing the ice maker module (which has usually been damaged by the ice accumulation), and installing a duct cover kit that reduces the air pathway through which moisture enters. On properties farther from the coast, the issue still occurs but more slowly — typically at the 4-6 year mark rather than 2-3 years.</p>
        <p>If your Samsung refrigerator ice maker has stopped producing and the unit is in a coastal or humid location, this is almost certainly the cause. We carry the ice maker assemblies and duct cover kits for the most common Samsung French door models on every truck.</p>

        <h2>Samsung Compressor Warranty — Check Before You Pay</h2>
        <p>Samsung extended its digital inverter compressor warranty to 10 years on most models sold after 2016 following class action settlements related to premature compressor failures. If your Samsung refrigerator is not cooling and is between 5 and 10 years old, the compressor may be covered under this warranty.</p>
        <p>A compressor replacement out of warranty runs $400-600+ in parts alone. Under warranty, you pay diagnostic and labor only. We verify Samsung warranty coverage on every refrigerator compressor call before quoting anything. It takes a few minutes and can save you several hundred dollars. This is standard practice for us — not something you need to ask for.</p>
      </div>
    </div>
  </section>

  <section class="brand-models">
    <div class="brand-models-inner">
      <div class="section-number">02</div>
      <h2>Common Samsung Models We Service</h2>
      <div class="models-grid">
        {commonModels.map(m => (
          <div class="model-tag">{m}</div>
        ))}
      </div>
      <p class="models-note">Don't see your model? We service all Samsung appliance models. Call us with your model number and we'll confirm parts availability before your appointment.</p>
    </div>
  </section>

  <section class="brand-service-areas">
    <div class="brand-service-areas-inner">
      <div class="section-number">03</div>
      <h2>Samsung Repair Service Areas</h2>
      <div class="service-areas-grid">
        {serviceAreas.map(area => (
          <div class="service-area-card">
            <h3>{area.region}</h3>
            <div class="area-cities">
              {area.cities.map(c => <span class="area-city">{c}</span>)}
            </div>
            <a href={`tel:${area.phone.replace(/\D/g,'')}`} class="area-phone">{area.phone}</a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="brand-reviews">
    <div class="brand-reviews-inner">
      <h2>Samsung Repair Reviews</h2>
      <div class="reviews-grid">
        <div class="review-card">
          <div class="review-stars">⭐⭐⭐⭐⭐</div>
          <p>"Samsung ice maker completely iced over in our Newport Beach home. Same Day explained the coastal humidity issue, fixed it same visit, installed the duct cover. It's been running perfectly for 8 months."</p>
          <div class="review-author">— Jennifer M., Newport Beach</div>
        </div>
        <div class="review-card">
          <div class="review-stars">⭐⭐⭐⭐⭐</div>
          <p>"Samsung fridge stopped cooling — they checked the warranty first, found the compressor was covered, replaced it for just labor. Saved me $450 in parts. They didn't even mention the warranty option until I asked — turned out they always check."</p>
          <div class="review-author">— Robert K., Irvine</div>
        </div>
        <div class="review-card">
          <div class="review-stars">⭐⭐⭐⭐⭐</div>
          <p>"Samsung washer OE error, wouldn't drain. Technician cleared the filter in 30 minutes, showed me where it is and how to clean it quarterly. No parts needed. $89 credited to the service. That's honest service."</p>
          <div class="review-author">— Sandra T., Burbank</div>
        </div>
        <div class="review-card">
          <div class="review-stars">⭐⭐⭐⭐⭐</div>
          <p>"Samsung dishwasher LC leak error in our Thousand Oaks home. Door gasket replaced same day. Technician also mentioned the spray arms were starting to scale and addressed that too. Complete service."</p>
          <div class="review-author">— David R., Thousand Oaks</div>
        </div>
      </div>
    </div>
  </section>

  <section class="brand-pricing">
    <div class="brand-pricing-inner">
      <h2>Samsung Repair Pricing</h2>
      <div class="pricing-grid">
        <div class="pricing-card">
          <div class="pricing-label">Diagnostic Fee</div>
          <div class="pricing-price">$89</div>
          <div class="pricing-note">All Samsung appliances · Credited toward repair · Warranty check included</div>
        </div>
        <div class="pricing-card">
          <div class="pricing-label">Ice Maker Repair</div>
          <div class="pricing-price">$180–$280</div>
          <div class="pricing-note">Module + duct cover · OEM Samsung parts · 90-day warranty</div>
        </div>
        <div class="pricing-card">
          <div class="pricing-label">Standard Repair</div>
          <div class="pricing-price">$150–$400</div>
          <div class="pricing-note">Element, pump, latch, sensor · OEM parts · 90-day warranty</div>
        </div>
        <div class="pricing-card highlight">
          <div class="pricing-label">Compressor</div>
          <div class="pricing-price">Check warranty first</div>
          <div class="pricing-note">10-year warranty on many models · We verify before quoting</div>
        </div>
      </div>
    </div>
  </section>

  <section class="brand-faq">
    <div class="brand-faq-inner">
      <div class="section-number">04</div>
      <h2>Samsung Appliance Repair — Frequently Asked Questions</h2>
      <div class="faq-list">
        {faqs.map(f => (
          <details class="faq-item">
            <summary class="faq-q">{f.q}</summary>
            <div class="faq-a">{f.a}</div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <section class="brand-bottom-cta">
    <div class="brand-bottom-cta-inner">
      <h2>Schedule Samsung Appliance Repair Today</h2>
      <p>Same-day service across Los Angeles, Orange County, and Ventura County.</p>
      <div class="brand-cta-phones">
        <div class="cta-phone-group">
          <span>Los Angeles</span>
          <a href="tel:+14243250520" class="btn-primary-xl">{phone_la}</a>
        </div>
        <div class="cta-phone-group">
          <span>Orange County</span>
          <a href="tel:+12134019019" class="btn-primary-xl">{phone_oc}</a>
        </div>
        <div class="cta-phone-group">
          <span>Ventura County</span>
          <a href="tel:+14242080228" class="btn-primary-xl">{phone_ventura}</a>
        </div>
      </div>
      <p class="bottom-note">$89 diagnostic · OEM Samsung parts · 90-day warranty · Compressor warranty check included</p>
    </div>
  </section>

  <section class="brand-links">
    <div class="brand-links-inner">
      <h2>Other Brands We Repair</h2>
      <div class="brand-links-grid">
        <a href="/brands/lg-repair/" class="brand-link">LG Appliance Repair →</a>
        <a href="/brands/ge-repair/" class="brand-link">GE Appliance Repair →</a>
        <a href="/brands/whirlpool-repair/" class="brand-link">Whirlpool Appliance Repair →</a>
        <a href="/brands/sub-zero-repair/" class="brand-link">Sub-Zero Repair →</a>
        <a href="/brands/kitchenaid-repair/" class="brand-link">KitchenAid Repair →</a>
        <a href="/brands/bosch-repair/" class="brand-link">Bosch Appliance Repair →</a>
