---
import Layout from '../layouts/Layout.astro';

const title = "AGA Range Cooker Repair Los Angeles | Classic, Mercury & Total Control Specialists";
const description = "Expert AGA range cooker repair in Los Angeles. Classic 2/3/4-oven, AGA Total Control, Mercury, Elise — heat storage service, cast iron doors, enamel care. Coalbrookdale since 1922. Same-day service. Call (626) 376-4458.";
const phone = "(626) 376-4458";
const phoneRaw = "6263764458";
---

<Layout title={title} description={description}>

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "HomeAndConstructionBusiness",
  "name": "Same Day Appliance Repair — AGA Specialist",
  "url": "https://samedayappliance.repair/brand-aga-appliance-repair/",
  "telephone": "+16263764458",
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Los Angeles",
    "addressRegion": "CA",
    "postalCode": "90001",
    "addressCountry": "US"
  },
  "areaServed": ["Los Angeles County", "Orange County", "Ventura County"],
  "priceRange": "$$$",
  "openingHours": "Mo-Sa 08:00-20:00",
  "hasOfferCatalog": {
    "@type": "OfferCatalog",
    "name": "AGA Repair Services",
    "itemListElement": [
      {"@type":"Offer","itemOffered":{"@type":"Service","name":"AGA Classic Range Cooker Repair"}},
      {"@type":"Offer","itemOffered":{"@type":"Service","name":"AGA Total Control Repair"}},
      {"@type":"Offer","itemOffered":{"@type":"Service","name":"AGA Mercury Range Repair"}},
      {"@type":"Offer","itemOffered":{"@type":"Service","name":"AGA Heat Storage Service"}},
      {"@type":"Offer","itemOffered":{"@type":"Service","name":"AGA Cast Iron Door Service"}},
      {"@type":"Offer","itemOffered":{"@type":"Service","name":"AGA Enamel Repair Assessment"}}
    ]
  }
}
</script>

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "How much does AGA range cooker repair cost in Los Angeles?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Most AGA repairs run $225–$720. Gas valve, thermostat, or burner service on Classic models is on the lower end. Cast iron door hinge replacement, control board on Total Control models, or enamel assessment runs higher. Diagnostic fee is $89, waived when you proceed. Written flat-rate estimate before work begins."
      }
    },
    {
      "@type": "Question",
      "name": "What is AGA's heat storage system and how does it affect service?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Classic AGA ranges are heat storage appliances — not conventional ovens you heat before cooking. A continuous low-output gas or electric heat source warms massive cast iron ovens to fixed temperatures, which the iron retains and radiates. The roasting oven stays at approximately 400-450°F, the simmering oven at 250-300°F. This system requires specific diagnostic approach: temperature complaints on a Classic AGA almost always trace to the heat source (gas valve, burner, thermostat) rather than any oven-side component, because the ovens themselves are passive cast iron. AGA Total Control and Mercury models work differently — they can be turned on and off, and have conventional heating elements."
      }
    },
    {
      "@type": "Question",
      "name": "What is the difference between AGA Classic, Total Control, and Mercury?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Classic AGA: always-on heat storage using gas or oil. The cast iron ovens are permanently heated to their fixed temperatures. No programmable on/off. AGA Total Control: electric version that can be turned on and off — each oven has individual heating elements controlled independently. The AGA aesthetic with modern convenience. Mercury series: AGA's modern range cooker line using conventional cooking technology in AGA-inspired design — not heat storage. Each requires completely different service approaches."
      }
    },
    {
      "@type": "Question",
      "name": "Why is my Classic AGA not holding temperature?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "For gas Classic AGA: almost always the gas thermostat, gas valve, or burner assembly — the component that controls the continuous low-output flame. The cast iron ovens themselves don't fail; they're passive heat storage. For electric Classic AGA: the heating element or temperature controller. We test the heat source components specifically, not the ovens, on every Classic AGA temperature complaint."
      }
    },
    {
      "@type": "Question",
      "name": "Where is AGA made?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "AGA Classic cast iron range cookers are manufactured in Coalbrookdale, Shropshire, England — the same Shropshire ironworking region that was central to the Industrial Revolution. The AGA was invented in 1922 by Dr. Gustaf Dalén, a Swedish Nobel Prize winner, in Coalbrookdale. Classic AGA manufacturing remains in Shropshire to this day."
      }
    },
    {
      "@type": "Question",
      "name": "Can you service AGA's cast iron oven doors?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes. AGA Classic oven doors are solid cast iron — each weighing 25-35 lbs. The door hinge and latch system must support this weight across thousands of open-close cycles. Door hinge wear creates doors that don't seal flush, affecting temperature retention in the oven. We service AGA door hinges, latches, and door seals as standard components on Classic AGA service calls."
      }
    }
  ]
}
</script>

<style>
  :root {
    --red: #C8102E;
    --black: #0a0a0a;
    --gray: #f5f5f5;
    --border: #e2e2e2;
    --text: #1a1a1a;
    --muted: #6b6b6b;
  }
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body { font-family: 'Barlow', 'Inter', system-ui, sans-serif; color: var(--text); }

  .top-bar { background: var(--red); padding: 8px 24px; display: flex; justify-content: space-between; align-items: center; font-size: 13px; color: #fff; }
  .top-bar a { color: #fff; text-decoration: none; font-weight: 700; }

  .hero { background: var(--black); padding: 72px 24px 64px; color: #fff; }
  .hero-inner { max-width: 1100px; margin: 0 auto; display: grid; grid-template-columns: 1fr 420px; gap: 48px; align-items: center; }
  .hero-eyebrow { font-size: 11px; font-weight: 700; letter-spacing: 0.15em; text-transform: uppercase; color: var(--red); margin-bottom: 16px; }
  .hero-title { font-size: clamp(32px, 5vw, 52px); font-weight: 900; line-height: 1.05; text-transform: uppercase; letter-spacing: -0.02em; margin-bottom: 20px; }
  .hero-title span { color: var(--red); }
  .hero-sub { font-size: 17px; line-height: 1.6; color: #aaa; margin-bottom: 32px; max-width: 540px; }
  .hero-cta-group { display: flex; gap: 16px; flex-wrap: wrap; }
  .btn-primary { display: inline-block; background: var(--red); color: #fff; padding: 14px 28px; font-size: 15px; font-weight: 700; text-decoration: none; letter-spacing: 0.04em; text-transform: uppercase; }
  .btn-secondary { display: inline-block; border: 1px solid #555; color: #ccc; padding: 14px 28px; font-size: 15px; font-weight: 600; text-decoration: none; letter-spacing: 0.04em; text-transform: uppercase; }
  .hero-badge-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
  .hero-badge { background: #161616; border: 1px solid #2a2a2a; padding: 16px 18px; }
  .badge-num { font-size: 22px; font-weight: 900; color: var(--red); line-height: 1; margin-bottom: 4px; }
  .badge-label { font-size: 12px; color: #888; text-transform: uppercase; letter-spacing: 0.08em; }

  .trust-bar { background: var(--red); padding: 14px 24px; }
  .trust-bar-inner { max-width: 1100px; margin: 0 auto; display: flex; justify-content: space-between; flex-wrap: wrap; gap: 8px; }
  .trust-item { color: #fff; font-size: 13px; font-weight: 600; letter-spacing: 0.04em; text-transform: uppercase; }
  .trust-item::before { content: "✓ "; }

  .section { padding: 64px 24px; }
  .section-gray { background: var(--gray); }
  .section-black { background: var(--black); color: #fff; }
  .section-inner { max-width: 1100px; margin: 0 auto; }
  .section-num { font-size: 11px; font-weight: 700; letter-spacing: 0.15em; text-transform: uppercase; color: var(--red); margin-bottom: 8px; }
  .section-title { font-size: clamp(24px, 3.5vw, 36px); font-weight: 900; text-transform: uppercase; letter-spacing: -0.01em; margin-bottom: 20px; }
  .section-black .section-title { color: #fff; }
  .section-lead { font-size: 17px; line-height: 1.7; color: var(--muted); max-width: 760px; margin-bottom: 40px; }
  .section-black .section-lead { color: #999; }

  /* Models comparison */
  .models-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1px; background: #2a2a2a; border: 1px solid #2a2a2a; margin-top: 28px; }
  .model-card { background: #161616; padding: 22px 18px; }
  .model-card.featured { border-top: 2px solid var(--red); }
  .model-badge { font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; color: var(--red); margin-bottom: 8px; }
  .model-name { font-size: 15px; font-weight: 900; text-transform: uppercase; color: #fff; margin-bottom: 8px; }
  .model-desc { font-size: 12px; color: #666; line-height: 1.6; }

  .tip-block { border-left: 3px solid var(--red); background: #fff8f8; padding: 18px 20px; margin: 32px 0; max-width: 760px; }
  .tip-label { font-size: 10px; font-weight: 800; text-transform: uppercase; letter-spacing: 0.15em; color: var(--red); margin-bottom: 6px; }
  .tip-text { font-size: 14px; line-height: 1.65; color: var(--text); }
  .tip-heat { border-color: #c8820a; background: #fff8f0; }
  .tip-heat .tip-label { color: #c8820a; }
  .tip-england { border-color: #2a5ea5; background: #f0f7ff; }
  .tip-england .tip-label { color: #2a5ea5; }

  .services-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 1px; background: var(--border); border: 1px solid var(--border); }
  .service-card { background: #fff; padding: 28px 24px; }
  .service-icon { font-size: 28px; margin-bottom: 12px; }
  .service-name { font-size: 16px; font-weight: 800; text-transform: uppercase; letter-spacing: 0.04em; margin-bottom: 10px; color: var(--text); }
  .service-desc { font-size: 14px; line-height: 1.65; color: var(--muted); margin-bottom: 12px; }
  .service-issues { font-size: 12px; color: var(--red); font-weight: 600; text-transform: uppercase; letter-spacing: 0.06em; }

  .features-2col { display: grid; grid-template-columns: 1fr 1fr; gap: 48px; align-items: start; }
  .features-list { list-style: none; }
  .features-list li { padding: 14px 0; border-bottom: 1px solid #2a2a2a; font-size: 15px; color: #ccc; display: flex; gap: 12px; }
  .features-list li::before { content: "→"; color: var(--red); flex-shrink: 0; }

  .problems-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(260px, 1fr)); gap: 16px; margin-top: 32px; }
  .problem-card { border: 1px solid var(--border); background: #fff; padding: 20px; }
  .problem-title { font-size: 14px; font-weight: 800; text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 8px; color: var(--text); }
  .problem-cause { font-size: 13px; color: var(--muted); line-height: 1.6; margin-bottom: 10px; }
  .problem-tag { display: inline-block; font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; padding: 3px 8px; color: #fff; }
  .tag-classic { background: #c8820a; }
  .tag-tc { background: #2a5ea5; }
  .tag-common { background: var(--red); }
  .tag-enamel { background: #5a2a7a; }

  .pricing-table { width: 100%; border-collapse: collapse; margin-top: 24px; }
  .pricing-table th { background: var(--text); color: #fff; text-align: left; padding: 12px 16px; font-size: 12px; text-transform: uppercase; letter-spacing: 0.08em; }
  .pricing-table td { padding: 14px 16px; border-bottom: 1px solid var(--border); font-size: 14px; }
  .pricing-table tr:last-child td { border-bottom: none; }
  .pricing-table tr:nth-child(even) td { background: var(--gray); }
  .price-range { font-weight: 700; color: var(--red); }

  .why-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: 24px; margin-top: 32px; }
  .why-card { border-left: 3px solid var(--red); padding: 20px; background: #fff; }
  .why-icon { font-size: 24px; margin-bottom: 10px; }
  .why-title { font-size: 14px; font-weight: 800; text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 8px; }
  .why-desc { font-size: 13px; color: var(--muted); line-height: 1.6; }

  .reviews-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 20px; margin-top: 32px; }
  .review-card { background: #fff; border: 1px solid var(--border); padding: 24px; }
  .review-stars { color: var(--red); font-size: 18px; margin-bottom: 10px; }
  .review-text { font-size: 14px; line-height: 1.7; color: var(--text); margin-bottom: 14px; }
  .review-author { font-size: 12px; font-weight: 700; text-transform: uppercase; color: var(--muted); }

  .repairs-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 1px; background: var(--border); border: 1px solid var(--border); margin-top: 32px; }
  .repair-item { background: #fff; padding: 24px; }
  .repair-appliance { font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; color: var(--red); margin-bottom: 6px; }
  .repair-issue { font-size: 15px; font-weight: 800; color: var(--text); margin-bottom: 8px; }
  .repair-detail { font-size: 13px; color: var(--muted); line-height: 1.6; }
  .repair-meta { margin-top: 12px; font-size: 12px; font-weight: 600; color: #aaa; text-transform: uppercase; letter-spacing: 0.06em; }

  .faq-list { margin-top: 32px; }
  .faq-item { border-bottom: 1px solid var(--border); padding: 20px 0; }
  .faq-q { font-size: 16px; font-weight: 800; color: var(--text); margin-bottom: 10px; }
  .faq-a { font-size: 14px; line-height: 1.7; color: var(--muted); max-width: 760px; }

  .nearby-grid { display: flex; flex-wrap: wrap; gap: 8px; margin-top: 20px; }
  .nearby-chip { background: var(--gray); border: 1px solid var(--border); padding: 8px 14px; font-size: 13px; color: var(--muted); text-decoration: none; font-weight: 600; }
  .nearby-chip:hover { border-color: var(--red); color: var(--red); }

  .bottom-cta { background: var(--black); padding: 72px 24px; text-align: center; color: #fff; }
  .bottom-cta-title { font-size: clamp(28px, 4vw, 44px); font-weight: 900; text-transform: uppercase; letter-spacing: -0.01em; margin-bottom: 12px; }
  .bottom-cta-title span { color: var(--red); }
  .bottom-cta-sub { font-size: 17px; color: #888; margin-bottom: 32px; }
  .cta-phone-large { display: inline-block; font-size: clamp(28px, 4vw, 42px); font-weight: 900; color: #fff; text-decoration: none; letter-spacing: -0.01em; margin-bottom: 24px; border-bottom: 2px solid var(--red); padding-bottom: 4px; }

  @media (max-width: 768px) {
    .hero-inner { grid-template-columns: 1fr; }
    .hero-badge-grid { grid-template-columns: 1fr 1fr; }
    .features-2col { grid-template-columns: 1fr; }
    .models-grid { grid-template-columns: 1fr; }
    .trust-bar-inner { flex-direction: column; gap: 6px; }
  }
</style>

<div class="top-bar">
  <span>Mon–Sat 8am–8pm · Los Angeles &amp; Southern California</span>
  <a href={`tel:${phoneRaw}`}>{phone}</a>
</div>

<section class="hero">
  <div class="hero-inner">
    <div>
      <div class="hero-eyebrow">AGA Range Cooker Repair — Los Angeles</div>
      <h1 class="hero-title">
        AGA Repair.<br/>
        <span>Classic. Heat Storage.</span><br/>
        Coalbrookdale, 1922.
      </h1>
      <p class="hero-sub">
        AGA invented heat storage cooking in 1922 in Coalbrookdale, Shropshire. The Classic AGA isn't a range you heat before cooking — it's always on, always hot, radiating from cast iron ovens that weigh hundreds of pounds. Service requires knowing the difference between Classic, Total Control, and Mercury. We do.
      </p>
      <div class="hero-cta-group">
        <a href={`tel:${phoneRaw}`} class="btn-primary">Call {phone}</a>
        <a href="/book/" class="btn-secondary">Book Online</a>
      </div>
    </div>
    <div class="hero-badge-grid">
      <div class="hero-badge">
        <div class="badge-num">Same</div>
        <div class="badge-label">Day Service</div>
      </div>
      <div class="hero-badge">
        <div class="badge-num">OEM</div>
        <div class="badge-label">AGA Parts</div>
      </div>
      <div class="hero-badge">
        <div class="badge-num">90-Day</div>
        <div class="badge-label">Warranty</div>
      </div>
      <div class="hero-badge">
        <div class="badge-num">$89</div>
        <div class="badge-label">Diagnostic Fee</div>
      </div>
    </div>
  </div>
</section>

<div class="trust-bar">
  <div class="trust-bar-inner">
    <span class="trust-item">Licensed &amp; Insured · CSLB #1138898</span>
    <span class="trust-item">Classic Heat Storage Service</span>
    <span class="trust-item">AGA Total Control Specialists</span>
    <span class="trust-item">Cast Iron Door Hinge Service</span>
    <span class="trust-item">Flat-Rate Written Estimate</span>
  </div>
</div>

<section class="section">
  <div class="section-inner">
    <div class="section-num">01 — About AGA</div>
    <h2 class="section-title">Coalbrookdale, Shropshire. Nobel Prize Origin. Heat Storage Since 1922.</h2>
    <p class="section-lead">
      The AGA was invented in 1922 by Dr. Gustaf Dalén — a Swedish physicist and Nobel Prize laureate who had been blinded in a laboratory accident. Unable to see, Dalén became frustrated with the constant attention traditional ranges demanded and set about designing a cooking appliance that required almost none. Working in Coalbrookdale, Shropshire — the cradle of the British Industrial Revolution — he created the heat storage range: a continuously heated cast iron cooking system that never needs preheating because it is never turned off. Classic AGA cast iron ranges are still manufactured in Coalbrookdale today.
    </p>
    <p class="section-lead">
      Understanding this history matters for service: the Classic AGA is fundamentally different from every other cooking appliance. It is not a range you turn on to cook — it is a heat storage appliance you live with, that provides constant radiant heat from massive cast iron ovens maintained at fixed temperatures. When a Classic AGA isn't performing, the problem is always in the heat source (gas valve, burner, thermostat, element) — never in the cast iron ovens themselves, which are passive. AGA Total Control and Mercury are different products entirely, with conventional heating elements and on/off capability.
    </p>

    <div class="models-grid">
      <div class="model-card featured">
        <div class="model-badge">Original · Always-On Heat Storage</div>
        <div class="model-name">Classic AGA</div>
        <div class="model-desc">Gas, oil, or electric versions — always on, always hot. 2-oven (roasting + simmering), 3-oven (+ warming), and 4-oven (+ slow cooking) configurations. Cast iron ovens maintained at fixed temperatures by a continuous low-output heat source. The range Dalén designed in 1922. Service focuses on the heat source, not the ovens.</div>
      </div>
      <div class="model-card">
        <div class="model-badge">Electric · On/Off Capable</div>
        <div class="model-name">AGA Total Control</div>
        <div class="model-desc">AGA's electric model designed to be turned on and off — each oven has individual electric heating elements controlled independently. The AGA aesthetic with modern convenience and energy flexibility. Service requires conventional oven element and control board diagnosis alongside AGA-specific door and enamel knowledge.</div>
      </div>
      <div class="model-card">
        <div class="model-badge">Modern Range Cooker</div>
        <div class="model-name">Mercury / Elise</div>
        <div class="model-desc">AGA's modern range cooker lines — conventional cooking technology (gas, dual-fuel, induction) in AGA-inspired styling. Not heat storage. These function as standard professional ranges and are serviced accordingly. The AGA name and design language without the heat storage philosophy.</div>
      </div>
    </div>

    <div class="tip-block tip-heat" style="margin-top:32px">
      <div class="tip-label">🔥 Classic AGA: Always On — The Diagnostic Implication</div>
      <div class="tip-text">When a Classic AGA owner says "my oven isn't holding temperature," a general appliance technician's instinct is to check the oven thermostat, heating element, or temperature sensor. On a Classic AGA, none of those exist in the oven cavity — the ovens are passive cast iron chambers. The temperature is determined entirely by the heat source beneath: the gas burner or electric element and its control thermostat. "Oven not holding temperature" on a Classic AGA means "heat source not maintaining output" — the diagnosis is at the flue, gas valve, burner assembly, or thermostat. We approach Classic AGA temperature calls with this fundamental understanding before touching anything.</div>
    </div>
  </div>
</section>

<section class="section section-gray">
  <div class="section-inner">
    <div class="section-num">02 — Services</div>
    <h2 class="section-title">Every AGA Configuration We Service</h2>
    <p class="section-lead">All AGA models — Classic 2/3/4-oven, Total Control, Mercury, Elise — gas, oil, and electric. Same-day across Los Angeles County.</p>

    <div class="services-grid">
      <div class="service-card">
        <div class="service-icon">🔥</div>
        <div class="service-name">Classic AGA Heat Source Service</div>
        <div class="service-desc">The Classic AGA's performance depends entirely on the heat source — the gas burner, oil burner, or electric element and its control thermostat that maintains the cast iron at operating temperature. Gas Classic AGA: the gas valve, thermostat, and burner assembly are the service focus. Electric Classic AGA: the heating element, element control, and temperature regulator. When a Classic AGA isn't as hot as it should be, isn't heating evenly, or has gone cold entirely, we diagnose the heat source first and always — never the passive cast iron ovens.</div>
        <div class="service-issues">Common: gas valve · thermostat (always-on control) · burner assembly · gas pressure regulator · flue assessment · electric element (electric models) · temperature regulator · pilot issues</div>
      </div>

      <div class="service-card">
        <div class="service-icon">🚪</div>
        <div class="service-name">Cast Iron Door &amp; Hinge Service</div>
        <div class="service-desc">AGA Classic oven doors are solid cast iron — each weighing 25-35 lbs. The door hinge system must support this weight through thousands of open-close cycles. Hinge wear manifests gradually: the door begins to sag at the open position, then stops seating flush when closed. A Classic AGA oven door that doesn't seal correctly loses radiant heat from the cavity, reducing oven temperature. We service AGA door hinges, hinge springs, door catches, and door seals as a specific discipline of AGA service.</div>
        <div class="service-issues">Common: door hinge wear (heavy cast iron) · door not sealing flush · door catch fault · door seal compression loss · hinge spring replacement · door alignment</div>
      </div>

      <div class="service-card">
        <div class="service-icon">⚡</div>
        <div class="service-name">AGA Total Control Service</div>
        <div class="service-desc">AGA Total Control uses individual electric heating elements for each oven cavity — independently controlled so each oven can be set to different temperatures or turned off entirely. Service is conventional oven service with AGA-specific considerations: heavy cast iron door hinges (same as Classic), porcelain enamel finish, and the AGA physical construction that differs from standard range ovens. Control board failure, element failure, and temperature sensor issues are the most common Total Control faults.</div>
        <div class="service-issues">Common: heating element · control board · temperature sensor · individual oven not heating · door hinge (heavy cast iron) · enamel care · power supply</div>
      </div>

      <div class="service-card">
        <div class="service-icon">✨</div>
        <div class="service-name">Porcelain Enamel Assessment</div>
        <div class="service-desc">AGA's porcelain enamel finish — applied to the cast iron exterior — is a fired vitreous enamel similar to La Cornue and Smeg. Enamel chips at sharp impact and cannot be touched up in-situ without professional respray. AGA's enamel is specifically formulated for continuous heat exposure — which standard enamel cannot withstand. Chipping typically occurs at edges and corners from contact. We assess enamel condition on every AGA service call and document any chipping for owner reference.</div>
        <div class="service-issues">Enamel condition assessment · chip documentation · cleaning protocol guidance · AGA-approved cleaner recommendation · AGA Customer Care referral for professional respray</div>
      </div>

      <div class="service-card">
        <div class="service-icon">🌀</div>
        <div class="service-name">Mercury &amp; Elise Range Service</div>
        <div class="service-desc">AGA Mercury and Elise ranges use conventional cooking technology — gas, dual-fuel, or induction — in AGA's distinctive styling. These are not heat storage appliances. Service follows the same professional range protocols as other European ranges: gas igniter and valve service, induction zone inverter diagnosis, oven temperature calibration, convection fan service. The AGA name applies to the design; the engineering is conventional range architecture.</div>
        <div class="service-issues">Common: igniter failure · gas valve · induction zone inverter · oven temperature · convection fan · door gasket · control board · cooktop service</div>
      </div>

