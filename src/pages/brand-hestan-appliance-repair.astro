---
import Layout from '../layouts/Layout.astro';

const title = "Hestan Appliance Repair Los Angeles | Indoor & Outdoor Specialists";
const description = "Expert Hestan appliance repair in Los Angeles. Trellis Burner grills, Campania Pizza Oven, indoor ranges, refrigerators & more. Made in Anaheim — we know this brand. Same-day service, OEM parts, 90-day warranty. Call (626) 376-4458.";
const phone = "(626) 376-4458";
const phoneRaw = "6263764458";
---

<Layout title={title} description={description}>

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "HomeAndConstructionBusiness",
  "name": "Same Day Appliance Repair — Hestan Specialist",
  "url": "https://samedayappliance.repair/brand-hestan-appliance-repair/",
  "telephone": "+16263764458",
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Los Angeles",
    "addressRegion": "CA",
    "postalCode": "90001",
    "addressCountry": "US"
  },
  "areaServed": ["Los Angeles County", "Orange County", "Ventura County"],
  "priceRange": "$$",
  "openingHours": "Mo-Sa 08:00-20:00",
  "hasOfferCatalog": {
    "@type": "OfferCatalog",
    "name": "Hestan Repair Services",
    "itemListElement": [
      {"@type":"Offer","itemOffered":{"@type":"Service","name":"Hestan Trellis Burner Grill Repair"}},
      {"@type":"Offer","itemOffered":{"@type":"Service","name":"Hestan Campania Pizza Oven Repair"}},
      {"@type":"Offer","itemOffered":{"@type":"Service","name":"Hestan Indoor Range Repair"}},
      {"@type":"Offer","itemOffered":{"@type":"Service","name":"Hestan Refrigerator Repair"}},
      {"@type":"Offer","itemOffered":{"@type":"Service","name":"Hestan Outdoor Kitchen Repair"}},
      {"@type":"Offer","itemOffered":{"@type":"Service","name":"Hestan Dishwasher Repair"}}
    ]
  }
}
</script>

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "How much does Hestan appliance repair cost in Los Angeles?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Most Hestan repairs run $185–$620. Trellis Burner igniter replacement, door gasket, or temperature sensor work is on the lower end. Control board or sealed system repairs run higher. Diagnostic fee is $89, waived when you proceed. Written flat-rate estimate before work begins."
      }
    },
    {
      "@type": "Question",
      "name": "Do you repair the Hestan Campania Pizza Oven?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes. The Hestan Campania Pizza Oven is a unique product requiring specific service knowledge — the ceramic deck, gas burner configuration, and high-temperature operation (up to 700°F) create failure modes different from standard outdoor cooking equipment. Common issues: igniter failure, burner valve fault, temperature inconsistency, and ceramic deck damage assessment. We service the Campania as part of our Hestan outdoor service scope."
      }
    },
    {
      "@type": "Question",
      "name": "Do you service Hestan outdoor grills in coastal Los Angeles?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes — and coastal service is a specialty. Hestan grills are made from heavy-gauge stainless steel in Anaheim, CA, but even the best materials are vulnerable to salt air corrosion at igniter tips and valve stems. Properties in Malibu, Pacific Palisades, and Manhattan Beach need annual igniter and valve inspection. We treat Hestan outdoor service calls with marine-grade anti-corrosion protocols."
      }
    },
    {
      "@type": "Question",
      "name": "What is Hestan's Trellis Burner and what breaks?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The Trellis Burner™ is Hestan's patented grill burner design — a trellis-shaped stainless steel configuration that delivers 25,000 BTUs with more even heat distribution than standard tube burners. The most common failure: burner tube blockage from grease and debris accumulation between the trellis elements. The trellis geometry traps debris differently than tube burners and requires specific cleaning technique. Igniter failure is the second most common Trellis Burner issue."
      }
    },
    {
      "@type": "Question",
      "name": "Where is Hestan made?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Hestan grills are made in Anaheim, California — about 30 miles from Los Angeles. Hestan cuts its own steel, fabricates grates in-house, and laser-cuts components on-site. This makes Hestan the only major luxury grill brand manufactured in the United States. Indoor Hestan appliances (ranges, refrigerators, dishwashers) are also designed in the US."
      }
    },
    {
      "@type": "Question",
      "name": "Do you service both Hestan Indoor and Hestan Outdoor appliances?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes — both the Hestan Indoor line (ranges, ovens, refrigerators, dishwashers, wine storage, ventilation) and Hestan Outdoor (grills, outdoor kitchen suites, Campania Pizza Oven). Many LA homeowners have both. We service the complete Hestan ecosystem in a single visit."
      }
    }
  ]
}
</script>

<style>
  :root {
    --red: #C8102E;
    --black: #0a0a0a;
    --gray: #f5f5f5;
    --border: #e2e2e2;
    --text: #1a1a1a;
    --muted: #6b6b6b;
  }
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body { font-family: 'Barlow', 'Inter', system-ui, sans-serif; color: var(--text); }

  .top-bar { background: var(--red); padding: 8px 24px; display: flex; justify-content: space-between; align-items: center; font-size: 13px; color: #fff; }
  .top-bar a { color: #fff; text-decoration: none; font-weight: 700; }

  .hero { background: var(--black); padding: 72px 24px 64px; color: #fff; }
  .hero-inner { max-width: 1100px; margin: 0 auto; display: grid; grid-template-columns: 1fr 420px; gap: 48px; align-items: center; }
  .hero-eyebrow { font-size: 11px; font-weight: 700; letter-spacing: 0.15em; text-transform: uppercase; color: var(--red); margin-bottom: 16px; }
  .hero-title { font-size: clamp(32px, 5vw, 52px); font-weight: 900; line-height: 1.05; text-transform: uppercase; letter-spacing: -0.02em; margin-bottom: 20px; }
  .hero-title span { color: var(--red); }
  .hero-sub { font-size: 17px; line-height: 1.6; color: #aaa; margin-bottom: 32px; max-width: 540px; }
  .hero-cta-group { display: flex; gap: 16px; flex-wrap: wrap; }
  .btn-primary { display: inline-block; background: var(--red); color: #fff; padding: 14px 28px; font-size: 15px; font-weight: 700; text-decoration: none; letter-spacing: 0.04em; text-transform: uppercase; }
  .btn-secondary { display: inline-block; border: 1px solid #555; color: #ccc; padding: 14px 28px; font-size: 15px; font-weight: 600; text-decoration: none; letter-spacing: 0.04em; text-transform: uppercase; }
  .hero-badge-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
  .hero-badge { background: #161616; border: 1px solid #2a2a2a; padding: 16px 18px; }
  .badge-num { font-size: 28px; font-weight: 900; color: var(--red); line-height: 1; margin-bottom: 4px; }
  .badge-label { font-size: 12px; color: #888; text-transform: uppercase; letter-spacing: 0.08em; }

  .trust-bar { background: var(--red); padding: 14px 24px; }
  .trust-bar-inner { max-width: 1100px; margin: 0 auto; display: flex; justify-content: space-between; flex-wrap: wrap; gap: 8px; }
  .trust-item { color: #fff; font-size: 13px; font-weight: 600; letter-spacing: 0.04em; text-transform: uppercase; }
  .trust-item::before { content: "✓ "; }

  .section { padding: 64px 24px; }
  .section-gray { background: var(--gray); }
  .section-black { background: var(--black); color: #fff; }
  .section-inner { max-width: 1100px; margin: 0 auto; }
  .section-num { font-size: 11px; font-weight: 700; letter-spacing: 0.15em; text-transform: uppercase; color: var(--red); margin-bottom: 8px; }
  .section-title { font-size: clamp(24px, 3.5vw, 36px); font-weight: 900; text-transform: uppercase; letter-spacing: -0.01em; margin-bottom: 20px; }
  .section-black .section-title { color: #fff; }
  .section-lead { font-size: 17px; line-height: 1.7; color: var(--muted); max-width: 760px; margin-bottom: 40px; }
  .section-black .section-lead { color: #999; }

  /* Indoor/Outdoor split */
  .ecosystem-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1px; background: #2a2a2a; border: 1px solid #2a2a2a; margin-top: 28px; }
  .eco-card { background: #161616; padding: 24px; }
  .eco-label { font-size: 10px; font-weight: 800; text-transform: uppercase; letter-spacing: 0.15em; color: var(--red); margin-bottom: 8px; }
  .eco-title { font-size: 18px; font-weight: 900; text-transform: uppercase; color: #fff; margin-bottom: 12px; }
  .eco-list { list-style: none; }
  .eco-list li { font-size: 13px; color: #888; padding: 4px 0; border-bottom: 1px solid #222; }
  .eco-list li::before { content: "· "; color: var(--red); }

  .tip-block { border-left: 3px solid var(--red); background: #fff8f8; padding: 18px 20px; margin: 32px 0; max-width: 760px; }
  .tip-label { font-size: 10px; font-weight: 800; text-transform: uppercase; letter-spacing: 0.15em; color: var(--red); margin-bottom: 6px; }
  .tip-text { font-size: 14px; line-height: 1.65; color: var(--text); }
  .tip-made { border-color: #2a7a4a; background: #f0fff5; }
  .tip-made .tip-label { color: #2a7a4a; }
  .tip-coastal { border-color: #3a7bd5; background: #f0f7ff; }
  .tip-coastal .tip-label { color: #3a7bd5; }

  .services-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 1px; background: var(--border); border: 1px solid var(--border); }
  .service-card { background: #fff; padding: 28px 24px; }
  .service-icon { font-size: 28px; margin-bottom: 12px; }
  .service-name { font-size: 16px; font-weight: 800; text-transform: uppercase; letter-spacing: 0.04em; margin-bottom: 10px; color: var(--text); }
  .service-desc { font-size: 14px; line-height: 1.65; color: var(--muted); margin-bottom: 12px; }
  .service-issues { font-size: 12px; color: var(--red); font-weight: 600; text-transform: uppercase; letter-spacing: 0.06em; }

  .features-2col { display: grid; grid-template-columns: 1fr 1fr; gap: 48px; align-items: start; }
  .features-list { list-style: none; }
  .features-list li { padding: 14px 0; border-bottom: 1px solid #2a2a2a; font-size: 15px; color: #ccc; display: flex; gap: 12px; }
  .features-list li::before { content: "→"; color: var(--red); flex-shrink: 0; }

  .problems-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(260px, 1fr)); gap: 16px; margin-top: 32px; }
  .problem-card { border: 1px solid var(--border); background: #fff; padding: 20px; }
  .problem-title { font-size: 14px; font-weight: 800; text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 8px; color: var(--text); }
  .problem-cause { font-size: 13px; color: var(--muted); line-height: 1.6; margin-bottom: 10px; }
  .problem-tag { display: inline-block; font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; padding: 3px 8px; color: #fff; }
  .tag-common { background: var(--red); }
  .tag-outdoor { background: #2a7a2a; }
  .tag-coastal { background: #2a5ea5; }
  .tag-pizza { background: #8b3a14; }

  .pricing-table { width: 100%; border-collapse: collapse; margin-top: 24px; }
  .pricing-table th { background: var(--text); color: #fff; text-align: left; padding: 12px 16px; font-size: 12px; text-transform: uppercase; letter-spacing: 0.08em; }
  .pricing-table td { padding: 14px 16px; border-bottom: 1px solid var(--border); font-size: 14px; }
  .pricing-table tr:last-child td { border-bottom: none; }
  .pricing-table tr:nth-child(even) td { background: var(--gray); }
  .price-range { font-weight: 700; color: var(--red); }

  .why-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: 24px; margin-top: 32px; }
  .why-card { border-left: 3px solid var(--red); padding: 20px; background: #fff; }
  .why-icon { font-size: 24px; margin-bottom: 10px; }
  .why-title { font-size: 14px; font-weight: 800; text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 8px; }
  .why-desc { font-size: 13px; color: var(--muted); line-height: 1.6; }

  .reviews-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 20px; margin-top: 32px; }
  .review-card { background: #fff; border: 1px solid var(--border); padding: 24px; }
  .review-stars { color: var(--red); font-size: 18px; margin-bottom: 10px; }
  .review-text { font-size: 14px; line-height: 1.7; color: var(--text); margin-bottom: 14px; }
  .review-author { font-size: 12px; font-weight: 700; text-transform: uppercase; color: var(--muted); }

  .repairs-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 1px; background: var(--border); border: 1px solid var(--border); margin-top: 32px; }
  .repair-item { background: #fff; padding: 24px; }
  .repair-appliance { font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; color: var(--red); margin-bottom: 6px; }
  .repair-issue { font-size: 15px; font-weight: 800; color: var(--text); margin-bottom: 8px; }
  .repair-detail { font-size: 13px; color: var(--muted); line-height: 1.6; }
  .repair-meta { margin-top: 12px; font-size: 12px; font-weight: 600; color: #aaa; text-transform: uppercase; letter-spacing: 0.06em; }

  .faq-list { margin-top: 32px; }
  .faq-item { border-bottom: 1px solid var(--border); padding: 20px 0; }
  .faq-q { font-size: 16px; font-weight: 800; color: var(--text); margin-bottom: 10px; }
  .faq-a { font-size: 14px; line-height: 1.7; color: var(--muted); max-width: 760px; }

  .nearby-grid { display: flex; flex-wrap: wrap; gap: 8px; margin-top: 20px; }
  .nearby-chip { background: var(--gray); border: 1px solid var(--border); padding: 8px 14px; font-size: 13px; color: var(--muted); text-decoration: none; font-weight: 600; }
  .nearby-chip:hover { border-color: var(--red); color: var(--red); }

  .bottom-cta { background: var(--black); padding: 72px 24px; text-align: center; color: #fff; }
  .bottom-cta-title { font-size: clamp(28px, 4vw, 44px); font-weight: 900; text-transform: uppercase; letter-spacing: -0.01em; margin-bottom: 12px; }
  .bottom-cta-title span { color: var(--red); }
  .bottom-cta-sub { font-size: 17px; color: #888; margin-bottom: 32px; }
  .cta-phone-large { display: inline-block; font-size: clamp(28px, 4vw, 42px); font-weight: 900; color: #fff; text-decoration: none; letter-spacing: -0.01em; margin-bottom: 24px; border-bottom: 2px solid var(--red); padding-bottom: 4px; }

  @media (max-width: 768px) {
    .hero-inner { grid-template-columns: 1fr; }
    .hero-badge-grid { grid-template-columns: 1fr 1fr; }
    .features-2col { grid-template-columns: 1fr; }
    .ecosystem-grid { grid-template-columns: 1fr; }
    .trust-bar-inner { flex-direction: column; gap: 6px; }
  }
</style>

<!-- TOP BAR -->
<div class="top-bar">
  <span>Mon–Sat 8am–8pm · Los Angeles &amp; Southern California</span>
  <a href={`tel:${phoneRaw}`}>{phone}</a>
</div>

<!-- HERO -->
<section class="hero">
  <div class="hero-inner">
    <div>
      <div class="hero-eyebrow">Hestan Appliance Repair — Los Angeles</div>
      <h1 class="hero-title">
        Hestan Repair.<br/>
        <span>Made 30 Miles</span><br/>
        From Here.
      </h1>
      <p class="hero-sub">
        Hestan grills are built in Anaheim, California — the only major luxury grill brand manufactured in the United States. Indoor ranges, refrigerators, the Campania Pizza Oven, the Trellis Burner™. We service the complete Hestan ecosystem, same day, with OEM parts sourced from the same supply chain as the factory.
      </p>
      <div class="hero-cta-group">
        <a href={`tel:${phoneRaw}`} class="btn-primary">Call {phone}</a>
        <a href="/book/" class="btn-secondary">Book Online</a>
      </div>
    </div>
    <div class="hero-badge-grid">
      <div class="hero-badge">
        <div class="badge-num">Same</div>
        <div class="badge-label">Day Service</div>
      </div>
      <div class="hero-badge">
        <div class="badge-num">OEM</div>
        <div class="badge-label">Hestan Parts</div>
      </div>
      <div class="hero-badge">
        <div class="badge-num">90-Day</div>
        <div class="badge-label">Warranty</div>
      </div>
      <div class="hero-badge">
        <div class="badge-num">$89</div>
        <div class="badge-label">Diagnostic Fee</div>
      </div>
    </div>
  </div>
</section>

<!-- TRUST BAR -->
<div class="trust-bar">
  <div class="trust-bar-inner">
    <span class="trust-item">Licensed &amp; Insured · CSLB #1138898</span>
    <span class="trust-item">Trellis Burner™ Specialists</span>
    <span class="trust-item">Campania Pizza Oven Service</span>
    <span class="trust-item">Indoor + Outdoor Complete Service</span>
    <span class="trust-item">Flat-Rate Written Estimate</span>
  </div>
</div>

<!-- 01 — ABOUT HESTAN -->
<section class="section">
  <div class="section-inner">
    <div class="section-num">01 — About Hestan</div>
    <h2 class="section-title">The Youngest Luxury Brand in the Room — Built 30 Miles From LA</h2>
    <p class="section-lead">
      Hestan was founded in 2015 by Stanley Chue, who also founded Meyer Corporation — the company behind Circulon, Anolon, and Farberware, and one of the world's largest cookware manufacturers. Chue applied the same manufacturing philosophy to appliances: control the entire process, use restaurant-grade materials, and build something that performs for professionals without requiring a commercial kitchen installation.
    </p>
    <p class="section-lead">
      The outdoor line is made in Anaheim, California. Hestan cuts its own steel, fabricates its own grates, and laser-cuts components in-house. This makes Hestan the only major luxury grill brand manufactured in the United States — and it puts the supply chain 30 miles from Los Angeles. The indoor line brings the same approach to ranges, refrigerators, dishwashers, and wine storage. When you have a Hestan in LA, you have a product that was built nearby.
    </p>

    <div class="ecosystem-grid">
      <div class="eco-card">
        <div class="eco-label">Hestan Indoor</div>
        <div class="eco-title">Kitchen Suite</div>
        <ul class="eco-list">
          <li>Professional ranges (30", 36", 48")</li>
          <li>Wall ovens — single &amp; double</li>
          <li>Refrigerators &amp; wine storage</li>
          <li>Dishwashers</li>
          <li>Ventilation hoods</li>
          <li>NanoeShield™ antimicrobial coating</li>
        </ul>
      </div>
      <div class="eco-card">
        <div class="eco-label">Hestan Outdoor</div>
        <div class="eco-title">Outdoor Kitchen</div>
        <ul class="eco-list">
          <li>Built-in &amp; freestanding grills</li>
          <li>Campania Pizza Oven™</li>
          <li>Trellis Burner™ 25,000 BTU</li>
          <li>Ceramic infrared top burner</li>
          <li>Outdoor kitchen suites</li>
          <li>Aspire collection (outdoor)</li>
        </ul>
      </div>
    </div>

    <div class="tip-block tip-made" style="margin-top:32px">
      <div class="tip-label">🏭 Made in Anaheim — What It Means for Service</div>
      <div class="tip-text">Because Hestan manufactures in Anaheim, OEM parts move faster through the supply chain for LA service calls than for imported luxury brands. When we need a specific Trellis Burner™ component or a Horizon Hood™ motor, we're sourcing from the same regional supply network as the factory. Most Hestan outdoor parts arrive same-day or next-day in the LA market. This is a real advantage over European luxury brands where specialty parts can take a week.</div>
    </div>
  </div>
</section>

<!-- 02 — SERVICES -->
<section class="section section-gray">
  <div class="section-inner">
    <div class="section-num">02 — Services</div>
    <h2 class="section-title">Every Hestan Appliance We Service</h2>
    <p class="section-lead">Complete Hestan Indoor and Outdoor service, same-day across Los Angeles County.</p>

    <div class="services-grid">
      <div class="service-card">
        <div class="service-icon">🔥</div>
        <div class="service-name">Trellis Burner™ Grill Repair</div>
        <div class="service-desc">Hestan's patented Trellis Burner™ delivers 25,000 BTUs through a trellis-shaped stainless steel configuration that distributes heat more evenly than standard tube burners. The trellis geometry accumulates grease and debris differently than tube burners — cleaning requires specific technique to clear between the trellis elements without damaging the burner. We service all Hestan grill configurations including the ceramic infrared top burner and rotisserie system.</div>
        <div class="service-issues">Common: trellis burner blocked · igniter failure · ceramic infrared fault · burner valve · rotisserie motor · temperature inconsistency · coastal corrosion (Malibu/Palisades)</div>
      </div>

      <div class="service-card">
        <div class="service-icon">🍕</div>
        <div class="service-name">Campania Pizza Oven™ Repair</div>
        <div class="service-desc">The Hestan Campania Pizza Oven is one of the most distinctive outdoor cooking products on the market — a purpose-built pizza oven designed to reach 700°F with a ceramic deck that mimics a wood-fired oven. Service requires knowledge of the high-temperature gas circuit, ceramic deck assessment, and the dome ventilation system. Most general appliance companies have never serviced one. We have.</div>
        <div class="service-issues">Common: igniter failure (high-temp environment) · burner valve fault · ceramic deck inspection · temperature inconsistency · ventilation restriction · door seal · control knob</div>
      </div>

      <div class="service-card">
        <div class="service-icon">🔴</div>
        <div class="service-name">Indoor Range &amp; Oven Repair</div>
        <div class="service-desc">Hestan's indoor professional ranges — the KNG (KANA collection) and KRGD series — bring outdoor grill-grade burner technology inside. The ranges use sealed burners with similar BTU output to the Trellis Burner outdoor system. Common issues mirror DCS and Wolf at comparable BTU levels: igniter failure from high-heat thermal cycling, oven temperature calibration, and control board faults.</div>
        <div class="service-issues">Common: igniter failure · oven temperature off · convection fan · door gasket · control board · bake element · dual fuel ignition · range hood motor</div>
      </div>

      <div class="service-card">
        <div class="service-icon">❄️</div>
        <div class="service-name">Refrigerator &amp; Wine Storage Repair</div>
        <div class="service-desc">Hestan column refrigerators and wine storage units. Hestan's refrigeration line shares design language with the indoor range suite — panel-ready configurations designed to integrate into custom cabinetry. Service requires care around the cabinetry interface, NanoeShield™ coated interior surfaces, and the wine storage temperature calibration system.</div>
        <div class="service-issues">Common: not cooling · temperature fluctuation · wine storage calibration · ice maker · door gasket · compressor · condenser service · NanoeShield interior care</div>
      </div>

      <div class="service-card">
        <div class="service-icon">🌿</div>
        <div class="service-name">Outdoor Kitchen Suite Repair</div>
        <div class="service-desc">Complete Hestan outdoor kitchen suites — built-in grills, side burners, refrigeration drawers, and the full Aspire and Kana outdoor collection. LA outdoor kitchens run year-round, which means year-round exposure to the coastal and Santa Ana conditions that accelerate valve and igniter wear. We provide full outdoor kitchen service including weatherproofing assessment.</div>
        <div class="service-issues">Common: igniter failure · valve corrosion · refrigeration drawer · side burner · outdoor refrigerator · Horizon Hood™ · lighting system · weatherproofing</div>
      </div>

      <div class="service-card">
        <div class="service-icon">🍽️</div>
        <div class="service-name">Dishwasher &amp; Ventilation Repair</div>
        <div class="service-desc">Hestan dishwashers and ventilation hoods. Hestan's indoor dishwashers use a quiet-operation design with specific filter and spray arm configurations. The ventilation hood line includes wall and island configurations designed to match the indoor range suite — blower motor and speed selector are the most common service points.</div>
