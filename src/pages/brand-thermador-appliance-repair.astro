---
import Layout from '../layouts/Layout.astro';

const title = "Thermador Appliance Repair Los Angeles | Same Day Service";
const description = "Expert Thermador appliance repair in Los Angeles. Certified technicians for ranges, wall ovens, built-in refrigerators, steam ovens & more. Same-day service, OEM parts, 90-day warranty. Call (626) 376-4458.";
const phone = "(626) 376-4458";
const phoneRaw = "6263764458";
---

<Layout title={title} description={description}>

<!-- ══════════════════════════════════════
     SCHEMA — LocalBusiness + Service
══════════════════════════════════════ -->
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "HomeAndConstructionBusiness",
  "name": "Same Day Appliance Repair — Thermador Specialist",
  "image": "https://samedayappliance.repair/images/logo.png",
  "url": "https://samedayappliance.repair/brand-thermador-appliance-repair/",
  "telephone": "+16263764458",
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Los Angeles",
    "addressRegion": "CA",
    "postalCode": "90001",
    "addressCountry": "US"
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": 34.0522,
    "longitude": -118.2437
  },
  "areaServed": ["Los Angeles County", "Orange County", "Ventura County"],
  "priceRange": "$$",
  "openingHours": "Mo-Sa 08:00-20:00",
  "hasOfferCatalog": {
    "@type": "OfferCatalog",
    "name": "Thermador Repair Services",
    "itemListElement": [
      {"@type":"Offer","itemOffered":{"@type":"Service","name":"Thermador Range Repair"}},
      {"@type":"Offer","itemOffered":{"@type":"Service","name":"Thermador Wall Oven Repair"}},
      {"@type":"Offer","itemOffered":{"@type":"Service","name":"Thermador Refrigerator Repair"}},
      {"@type":"Offer","itemOffered":{"@type":"Service","name":"Thermador Steam Oven Repair"}},
      {"@type":"Offer","itemOffered":{"@type":"Service","name":"Thermador Dishwasher Repair"}},
      {"@type":"Offer","itemOffered":{"@type":"Service","name":"Thermador Warming Drawer Repair"}}
    ]
  }
}
</script>

<!-- FAQ Schema -->
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "How much does Thermador appliance repair cost in Los Angeles?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Most Thermador repairs run $180–$650 in parts and labor. Common fixes like an igniter replacement or door gasket are on the lower end. Control board or sealed system work runs higher. We provide a flat-rate written estimate before any work begins — diagnostic fee is $89, waived if you proceed with the repair."
      }
    },
    {
      "@type": "Question",
      "name": "Do you carry Thermador OEM parts on the truck?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes. Our vans stock the most common Thermador parts — igniters for Star® and ExtraLow® burners, control boards, door gaskets, thermistors, convection fan motors, and more. Most repairs are completed in a single visit. Rare or model-specific parts typically arrive within 1–2 business days."
      }
    },
    {
      "@type": "Question",
      "name": "Is it worth repairing a Thermador vs replacing it?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Almost always yes, especially for built-in models. A Thermador wall oven or column refrigerator costs $4,000–$12,000 new, plus cabinet modification. If the repair is under 40% of replacement cost and the appliance is under 15 years old, repair is almost always the right call. Our technician gives you an honest assessment on-site."
      }
    },
    {
      "@type": "Question",
      "name": "Do you service Thermador appliances throughout LA County?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes. We cover all of Los Angeles County — from Malibu and Pacific Palisades to Pasadena, Bel Air, Beverly Hills, Brentwood, West Hollywood, Silver Lake, and the San Fernando Valley."
      }
    },
    {
      "@type": "Question",
      "name": "Will non-OEM parts void my Thermador warranty?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes, in most cases. Non-OEM parts can void your remaining Thermador factory warranty and may affect insurance claims on built-in appliances. We use only genuine Thermador OEM parts on every job."
      }
    },
    {
      "@type": "Question",
      "name": "Can you convert my Thermador cooktop from LP to natural gas?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes. Our technicians carry factory LP-to-natural gas conversion kits for Thermador ranges and cooktops. Mention the fuel type when you call so we can confirm the right kit is on the truck."
      }
    }
  ]
}
</script>

<style>
  /* ── DESIGN TOKENS ── */
  :root {
    --red: #C8102E;
    --black: #0a0a0a;
    --gray: #f5f5f5;
    --border: #e2e2e2;
    --text: #1a1a1a;
    --muted: #6b6b6b;
  }

  * { box-sizing: border-box; margin: 0; padding: 0; }

  body { font-family: 'Barlow', 'Inter', system-ui, sans-serif; color: var(--text); }

  /* ── TOP BAR ── */
  .top-bar {
    background: var(--red);
    padding: 8px 24px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 13px;
    color: #fff;
  }
  .top-bar a { color: #fff; text-decoration: none; font-weight: 700; }

  /* ── HERO ── */
  .hero {
    background: var(--black);
    padding: 72px 24px 64px;
    color: #fff;
  }
  .hero-inner {
    max-width: 1100px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 420px;
    gap: 48px;
    align-items: center;
  }
  .hero-eyebrow {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--red);
    margin-bottom: 16px;
  }
  .hero-title {
    font-size: clamp(32px, 5vw, 52px);
    font-weight: 900;
    line-height: 1.05;
    text-transform: uppercase;
    letter-spacing: -0.02em;
    margin-bottom: 20px;
  }
  .hero-title span { color: var(--red); }
  .hero-sub {
    font-size: 17px;
    line-height: 1.6;
    color: #aaa;
    margin-bottom: 32px;
    max-width: 540px;
  }
  .hero-cta-group { display: flex; gap: 16px; flex-wrap: wrap; }
  .btn-primary {
    display: inline-block;
    background: var(--red);
    color: #fff;
    padding: 14px 28px;
    font-size: 15px;
    font-weight: 700;
    text-decoration: none;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }
  .btn-secondary {
    display: inline-block;
    border: 1px solid #555;
    color: #ccc;
    padding: 14px 28px;
    font-size: 15px;
    font-weight: 600;
    text-decoration: none;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }
  .hero-badge-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
  }
  .hero-badge {
    background: #161616;
    border: 1px solid #2a2a2a;
    padding: 16px 18px;
  }
  .badge-num {
    font-size: 28px;
    font-weight: 900;
    color: var(--red);
    line-height: 1;
    margin-bottom: 4px;
  }
  .badge-label { font-size: 12px; color: #888; text-transform: uppercase; letter-spacing: 0.08em; }

  /* ── TRUST BAR ── */
  .trust-bar {
    background: var(--red);
    padding: 14px 24px;
  }
  .trust-bar-inner {
    max-width: 1100px;
    margin: 0 auto;
    display: flex;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 8px;
  }
  .trust-item {
    color: #fff;
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }
  .trust-item::before { content: "✓ "; }

  /* ── SECTIONS ── */
  .section { padding: 64px 24px; }
  .section-gray { background: var(--gray); }
  .section-black { background: var(--black); color: #fff; }
  .section-inner { max-width: 1100px; margin: 0 auto; }

