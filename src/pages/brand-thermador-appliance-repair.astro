    color: var(--red);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  /* ── TIP BLOCK ── */
  .tip-block {
    border-left: 3px solid var(--red);
    background: #fff8f8;
    padding: 18px 20px;
    margin: 32px 0;
    max-width: 760px;
  }
  .tip-label {
