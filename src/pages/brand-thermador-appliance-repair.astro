  .tip-climate {
    border-color: #3a7bd5;
    background: #f0f7ff;
  }

  /* ── FEATURES 2-COL ── */
  .features-2col {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 48px;
