    font-size: 12px;
    font-weight: 600;
    color: #aaa;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  /* ── FAQ ── */
  .faq-list { margin-top: 32px; }
  .faq-item {
    border-bottom: 1px solid var(--border);
    padding: 20px 0;
  }
  .faq-q {
    font-size: 16px;
    font-weight: 800;
    color: var(--text);
    margin-bottom: 10px;
