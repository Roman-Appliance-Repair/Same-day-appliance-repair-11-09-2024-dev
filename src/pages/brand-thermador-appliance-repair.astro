  .repair-appliance {
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--red);
    margin-bottom: 6px;
  }
  .repair-issue {
    font-size: 15px;
    font-weight: 800;
    color: var(--text);
