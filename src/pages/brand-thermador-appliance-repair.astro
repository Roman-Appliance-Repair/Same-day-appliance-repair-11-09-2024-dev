  }
  .faq-a { font-size: 14px; line-height: 1.7; color: var(--muted); max-width: 760px; }

  /* ── BOTTOM CTA ── */
  .bottom-cta {
    background: var(--black);
    padding: 72px 24px;
    text-align: center;
    color: #fff;
  }
  .bottom-cta-title {
    font-size: clamp(28px, 4vw, 44px);
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: -0.01em;
    margin-bottom: 12px;
  }
  .bottom-cta-title span { color: var(--red); }
  .bottom-cta-sub {
    font-size: 17px;
    color: #888;
    margin-bottom: 32px;
  }
  .cta-phone-large {
    display: inline-block;
    font-size: clamp(28px, 4vw, 42px);
    font-weight: 900;
    color: #fff;
    text-decoration: none;
    letter-spacing: -0.01em;
    margin-bottom: 24px;
    border-bottom: 2px solid var(--red);
    padding-bottom: 4px;
  }

  /* ── NEARBY ── */
  .nearby-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 20px;
  }
  .nearby-chip {
    background: var(--gray);
    border: 1px solid var(--border);
    padding: 8px 14px;
    font-size: 13px;
    color: var(--muted);
    text-decoration: none;
    font-weight: 600;
  }
  .nearby-chip:hover { border-color: var(--red); color: var(--red); }

  @media (max-width: 768px) {
    .hero-inner { grid-template-columns: 1fr; }
    .hero-badge-grid { grid-template-columns: 1fr 1fr; }
    .features-2col { grid-template-columns: 1fr; }
    .trust-bar-inner { flex-direction: column; gap: 6px; }
  }
</style>

