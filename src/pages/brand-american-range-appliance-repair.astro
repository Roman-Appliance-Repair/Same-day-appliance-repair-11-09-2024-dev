---
import Layout from '../layouts/Layout.astro';

const title = "American Range Appliance Repair Los Angeles | Made in LA — Chatsworth Specialists";
const description = "Expert American Range repair in Los Angeles. Pro ranges, Innovection® Convection, open burners, stock pot, wok range — made in Chatsworth, LA since the 1970s. Same-day service. Call (626) 376-4458.";
const phone = "(626) 376-4458";
const phoneRaw = "6263764458";
---

<Layout title={title} description={description}>

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "HomeAndConstructionBusiness",
  "name": "Same Day Appliance Repair — American Range Specialist",
  "url": "https://samedayappliance.repair/brand-american-range-appliance-repair/",
  "telephone": "+16263764458",
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Los Angeles",
    "addressRegion": "CA",
    "postalCode": "90001",
    "addressCountry": "US"
  },
  "areaServed": ["Los Angeles County", "Orange County", "Ventura County"],
  "priceRange": "$$",
  "openingHours": "Mo-Sa 08:00-20:00",
  "hasOfferCatalog": {
    "@type": "OfferCatalog",
    "name": "American Range Repair Services",
    "itemListElement": [
      {"@type":"Offer","itemOffered":{"@type":"Service","name":"American Range Pro Range Repair"}},
      {"@type":"Offer","itemOffered":{"@type":"Service","name":"American Range Innovection Convection Service"}},
      {"@type":"Offer","itemOffered":{"@type":"Service","name":"American Range Open Burner Service"}},
      {"@type":"Offer","itemOffered":{"@type":"Service","name":"American Range Stock Pot Repair"}},
      {"@type":"Offer","itemOffered":{"@type":"Service","name":"American Range Wall Oven Repair"}},
      {"@type":"Offer","itemOffered":{"@type":"Service","name":"American Range Warming Drawer Repair"}}
    ]
  }
}
</script>

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "How much does American Range appliance repair cost in Los Angeles?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Most American Range repairs run $175–$560. Common fixes like an igniter, temperature sensor, convection fan, or burner port service are on the lower end. Control board, gas valve, or Innovection® element replacement runs higher. Diagnostic fee is $89, waived when you proceed. Written flat-rate estimate before work begins. Parts sourced through American Range's Chatsworth facility."
      }
    },
    {
      "@type": "Question",
      "name": "Where is American Range made?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "American Range is manufactured in Chatsworth, in the western San Fernando Valley — part of Los Angeles. The company was founded by the Demirjian family and has been producing professional-grade cooking equipment in LA since the 1970s. American Range is one of the very few major professional range brands manufactured in the United States, and the only one made in Los Angeles itself."
      }
    },
    {
      "@type": "Question",
      "name": "What is American Range's Innovection® Convection?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Innovection® is American Range's patented convection system — a ring-shaped heating element surrounding the convection fan that delivers heat from a 360-degree source around the fan rather than from a single element elsewhere in the oven. The result is more even heat distribution than standard convection and faster preheat. When the Innovection® system underperforms — uneven cooking, slow preheat — we test the ring element and convection fan independently, since either component can fail without the other."
      }
    },
    {
      "@type": "Question",
      "name": "Can you service American Range commercial equipment in a home kitchen?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes. American Range builds both commercial and residential equipment, and some homeowners have commercial American Range units in their home kitchens. The service protocols are the same — we service both residential pro-style ranges and commercial American Range equipment including stock pot burners, wok ranges, and heavy-duty rangetops."
      }
    },
    {
      "@type": "Question",
      "name": "What are the most common American Range failures in Los Angeles?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The most common American Range calls we receive in LA are: open burner port blockage from LA cooking oil + hard water deposits (produces weak or yellow flame); igniter failure, especially at coastal properties from salt air corrosion; Innovection® ring element degradation causing uneven oven results; and continuous cast iron grate wear at the wok ring position from high-heat wok cooking. Gas valve and control board failures are less common but occur on older units."
      }
    }
  ]
}
</script>

<style>
  :root {
    --red: #C8102E;
    --black: #0a0a0a;
    --gray: #f5f5f5;
    --border: #e2e2e2;
    --text: #1a1a1a;
    --muted: #6b6b6b;
  }
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body { font-family: 'Barlow', 'Inter', system-ui, sans-serif; color: var(--text); }

  .top-bar { background: var(--red); padding: 8px 24px; display: flex; justify-content: space-between; align-items: center; font-size: 13px; color: #fff; }
  .top-bar a { color: #fff; text-decoration: none; font-weight: 700; }

  .hero { background: var(--black); padding: 72px 24px 64px; color: #fff; }
  .hero-inner { max-width: 1100px; margin: 0 auto; display: grid; grid-template-columns: 1fr 420px; gap: 48px; align-items: center; }
  .hero-eyebrow { font-size: 11px; font-weight: 700; letter-spacing: 0.15em; text-transform: uppercase; color: var(--red); margin-bottom: 16px; }
  .hero-title { font-size: clamp(32px, 5vw, 52px); font-weight: 900; line-height: 1.05; text-transform: uppercase; letter-spacing: -0.02em; margin-bottom: 20px; }
  .hero-title span { color: var(--red); }
  .hero-sub { font-size: 17px; line-height: 1.6; color: #aaa; margin-bottom: 32px; max-width: 540px; }
  .hero-cta-group { display: flex; gap: 16px; flex-wrap: wrap; }
  .btn-primary { display: inline-block; background: var(--red); color: #fff; padding: 14px 28px; font-size: 15px; font-weight: 700; text-decoration: none; letter-spacing: 0.04em; text-transform: uppercase; }
  .btn-secondary { display: inline-block; border: 1px solid #555; color: #ccc; padding: 14px 28px; font-size: 15px; font-weight: 600; text-decoration: none; letter-spacing: 0.04em; text-transform: uppercase; }
  .hero-badge-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
  .hero-badge { background: #161616; border: 1px solid #2a2a2a; padding: 16px 18px; }
  .badge-num { font-size: 22px; font-weight: 900; color: var(--red); line-height: 1; margin-bottom: 4px; }
  .badge-label { font-size: 12px; color: #888; text-transform: uppercase; letter-spacing: 0.08em; }

  .trust-bar { background: var(--red); padding: 14px 24px; }
  .trust-bar-inner { max-width: 1100px; margin: 0 auto; display: flex; justify-content: space-between; flex-wrap: wrap; gap: 8px; }
  .trust-item { color: #fff; font-size: 13px; font-weight: 600; letter-spacing: 0.04em; text-transform: uppercase; }
  .trust-item::before { content: "✓ "; }

  .section { padding: 64px 24px; }
  .section-gray { background: var(--gray); }
  .section-black { background: var(--black); color: #fff; }
  .section-inner { max-width: 1100px; margin: 0 auto; }
  .section-num { font-size: 11px; font-weight: 700; letter-spacing: 0.15em; text-transform: uppercase; color: var(--red); margin-bottom: 8px; }
  .section-title { font-size: clamp(24px, 3.5vw, 36px); font-weight: 900; text-transform: uppercase; letter-spacing: -0.01em; margin-bottom: 20px; }
  .section-black .section-title { color: #fff; }
  .section-lead { font-size: 17px; line-height: 1.7; color: var(--muted); max-width: 760px; margin-bottom: 40px; }
  .section-black .section-lead { color: #999; }

  .products-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1px; background: #2a2a2a; border: 1px solid #2a2a2a; margin-top: 28px; }
  .product-card { background: #161616; padding: 20px 18px; }
  .product-badge { font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; color: var(--red); margin-bottom: 8px; }
  .product-name { font-size: 15px; font-weight: 900; text-transform: uppercase; color: #fff; margin-bottom: 8px; }
  .product-desc { font-size: 12px; color: #666; line-height: 1.6; }

  .tip-block { border-left: 3px solid var(--red); background: #fff8f8; padding: 18px 20px; margin: 32px 0; max-width: 760px; }
  .tip-label { font-size: 10px; font-weight: 800; text-transform: uppercase; letter-spacing: 0.15em; color: var(--red); margin-bottom: 6px; }
  .tip-text { font-size: 14px; line-height: 1.65; color: var(--text); }
  .tip-local { border-color: #2a7a4a; background: #f0fff5; }
  .tip-local .tip-label { color: #2a7a4a; }
  .tip-convection { border-color: #c8820a; background: #fff8f0; }
  .tip-convection .tip-label { color: #c8820a; }

  .services-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 1px; background: var(--border); border: 1px solid var(--border); }
  .service-card { background: #fff; padding: 28px 24px; }
  .service-icon { font-size: 28px; margin-bottom: 12px; }
  .service-name { font-size: 16px; font-weight: 800; text-transform: uppercase; letter-spacing: 0.04em; margin-bottom: 10px; color: var(--text); }
  .service-desc { font-size: 14px; line-height: 1.65; color: var(--muted); margin-bottom: 12px; }
  .service-issues { font-size: 12px; color: var(--red); font-weight: 600; text-transform: uppercase; letter-spacing: 0.06em; }

  .features-2col { display: grid; grid-template-columns: 1fr 1fr; gap: 48px; align-items: start; }
  .features-list { list-style: none; }
  .features-list li { padding: 14px 0; border-bottom: 1px solid #2a2a2a; font-size: 15px; color: #ccc; display: flex; gap: 12px; }
  .features-list li::before { content: "→"; color: var(--red); flex-shrink: 0; }

  .problems-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(260px, 1fr)); gap: 16px; margin-top: 32px; }
  .problem-card { border: 1px solid var(--border); background: #fff; padding: 20px; }
  .problem-title { font-size: 14px; font-weight: 800; text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 8px; color: var(--text); }
  .problem-cause { font-size: 13px; color: var(--muted); line-height: 1.6; margin-bottom: 10px; }
  .problem-tag { display: inline-block; font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; padding: 3px 8px; color: #fff; }
  .tag-burner { background: #c8820a; }
  .tag-convection { background: #2a5ea5; }
  .tag-common { background: var(--red); }
  .tag-coastal { background: #2a7a4a; }

  .pricing-table { width: 100%; border-collapse: collapse; margin-top: 24px; }
  .pricing-table th { background: var(--text); color: #fff; text-align: left; padding: 12px 16px; font-size: 12px; text-transform: uppercase; letter-spacing: 0.08em; }
  .pricing-table td { padding: 14px 16px; border-bottom: 1px solid var(--border); font-size: 14px; }
  .pricing-table tr:last-child td { border-bottom: none; }
  .pricing-table tr:nth-child(even) td { background: var(--gray); }
  .price-range { font-weight: 700; color: var(--red); }

  .why-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: 24px; margin-top: 32px; }
  .why-card { border-left: 3px solid var(--red); padding: 20px; background: #fff; }
  .why-icon { font-size: 24px; margin-bottom: 10px; }
  .why-title { font-size: 14px; font-weight: 800; text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 8px; }
  .why-desc { font-size: 13px; color: var(--muted); line-height: 1.6; }

  .reviews-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 20px; margin-top: 32px; }
  .review-card { background: #fff; border: 1px solid var(--border); padding: 24px; }
  .review-stars { color: var(--red); font-size: 18px; margin-bottom: 10px; }
  .review-text { font-size: 14px; line-height: 1.7; color: var(--text); margin-bottom: 14px; }
  .review-author { font-size: 12px; font-weight: 700; text-transform: uppercase; color: var(--muted); }

  .repairs-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 1px; background: var(--border); border: 1px solid var(--border); margin-top: 32px; }
  .repair-item { background: #fff; padding: 24px; }
  .repair-appliance { font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; color: var(--red); margin-bottom: 6px; }
  .repair-issue { font-size: 15px; font-weight: 800; color: var(--text); margin-bottom: 8px; }
  .repair-detail { font-size: 13px; color: var(--muted); line-height: 1.6; }
  .repair-meta { margin-top: 12px; font-size: 12px; font-weight: 600; color: #aaa; text-transform: uppercase; letter-spacing: 0.06em; }

  .faq-list { margin-top: 32px; }
  .faq-item { border-bottom: 1px solid var(--border); padding: 20px 0; }
  .faq-q { font-size: 16px; font-weight: 800; color: var(--text); margin-bottom: 10px; }
  .faq-a { font-size: 14px; line-height: 1.7; color: var(--muted); max-width: 760px; }

  .nearby-grid { display: flex; flex-wrap: wrap; gap: 8px; margin-top: 20px; }
  .nearby-chip { background: var(--gray); border: 1px solid var(--border); padding: 8px 14px; font-size: 13px; color: var(--muted); text-decoration: none; font-weight: 600; }
  .nearby-chip:hover { border-color: var(--red); color: var(--red); }

  .bottom-cta { background: var(--black); padding: 72px 24px; text-align: center; color: #fff; }
  .bottom-cta-title { font-size: clamp(28px, 4vw, 44px); font-weight: 900; text-transform: uppercase; letter-spacing: -0.01em; margin-bottom: 12px; }
  .bottom-cta-title span { color: var(--red); }
  .bottom-cta-sub { font-size: 17px; color: #888; margin-bottom: 32px; }
  .cta-phone-large { display: inline-block; font-size: clamp(28px, 4vw, 42px); font-weight: 900; color: #fff; text-decoration: none; letter-spacing: -0.01em; margin-bottom: 24px; border-bottom: 2px solid var(--red); padding-bottom: 4px; }

  @media (max-width: 768px) {
    .hero-inner { grid-template-columns: 1fr; }
    .hero-badge-grid { grid-template-columns: 1fr 1fr; }
    .features-2col { grid-template-columns: 1fr; }
    .products-grid { grid-template-columns: 1fr; }
    .trust-bar-inner { flex-direction: column; gap: 6px; }
  }
</style>

<div class="top-bar">
  <span>Mon–Sat 8am–8pm · Los Angeles &amp; Southern California</span>
  <a href={`tel:${phoneRaw}`}>{phone}</a>
</div>

<section class="hero">
  <div class="hero-inner">
    <div>
      <div class="hero-eyebrow">American Range Repair — Los Angeles</div>
      <h1 class="hero-title">
        American Range Repair.<br/>
        <span>Made in LA.</span><br/>
        Chatsworth, California.
      </h1>
      <p class="hero-sub">
        American Range is manufactured in Chatsworth, in the western San Fernando Valley — making it the only major professional range brand built right here in Los Angeles. The open burners, the Innovection® Convection ring element, the continuous cast iron grates. Commercial heritage from LA's restaurant industry, brought home. We know this range.
      </p>
      <div class="hero-cta-group">
        <a href={`tel:${phoneRaw}`} class="btn-primary">Call {phone}</a>
        <a href="/book/" class="btn-secondary">Book Online</a>
      </div>
    </div>
    <div class="hero-badge-grid">
      <div class="hero-badge">
        <div class="badge-num">Same</div>
        <div class="badge-label">Day Service</div>
      </div>
      <div class="hero-badge">
        <div class="badge-num">OEM</div>
        <div class="badge-label">American Range Parts</div>
      </div>
      <div class="hero-badge">
        <div class="badge-num">90-Day</div>
        <div class="badge-label">Warranty</div>
      </div>
      <div class="hero-badge">
        <div class="badge-num">$89</div>
        <div class="badge-label">Diagnostic Fee</div>
      </div>
    </div>
  </div>
</section>

<div class="trust-bar">
  <div class="trust-bar-inner">
    <span class="trust-item">Licensed &amp; Insured · CSLB #1138898</span>
    <span class="trust-item">Innovection® Convection Service</span>
    <span class="trust-item">Open Burner Port Specialists</span>
    <span class="trust-item">Stock Pot &amp; Wok Range Service</span>
    <span class="trust-item">Flat-Rate Written Estimate</span>
  </div>
</div>

<section class="section">
  <div class="section-inner">
    <div class="section-num">01 — About American Range</div>
    <h2 class="section-title">Made in Chatsworth, Los Angeles. Commercial Heritage Since the 1970s.</h2>
    <p class="section-lead">
      American Range is manufactured in Chatsworth — a neighborhood in the western San Fernando Valley that is, geographically and technically, part of Los Angeles. The company was founded by the Demirjian family and has been producing professional-grade cooking equipment in LA since the 1970s, starting with commercial ranges for the restaurant industry before expanding into the residential pro-style market.
    </p>
    <p class="section-lead">
      This makes American Range something genuinely unusual in the professional range market: a major brand whose manufacturing is in the same metropolitan area as most of its LA customers. Parts come from Chatsworth. The engineering team is in Chatsworth. When you need service, you're dealing with a company whose physical operation is across the Valley. For LA homeowners, that means faster parts access and a closer relationship between the range and the service infrastructure than any imported European brand can offer.
    </p>

    <div class="products-grid">
      <div class="product-card">
        <div class="product-badge">Flagship · Made in LA</div>
        <div class="product-name">Pro-Style Freestanding Range</div>
        <div class="product-desc">American Range's signature product — open burner gas ranges in 30", 36", and 48" configurations with the commercial-kitchen open burner system, continuous cast iron grates, and Innovection® Convection oven. Available in gas and dual-fuel. The range that LA restaurants and LA home kitchens both use.</div>
      </div>
      <div class="product-card">
        <div class="product-badge">Commercial-Grade Specialty</div>
        <div class="product-name">Stock Pot &amp; Wok Ranges</div>
        <div class="product-desc">High-output specialty burner configurations designed for stock pot cooking and wok cooking — enormous BTU output (up to 35,000 BTU) at the dedicated burner position. Popular in LA's Asian-cuisine home kitchen market and serious cooking households. The wok ring and stock pot burner require dedicated service protocol.</div>
      </div>
      <div class="product-card">
        <div class="product-badge">Built-In</div>
        <div class="product-name">Rangetops &amp; Wall Ovens</div>
        <div class="product-desc">American Range's built-in configurations — rangetops for custom kitchen installations, and Innovection® wall ovens as standalone or paired units. The wall oven's Infrared Broil and Innovection® Convection Bake modes are the most service-relevant features. Available in coordinating finishes with the freestanding range line.</div>
      </div>
    </div>

    <div class="tip-block tip-local" style="margin-top:32px">
      <div class="tip-label">🏭 Made in Chatsworth — What It Means for LA Service</div>
      <div class="tip-text">American Range's Chatsworth manufacturing facility (818-897-0808) is the parts and service hub for the brand. For LA owners, this means a fundamentally different parts availability situation compared to European-made ranges: OEM American Range parts can often reach the technician within 24–48 hours rather than the 1–3 weeks typical for imported range parts. Standard American Range components — igniters, burner valves, oven thermostats, convection elements — are typically in stock at the Chatsworth facility. For the service company, being across the Valley from the manufacturer is a genuine advantage that translates to faster same-day and next-day completions.</div>
    </div>
  </div>
</section>

<section class="section section-gray">
  <div class="section-inner">
    <div class="section-num">02 — Services</div>
    <h2 class="section-title">Every American Range Appliance We Service</h2>
    <p class="section-lead">All American Range models — freestanding ranges, rangetops, wall ovens, stock pot and wok burners, warming drawers. Same-day across Los Angeles County.</p>

    <div class="services-grid">
      <div class="service-card">
        <div class="service-icon">🔥</div>
        <div class="service-name">Open Burner Service</div>
        <div class="service-desc">American Range uses open burner design — the same fundamental architecture as BlueStar, where each burner is an exposed star-cap assembly rather than a sealed burner. Open burners deliver more BTU output and a distinct flame character, but require specific maintenance: the individual star ports must be cleared to maintain flame quality. In LA's cooking environment, the combination of high-heat wok and stir-fry cooking oil, LA hard water (250–400 ppm), and ambient particulate creates a specific port-blocking compound. We clean and inspect all open burner star-cap ports on every American Range burner call.</div>
        <div class="service-issues">Common: weak flame · yellow flame tips · port blockage · igniter failure · gas valve · coastal salt air corrosion on igniters · burner cap wear · wok ring high-BTU service</div>
      </div>

      <div class="service-card">
        <div class="service-icon">🌀</div>
        <div class="service-name">Innovection® Convection Service</div>
        <div class="service-desc">American Range's patented Innovection® system uses a ring-shaped heating element surrounding the convection fan — delivering 360-degree heat input to the fan rather than a single element elsewhere in the oven. This produces more even results than standard rear-element convection and faster preheat. When Innovection® performance degrades — uneven oven results, slow preheat — we test the ring element and convection fan independently. The ring element is a distinct failure component from the main bake and broil elements and must be tested specifically.</div>
        <div class="service-issues">Common: ring element degradation · convection fan · uneven oven results · slow preheat · element test before fan replacement · Innovection® Bake mode fault · temperature sensor</div>
      </div>

      <div class="service-card">
        <div class="service-icon">🥘</div>
        <div class="service-name">Stock Pot &amp; Wok Burner Service</div>
        <div class="service-desc">American Range's high-output specialty burners — stock pot configurations up to 35,000 BTU and wok ring positions — require specific service awareness. The extreme BTU output places higher thermal stress on the gas valve and thermocouple components at those positions versus standard burners. We service high-output burner positions with awareness of their operating envelope and inspect the gas valve and thermocouple at the stock pot and wok ring positions on every service call involving those burners.</div>
        <div class="service-issues">Common: stock pot burner not reaching full output · wok ring flame inconsistency · high-BTU gas valve · thermocouple at high-output position · port blockage at large-orifice burner · gas pressure assessment</div>
      </div>

      <div class="service-card">
        <div class="service-icon">🌡️</div>
        <div class="service-name">Wall Oven &amp; Rangetop Service</div>
        <div class="service-desc">American Range wall ovens — single and double configurations with Innovection® Convection Bake, Standard Bake, Infrared Broil, and Fan modes. The Infrared Broil element is a distinct failure component from the standard bake element — it operates at much higher surface temperature and has a different failure mode and lifespan. Rangetop service uses the same open burner protocol as the freestanding range. Control boards on American Range wall ovens follow conventional diagnostic approach with Chatsworth parts availability.</div>
        <div class="service-issues">Common: Infrared Broil element · Innovection® ring element · temperature sensor · convection fan · control board · door gasket · Standard Bake element · dual oven independent circuit</div>
      </div>

      <div class="service-card">
        <div class="service-icon">🔆</div>
        <div class="service-name">Warming Drawer Service</div>
        <div class="service-desc">American Range warming drawers — four heating zones with a 70°F to 190°F temperature range and rapid heat-up (reaching 140°F in 4 minutes per American Range spec). The warming drawer thermostat, drawer heating elements, and temperature control are the service focus. Warming drawer failures are typically heating element or thermostat — we test both before ordering parts. The preset temperature feature (programmable drawer setpoints) operates through the control board.</div>
        <div class="service-issues">Common: not heating · temperature inconsistency · heating element · thermostat · preset control · drawer glide · control board</div>
      </div>

      <div class="service-card">
        <div class="service-icon">🔧</div>
        <div class="service-name">Continuous Grate Service</div>
        <div class="service-desc">American Range's continuous cast iron grates cover the entire cooktop surface without gaps — allowing pots to slide from burner to burner without lifting. The continuous grate system creates a specific cooking benefit and a specific maintenance consideration: LA cooking oil and wok cooking residue accumulates in the continuous grate surface and can eventually affect burner performance if not cleaned regularly. We inspect continuous grate condition on every burner call and advise on cast iron grate maintenance for LA cooking styles.</div>
        <div class="service-issues">Continuous grate inspection · cast iron seasoning assessment · grate support foot wear · wok ring position grate condition · LA cooking oil accumulation service</div>
      </div>
    </div>

    <div class="tip-block tip-convection" style="margin-top:32px">
      <div class="tip-label">🌀 Innovection® Ring Element — The Diagnostic That Gets Missed</div>
      <div class="tip-text">Most technicians unfamiliar with American Range diagnose "uneven convection" by testing the convection fan. On an American Range with Innovection®, this misses the actual failure point. The ring element surrounding the fan delivers heat to the fan — if the ring element is degrading (not failed, but running at partial output), the fan circulates air that isn't as hot as it should be across the full 360-degree ring. The result: uneven oven results where one side of the oven is cooler than the other, and baking results that improve with additional time but never quite achieve the evenness they should. We test the ring element's output specifically before any convection fan assessment. A partially degraded ring element produces an intermediate symptom that looks like a fan problem until you measure element output.</div>
    </div>
  </div>
</section>

<section class="section section-black">
  <div class="section-inner">
    <div class="section-num">03 — Technology</div>
    <h2 class="section-title">American Range Engineering — What Sets It Apart</h2>
    <p class="section-lead">American Range's commercial heritage and Chatsworth manufacturing create specific engineering choices that distinguish it from European pro ranges and mass-market domestics alike.</p>

    <div class="features-2col">
      <ul class="features-list">
        <li><strong>Open Burner Architecture</strong> — Like BlueStar and FiveStar, American Range uses exposed open burners rather than sealed burner design. The star-cap ports deliver gas to an open flame with higher BTU ceiling than sealed burners allow. Star-cap port maintenance is the primary open burner care requirement: the individual ports can accumulate oil and debris that restricts gas flow and shifts flame character from clean blue to yellow-tipped. We clear all star-cap ports on every American Range burner call.</li>
        <li><strong>Innovection® Ring Element</strong> — American Range's patented convection approach: a ring-shaped heating element encircles the convection fan, delivering heat input from 360 degrees around the fan rather than from a single element at the oven rear. This is different from standard rear-element convection and from La Cornue's vaulted oven natural convection. The ring element is a distinct component with its own failure mode — partial degradation produces intermediate symptoms before complete failure.</li>
        <li><strong>Infrared Broil Element</strong> — American Range wall ovens include an Infrared Broil mode using a high-intensity infrared element that reaches higher surface temperatures than a standard broil element. Infrared elements have a different failure mode from standard elements — they tend to fail more abruptly rather than degrading gradually. When infrared broil stops working while standard bake functions normally, the infrared element is the specific diagnostic point.</li>
        <li><strong>Commercial-Grade Burner Output</strong> — American Range's open burners are rated at outputs typical of commercial kitchen equipment — 15,000 to 25,000 BTU per standard burner, with stock pot configurations reaching 35,000 BTU. This output level places different stress on gas valve and thermocouple components than residential-rated European burners. We service high-output burner positions with awareness of their thermal operating envelope.</li>
        <li><strong>Continuous Cast Iron Grates</strong> — Spanning the full cooktop width without gaps, American Range's continuous grates enable the commercial kitchen practice of sliding pots from burner to burner. LA's wok and high-heat cooking style means these grates accumulate more oil and food residue than a suburban family's gas range. We inspect grate condition and the burner cap positions beneath during every American Range service call.</li>
        <li><strong>Chatsworth Parts Infrastructure</strong> — All American Range parts and service support originates at the Chatsworth facility at (818) 897-0808. For LA technicians and owners, this means parts availability that's fundamentally better than any imported brand: same-day or next-day for most stock components, compared to the 1–3 weeks typical for European range parts. We use this proximity advantage actively — calling Chatsworth before any job where we anticipate parts needs.</li>
      </ul>
      <div>
        <div class="tip-block" style="background:#0a0f0a; border-color:#2a7a4a; margin-top:0">
          <div class="tip-label" style="color:#5abf5a">🍜 LA Cooking Culture + American Range</div>
          <div class="tip-text" style="color:#bbb">LA's cooking culture is uniquely well-matched to American Range's commercial heritage. The city's deep connection to Chinese, Korean, Thai, and Vietnamese cooking creates significant demand for wok-capable ranges in residential kitchens. American Range's high-BTU open burner and available wok ring are exactly what LA's serious home cooks want. LA's restaurant industry — one of the densest in the country — already uses American Range commercial equipment. When a chef-owner or serious home cook in Koreatown, Silver Lake, or Monterey Park wants commercial-grade wok capability at home, American Range is often their first choice. We service both the commercial units in restaurants and the pro-style units in homes.</div>
