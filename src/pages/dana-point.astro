  <section class="city-repairs"><div class="city-repairs-inner"><div class="section-number">03</div><h2>Recent Repairs in Dana Point</h2><div class="repairs-grid">{recentRepairs.map(r => (<div class="repair-card"><h3 class="repair-title">"{r.title}"</h3><div class="repair-location">&#128205; {r.neighborhood}</div><p class="repair-detail">{r.detail}</p><div class="repair-meta"><span class="repair-part">Part: {r.part}</span><span class="repair-time">&#9201; {r.time}</span></div></div>))}</div></div></section>

  <section class="city-why">
    <div class="city-why-inner">
      <div class="section-number">04</div>
      <h2>Why Dana Point Homeowners Call Us</h2>
