  <section class="city-nearby"><div class="city-nearby-inner"><h2>Also Serving Nearby South OC Cities</h2><div class="nearby-grid">{nearbyAreas.map(a => (<a href={`/${a.slug}/`} class="nearby-link">Appliance Repair {a.name} &rarr;</a>))}</div></div></section>

  <section class="city-bottom-cta"><div class="city-bottom-cta-inner"><h2>Schedule Your Dana Point Repair Today</h2><p>Same-day service across all of Dana Point. Sub-Zero, Wolf, Miele, and all major brands.</p><div class="bottom-cta-btns"><a href={`tel:${phoneRaw}`} class="btn-primary-xl">Call {phone}</a><a href="/book/" class="btn-secondary-xl">Book Online</a></div><p class="bottom-note">$89 diagnostic &middot; 90-day warranty &middot; OEM parts &middot; Dana Point, CA</p></div></section>

  <CTA phone={phone} branch={branch} zones={["Dana Point", "Monarch Beach", "Orange County"]} />
</Layout>
