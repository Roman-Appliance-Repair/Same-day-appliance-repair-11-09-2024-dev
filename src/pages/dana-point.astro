  { name: "Laguna Niguel", slug: "laguna-niguel" },
  { name: "Mission Viejo", slug: "mission-viejo" },
  { name: "San Clemente", slug: "san-clemente" },
  { name: "Newport Beach", slug: "newport-beach" },
];

const schemaJSON = JSON.stringify({
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "HomeAndConstructionBusiness",
      "name": "Same Day Appliance Repair — Dana Point",
      "telephone": phoneRaw,
      "email": email,
      "url": "https://samedayappliance.repair/dana-point/",
      "areaServed": [{ "@type": "City", "name": "Dana Point" }, { "@type": "Place", "name": "Monarch Beach" }],
      "openingHoursSpecification": [
        { "@type": "OpeningHoursSpecification", "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday"], "opens": "07:00", "closes": "21:00" },
        { "@type": "OpeningHoursSpecification", "dayOfWeek": "Saturday", "opens": "08:00", "closes": "19:00" },
        { "@type": "OpeningHoursSpecification", "dayOfWeek": "Sunday", "opens": "09:00", "closes": "17:00" }
      ],
      "priceRange": "$$",
      "aggregateRating": { "@type": "AggregateRating", "ratingValue": "4.9", "reviewCount": "52", "bestRating": "5" },
      "license": "CA CSLB #1138898"
    },
    {
      "@type": "FAQPage",
      "mainEntity": faqs.map(f => ({ "@type": "Question", "name": f.q, "acceptedAnswer": { "@type": "Answer", "text": f.a } }))
    }
  ]
});
---

<Layout title={metaTitle} description={metaDesc}>
  <script type="application/ld+json" set:html={schemaJSON}></script>

  <section class="city-hero">
    <div class="city-hero-inner">
      <div class="city-hero-text">
        <div class="city-eyebrow">Dana Point, CA &middot; Orange County &middot; 92624 &middot; 92629</div>
        <h1>Appliance Repair in Dana Point, CA</h1>
        <p class="city-hero-sub">Same-day service in Monarch Beach, Capistrano Beach, Niguel Shores, and across Dana Point. Salt-air coastal expertise. Sub-Zero, Wolf, Miele &amp; all brands. 90-day warranty.</p>
        <div class="city-hero-ctas">
          <a href={`tel:${phoneRaw}`} class="btn-primary">Call {phone}</a>
          <a href="/book/" class="btn-secondary">Book Online</a>
        </div>
        <div class="city-trust-row"><span>&#9733; 4.9 Google Rating</span><span>&#10003; Licensed &amp; Insured</span><span>&#10003; CA CSLB #1138898</span></div>
      </div>
      <div class="city-hero-img">
        <img src="/images/areas/dana-point/appliance-repair-dana-point-ca.webp" alt="Appliance repair technician in Dana Point CA" width="560" height="420" loading="eager" />
      </div>
    </div>
  </section>

  <section class="trust-bar"><div class="trust-bar-inner"><div class="trust-item"><span>&#9889; Same-Day Service</span></div><div class="trust-item"><span>&#128295; OEM Parts</span></div><div class="trust-item"><span>&#128737; 90-Day Warranty</span></div><div class="trust-item"><span>&#9989; Licensed &amp; Insured</span></div><div class="trust-item"><span>&#127941; BBB Accredited</span></div></div></section>

  <section class="city-intro">
    <div class="city-intro-inner">
      <div class="city-intro-content">
        <h2>Appliance Repair in Dana Point &mdash; The Coastal Reality</h2>
        <p>Dana Point is one of the most beautiful places on the Southern California coast and one of the most demanding environments for appliances. The combination of harbor salt air and direct Pacific exposure means that appliance components corrode faster here than almost anywhere else in Orange County. Our technicians see this on every visit to Monarch Beach, the Headlands, and the harbor-adjacent neighborhoods &mdash; packed condenser coils, corroded igniter electrodes, seized fan motors.</p>
        <p>The city also has a significant second-home and vacation rental market. If you're a property manager or manage your own Dana Point rental, you know how quickly a malfunctioning appliance becomes an emergency. We prioritize those calls and we're available seven days a week for exactly that reason.</p>
        <p>The housing stock ranges from modest Lantern District homes to waterfront estates at Monarch Beach and Ritz Cove &mdash; Sub-Zero, Wolf, Thermador, and Miele on the high end, Samsung and LG in the mid-range. We're stocked for both. Diagnostic fee is $89, credited toward the repair. Call <a href={`tel:${phoneRaw}`}>{phone}</a> &mdash; someone real picks up.</p>
      </div>
      <aside class="city-sidebar"><div class="city-sidebar-inner"><p class="sidebar-city-label">Dana Point Service</p><a href={`tel:${phoneRaw}`} class="btn-primary-lg">{phone}</a><p class="sidebar-hours">Mon&ndash;Fri 7am&ndash;9pm &middot; Sat 8am&ndash;7pm &middot; Sun 9am&ndash;5pm</p><a href="/book/" class="btn-secondary-sm">Book Online</a><div class="sidebar-guarantee"><strong>$89 Diagnostic</strong><span>&mdash; credited if you repair</span></div></div></aside>
    </div>
  </section>

  <section class="city-services"><div class="city-services-inner"><h2>Appliance Repair Services in Dana Point</h2><div class="services-grid">{services.map(s => (<a href={`/${citySlug}/${s.slug}/`} class="service-card"><span class="service-icon" set:html={s.icon}></span><span class="service-name" set:html={s.name}></span><span class="service-cta">Dana Point &rarr;</span></a>))}</div></div></section>

  <section class="city-context">
    <div class="city-context-inner">
      <div class="section-number">01</div>
      <div class="city-context-content">
        <h2>What Salt Air Does to Dana Point Appliances</h2>
        <p>Dana Point Harbor is one of the most picturesque spots in Southern California. It's also one of the most corrosive environments for appliance components. Salt air from the harbor and the Pacific deposits fine, electrochemically active particulate on every metal surface it touches &mdash; condenser coils, fan motor bearings, burner electrodes, door gaskets, and electrical terminals.</p>
        <p>The practical consequence for Dana Point homeowners: refrigerators need condenser coil cleaning every 4-6 months, not 12. Wolf and Viking ranges in ocean-facing homes need electrode inspections annually. Sub-Zero units within a quarter mile of the harbor show coil fouling at rates we only otherwise see in Newport Beach and Laguna Beach.</p>
        <p>This isn't a scare tactic &mdash; it's what our technicians observe on actual service calls in Dana Point. The coils we clean in Monarch Beach look nothing like what we clean in Mission Viejo. The maintenance schedule is genuinely different, and we tell homeowners that honestly when we're on site.</p>
        <p>For vacation rental properties or second homes that sit empty for months, the problem compounds. An unoccupied home doesn't have anyone noticing that the refrigerator is running longer than usual. By the time the owners arrive, the coils may have been restricting airflow for six months. We're available year-round for seasonal property check-ups &mdash; call us if that's relevant to your situation.</p>
      </div>
    </div>
  </section>

