---
import Container from "@components/container.astro";
import Cta from "@components/cta.astro";
import Layout from "@layouts/Layout.astro";
import Navbar from "@components/navbar/navbar.astro";
import Reviews from "@components/reviews.astro";
import Btn from "@components/btn.astro";
import Anchor from "@components/anchor/anchor-areas-enhanced.astro";
import FaqSection from "@components/faq-section.astro";
import HowItWorks from "@components/how-it-works.astro";
import HighEndBrands from "@components/high-end-brands.astro";
import TechTips from "@components/tech-tips.astro";
import PricingTable from "@components/pricing-table.astro";
import "css/service-areas/style-service-areas.css";
import "css/service-areas/style-area-enhanced.css";

const title = "Appliance Repair Burbank CA — Same Day Service | (323) 870-4790";
const description = "Same day appliance repair in Burbank CA. Certified technicians, 85% first-visit fix rate, honest $65 diagnostics. Residential, high-end & commercial. Call (323) 870-4790.";

const faqItems = [
  {
    question: "How much does appliance repair cost in Burbank?",
    answer: "Our diagnostic fee is $65, which is waived if you approve the repair. The average repair cost is $320–$450 depending on the appliance type and parts needed. You receive a written estimate before any work begins — no hidden fees."
  },
  {
    question: "Do you offer same day service in Burbank?",
    answer: "Yes. We offer same day service 7 days a week, including weekends. In most cases our technician arrives within 1 hour of your call. Call (323) 870-4790 to schedule your appointment today."
  },
  {
    question: "Do you repair Sub-Zero, Viking and other high-end brands?",
    answer: "Yes. Our technicians are factory-trained on Sub-Zero, Viking, Wolf, Thermador, Miele, Bosch, Bertazzoni and other premium brands. We use OEM parts exclusively and follow manufacturer repair protocols."
  },
  {
    question: "Do you offer commercial appliance repair in Burbank?",
    answer: "Absolutely. We serve over 50 recurring commercial clients in Burbank — restaurants, hotels, laundromats and property management companies. We offer 24/7 emergency service for commercial equipment breakdowns."
  },
  {
    question: "What warranty do you offer on repairs?",
    answer: "We offer a three-tier warranty: 90 days on standard repairs, 6 months on repairs over $400 (major components like control boards and motors), and up to 1 year on compressor replacements. We use OEM parts only."
  }
];

const howItWorksSteps = [
  { number: 1, title: "Call or Book Online", description: "Reach us at (323) 870-4790 or use our online booking form. Tell us about the appliance, the issue and your preferred time." },
  { number: 2, title: "Same Day Dispatch", description: "We assign a certified technician from our nearest hub. You'll receive a confirmation with your tech's name and arrival window." },
  { number: 3, title: "On-Site Diagnostic", description: "Your technician inspects the appliance, runs electrical and mechanical tests, and pinpoints the root cause within 20–30 minutes." },
  { number: 4, title: "Transparent Estimate", description: "You get a written quote with itemized parts and labor — no hidden fees. The $65 diagnostic is waived if you approve the repair." },
  { number: 5, title: "Expert Repair", description: "Most repairs are completed on the first visit. Our vans carry 200+ common parts so there's no waiting for shipments." },
  { number: 6, title: "Quality Check & Cleanup", description: "After the repair we test the appliance through a full cycle, clean the work area and walk you through what was done." },
  { number: 7, title: "Warranty & Follow-Up", description: "You receive a detailed invoice with warranty terms. Our support team follows up within 48 hours to make sure everything is running smoothly." }
];

const highEndBrands = [
  { name: "Sub-Zero", description: "Built-in refrigerators, freezers and wine storage. We service all Sub-Zero cooling systems including dual-compressor models and air purification systems." },
  { name: "Viking", description: "Professional ranges, cooktops and refrigerators. Our technicians handle Viking's heavy-duty burner systems, convection ovens and Pro-Series units." },
  { name: "Wolf", description: "Dual-fuel ranges, induction cooktops and built-in ovens. We are experienced with Wolf's signature red knob models and their advanced convection technology." },
  { name: "Thermador", description: "Star Burner cooktops, steam ovens and column refrigerators. We repair Thermador's Freedom Hinge dishwashers and Masterpiece Series wall ovens." },
  { name: "Bertazzoni", description: "Italian-crafted ranges, cooktops and ventilation. We service Bertazzoni's Heritage and Professional series with attention to their precision thermostat systems." },
  { name: "Miele", description: "Dishwashers, washers, dryers and built-in coffee machines. We maintain Miele's AutoDos dispensing systems, TwinDos technology and heat-pump dryers." },
  { name: "Bosch", description: "Dishwashers, compact laundry and cooking appliances. We handle Bosch's 800 Series, Benchmark line and their whisper-quiet dishwasher motors." }
];

const techTips = [
  { title: "Clean Refrigerator Condenser Coils Every 6 Months", description: "Dust-caked coils force the compressor to work harder, increasing energy bills by up to 25% and shortening the unit's lifespan. Pull the fridge out, vacuum the coils with a brush attachment, and your fridge will cool more efficiently." },
  { title: "Don't Overload Your Washer", description: "Consistently overfilling the drum stresses the bearings, suspension springs and drive motor. Follow the manufacturer's load capacity and leave room for clothes to tumble freely." },
  { title: "Check Your Dryer Vent Annually", description: "Lint buildup in the exhaust vent is a leading cause of dryer fires. Disconnect the vent hose once a year and clean it out. If drying times have doubled, the vent is likely clogged." },
  { title: "Run an Empty Dishwasher Cycle with Vinegar Monthly", description: "Hard water deposits and grease film reduce cleaning performance. Place a cup of white vinegar on the top rack and run a hot cycle to dissolve mineral buildup and eliminate odors." },
  { title: "Know When to Repair vs. Replace", description: "As a rule of thumb: if an appliance is more than 75% through its expected lifespan and the repair costs over 50% of a replacement, it's usually better to replace. Your technician can help you calculate both options." }
];

const pricingRows = [
  { service: "Diagnostic / Service Call", price: "$65", description: "Complete inspection and written estimate. Fee waived with approved repair. If we can't diagnose the issue, the fee is refunded." },
  { service: "Average Repair Cost", price: "$320 – $450", description: "Parts and labor included. Covers most residential repairs: thermostats, igniters, belts, switches, door seals and similar components." },
  { service: "Major Repair (labor + parts)", price: "$450 – $650", description: "Compressors, control boards, motors, pumps and sealed-system work." },
  { service: "High-End / Commercial Repair", price: "Custom quote", description: "Sub-Zero, Viking, Wolf and commercial equipment. Price depends on brand, parts availability and complexity." }
];
---
<Layout title={title} description={description}>
  <Navbar />
  <Reviews />

  <!-- 1. HERO BANNER — full width background image -->
  <div class="hero-banner">
    <img
      class="hero-banner__bg"
      src="/images/burbank/sub-zero-refrigerator-repair-burbank.webp"
      alt="Same Day Appliance Repair technician servicing Sub-Zero refrigerator in Burbank home"
      width="1200"
      height="800"
      loading="eager"
    />
    <div class="hero-banner__overlay">
      <h1>Appliance Repair Burbank CA</h1>
      <p class="hero-banner__subtitle">Same Day Service &bull; Certified Technicians &bull; All Brands</p>
      <a href="tel:+13238704790" class="hero-banner__cta">(323) 870-4790</a>
    </div>
  </div>

  <Container>
    <div class="full-page">

      <!-- Facts bar -->
      <div class="hero-facts-bar">
        <div class="hero-fact">
          <p class="fact-value">60–90 min</p>
          <p class="fact-label">Avg. Response Time</p>
        </div>
        <div class="hero-fact">
          <p class="fact-value">85%</p>
          <p class="fact-label">First-Visit Fix Rate</p>
        </div>
        <div class="hero-fact">
          <p class="fact-value">$65</p>
          <p class="fact-label">Diagnostic Fee</p>
        </div>
        <div class="hero-fact">
          <p class="fact-value">4.9 &#9733;</p>
          <p class="fact-label">Google Rating</p>
        </div>
      </div>

      <Anchor />

      <p><b>Need appliance repair in Burbank, CA?</b> Same Day Appliance Repair is a family-owned, licensed company
        serving Burbank homeowners and businesses since 2022. Our certified technicians arrive the same day, diagnose
        accurately and fix the problem — usually on the first visit. We repair all major residential and commercial
        appliances from everyday brands to high-end European manufacturers.</p>
      <p>We are BBB-accredited, EPA-certified and OSHA-trained. Every repair comes with transparent pricing,
        no hidden fees and a written warranty. Whether it's a leaking dishwasher on a Tuesday afternoon or a
        commercial walk-in cooler emergency on a Saturday, we're here for Burbank.</p>


      <!-- 2. WHY BURBANK -->
      <div class="content-section">
        <h2>Why Burbank Trusts Same Day Appliance Repair</h2>
        <div class="why-choose-grid">
          <div class="why-choose-card">
            <h3>Same Day Service, Every Day</h3>
            <p>We schedule appointments Monday through Saturday, 8 AM – 8 PM. Call before noon and we'll typically be at your door by the afternoon — no extra charge for same day visits.</p>
          </div>
          <div class="why-choose-card">
            <h3>Honest $65 Diagnostics</h3>
            <p>No guesswork, no inflated quotes. Our diagnostic fee covers a thorough inspection and a written estimate. Approve the repair and the $65 is waived completely. If we can't diagnose the issue, we refund your diagnostic fee — guaranteed.</p>
          </div>
          <div class="why-choose-card">
            <h3>High-End Brand Expertise</h3>
            <p>Burbank homes feature Sub-Zero, Viking, Wolf and Thermador. Our techs are factory-trained on these brands and carry OEM-approved parts so your premium appliances stay in top condition.</p>
          </div>
          <div class="why-choose-card">
            <h3>Weekends & Flexible Scheduling</h3>
            <p>Saturday appointments at no extra cost. We also offer 2-hour arrival windows so you aren't stuck waiting all day. Our dispatchers send text updates with your tech's ETA.</p>
          </div>
        </div>
      </div>


      <!-- 3. RESIDENTIAL REPAIRS -->
      <div id="home-anchor" class="content-section">
        <h2>Home Appliance Repair Burbank CA</h2>
        <p>From kitchen appliances to laundry room units, our Burbank technicians handle every residential repair —
          refrigerators, washers, dryers, dishwashers, ovens, cooktops, microwaves, range hoods, fireplaces and
          barbecue grills. We carry 200+ parts in our service vans for fast on-site repairs.</p>

        <h2>Kitchen Appliance Repair Burbank CA</h2>
        <div class="section-photo">
          <img
            src="/images/burbank/refrigerator-compressor-repair-burbank.webp"
            alt="Certified technician diagnosing refrigerator compressor with multimeter in Burbank CA kitchen"
            width="700"
            height="700"
            loading="lazy"
          />
        </div>

        <h3>Refrigerator Repair Burbank CA</h3>
        <p>Burbank's warm climate pushes cooling systems hard. If your fridge has temperature swings, ice buildup,
          a noisy compressor or a water leak, our techs can diagnose and fix it — often within an hour. We carry
          compressors, thermostats, fan motors, defrost timers and control boards in our vans.</p>
        <p>We service Samsung, LG, Whirlpool, Frigidaire, GE, Maytag, KitchenAid, Amana and high-end brands
          like <a href="/brands/sub-zero-repair/">Sub-Zero</a>, <a href="/brands/viking-repair/">Viking</a>,
          Bosch and Thermador. Less common brands — Kenmore, Haier, Electrolux, Jenn-Air, Miele, Dacor,
          Fisher &amp; Paykel and Liebherr — are also in our wheelhouse.</p>
        <p><b>Important note for Samsung and LG owners:</b> Samsung and LG refrigerators manufactured in the last
          five years tend to develop sealed-system failures earlier than expected. If your Samsung fridge is making
          clicking sounds or running constantly, call us before the compressor fails completely — early diagnosis
          saves hundreds.</p>

        <h3>Dishwasher Repair Burbank CA</h3>
        <p>Leaking water, poor drainage, dishes coming out dirty or error codes on the display — we handle all
          dishwasher problems. Our technicians work with Bosch, Whirlpool, KitchenAid, Samsung, GE, LG, Miele,
          Thermador and Fisher &amp; Paykel. We also offer maintenance to prevent mineral buildup and flooding.</p>

        <h3>Oven, Range &amp; Cooktop Repair Burbank CA</h3>
        <p>Gas or electric, freestanding or built-in — our techs repair heating elements, thermostats, igniters,
          gas valves, control panels and convection fans. Safety is our priority: we test for gas leaks and verify
          proper grounding on every job. Brands include Wolf, Thermador, Viking, Bertazzoni, GE, Samsung and more.</p>

        <h2>Laundry Appliance Repair Burbank CA</h2>
        <div class="section-photo">
          <img
            src="/images/same-day-washing-machine-repair-service-loa-angeles-and-surrounding-areas.webp"
            alt="Professional washer and dryer repair service in Burbank CA residential laundry room"
            width="700"
            height="700"
            loading="lazy"
          />
        </div>

        <h3>Washer Repair Burbank CA</h3>
        <p>Water leaks, spin cycle failures, mold in the rubber seal or error codes — our techs handle it all.
          Burbank's humid days can accelerate mold growth in front-loaders; we bring specialized cleaners to remove
          mold and advise on ventilation. We replace drum bearings, drive motors, control boards, pumps and door locks.</p>
        <p>Brands: Samsung, LG, Whirlpool, Maytag, GE, KitchenAid, Miele, Bosch, Electrolux, Speed Queen and more.</p>

        <h3>Dryer Repair Burbank CA</h3>
        <p>Overheating, long drying times, unusual noises or a drum that won't spin — these are the most common
          dryer calls we get in Burbank. Every dryer repair includes a complimentary lint-path cleaning to reduce fire
          risk and improve efficiency. We service gas and electric models from Samsung, LG, Whirlpool, Maytag, GE,
          Miele, Bosch, Electrolux and Speed Queen.</p>

        <Btn />
      </div>


      <!-- 4. HIGH-END BRANDS -->
      <div id="high-end-anchor" class="content-section">
        <h2>High-End Appliance Repair Burbank CA</h2>
        <p>Burbank homes in the hillside neighborhoods and Magnolia Park area feature luxury appliances that require specialized knowledge. Our technicians are factory-trained, use OEM-approved parts, and follow manufacturer repair protocols. <a href="/brands/">View all brands we service</a>.</p>
        <div class="section-photo">
          <img
            src="/images/burbank/wolf-range-repair-burbank.webp"
            alt="Same Day Appliance Repair technician servicing Wolf dual-fuel range in upscale Burbank kitchen"
            width="700"
            height="700"
            loading="lazy"
          />
        </div>
        <HighEndBrands
          brands={highEndBrands}
          heading=""
        />
      </div>


      <!-- 5. COMMERCIAL -->
      <div id="commercial-anchor" class="content-section">
        <h2>Commercial Appliance Repair Burbank CA</h2>
        <p>Burbank's restaurants, studios, hotels and laundromats rely on commercial-grade equipment.
          When a walk-in cooler goes down at a restaurant on Magnolia Blvd or a commercial dryer fails at a
          laundromat on Victory, downtime costs real money. We offer same day commercial service to minimize
          losses and get your business running again.</p>

        <h2>Commercial Kitchen &amp; Laundry Equipment</h2>
        <div class="section-photo">
          <img
            src="/images/burbank/commercial-refrigerator-repair-burbank.webp"
            alt="Commercial refrigerator compressor repair in Burbank restaurant kitchen by certified technician"
            width="700"
            height="700"
            loading="lazy"
          />
        </div>
        <p>We repair commercial refrigerators, freezers, dishwashers, ovens, stoves, ice machines, walk-in coolers,
          walk-in freezers, showcase refrigerators, bar refrigerators, slushie machines, fryers and commercial laundry
          equipment. Brands include True, Turbo Air, Hoshizaki, Traulsen, Hobart, Vulcan, Speed Queen and many more.</p>
        <p><b>Real story from a Burbank restaurant client:</b> One of our Burbank restaurant clients called for a
          single refrigerator issue. Our technician inspected all kitchen equipment on his own initiative — found
          every condenser clogged with dust and two motors weeks from failure. We performed preventive maintenance
          on everything in a second visit, saving the restaurant thousands in emergency replacements. The restaurant
          never missed a day of service.</p>

        <Btn />
      </div>


      <!-- 6. HOW IT WORKS -->
      <div id="how-it-works-anchor" class="content-section">
        <div class="section-photo">
          <img
            src="/images/burbank/same-day-appliance-repair-service-van-burbank.webp"
