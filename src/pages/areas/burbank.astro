        <TechTips
          tips={techTips}
          heading="Technician Tips: Keep Your Appliances Running Longer"
          image="/images/burbank/condenser-coils-before-after-burbank.webp"
          imageAlt="Refrigerator condenser coils before and after professional cleaning in Burbank CA — dust removal improves efficiency"
        />
      </div>


      <!-- 8. PRICING TABLE -->
      <div id="pricing-anchor" class="content-section">
        <PricingTable
          rows={pricingRows}
          heading="Appliance Repair Pricing Burbank CA"
          subheading="Transparent pricing with no hidden fees. Diagnostic fee waived with approved repair."
          discounts="<b>Discounts:</b> 5% off for first-time customers | 15% off for returning customers. See our full <a href='/price-list/'>price list</a> for details.<br/><br/><b>Warranty:</b> 90-day warranty on standard repairs. 6-month warranty on repairs over $400. Up to 1-year warranty on compressor replacements. OEM parts only."
        />
      </div>


      <!-- 9. SERVICE AREA COVERAGE -->
      <div class="service-coverage content-section">
        <h2>Neighborhoods We Serve in Burbank</h2>
        <p style="text-align: center;">Our technicians cover every Burbank neighborhood and the surrounding areas.</p>
        <div class="neighborhoods-grid">
          <span>Magnolia Park</span>
          <span>Media District</span>
          <span>Rancho Equestrian</span>
          <span>Hillside District</span>
          <span>Downtown Burbank</span>
          <span>Riverside Rancho</span>
          <span>Warner Bros. Studios Area</span>
          <span>Chandler Bikeway Corridor</span>
          <span>Airport District</span>
          <span>Northwest Burbank</span>
          <span>Verdugo Woodlands</span>
          <span>Toluca Lake (nearby)</span>
          <span>North Hollywood (nearby)</span>
          <span>Glendale (nearby)</span>
          <span>Sun Valley (nearby)</span>
        </div>
      </div>


      <!-- 10. FAQ -->
      <div id="faq-anchor" class="content-section">
        <FaqSection faqs={faqItems} heading="Frequently Asked Questions — Burbank Appliance Repair" />
      </div>


      <!-- 11. CTA SCHEDULE -->
      <div class="cta-schedule">
        <h2>Schedule Your Burbank Appliance Repair Today</h2>
        <p>Call <a href="tel:+13238704790" style="color: #fff; text-decoration: underline; font-weight: 700;">(323) 870-4790</a> or book online — same day appointments available Monday through Saturday.</p>
        <ul class="cta-checklist">
          <li>Same day service, no extra charge</li>
          <li>$65 diagnostic — waived with repair</li>
          <li>Up to 1-year warranty on parts</li>
          <li>BBB-accredited, licensed &amp; insured</li>
          <li>Residential, high-end &amp; commercial</li>
        </ul>
      </div>

    </div>
  </Container>
  <Cta />

