---
import Layout from '../layouts/Layout.astro';

const title = "Lacanche Range Repair Los Angeles | Cluny, Sully & Chaussin Specialists";
const description = "Expert Lacanche range repair in Los Angeles. Cluny, Chaussin, Sully, Beaune — brass jet service, plancha, metric fasteners, open burner calibration. Art Culinaire parts. Same-day service. Call (626) 376-4458.";
const phone = "(626) 376-4458";
const phoneRaw = "6263764458";
---

<Layout title={title} description={description}>

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "HomeAndConstructionBusiness",
  "name": "Same Day Appliance Repair — Lacanche Specialist",
  "url": "https://samedayappliance.repair/brand-lacanche-appliance-repair/",
  "telephone": "+16263764458",
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Los Angeles",
    "addressRegion": "CA",
    "postalCode": "90001",
    "addressCountry": "US"
  },
  "areaServed": ["Los Angeles County", "Orange County", "Ventura County"],
  "priceRange": "$$",
  "openingHours": "Mo-Sa 08:00-20:00",
  "hasOfferCatalog": {
    "@type": "OfferCatalog",
    "name": "Lacanche Repair Services",
    "itemListElement": [
      {"@type":"Offer","itemOffered":{"@type":"Service","name":"Lacanche Cluny Range Repair"}},
      {"@type":"Offer","itemOffered":{"@type":"Service","name":"Lacanche Brass Jet Service"}},
      {"@type":"Offer","itemOffered":{"@type":"Service","name":"Lacanche Plancha Repair"}},
      {"@type":"Offer","itemOffered":{"@type":"Service","name":"Lacanche Open Burner Calibration"}},
      {"@type":"Offer","itemOffered":{"@type":"Service","name":"Lacanche Oven Temperature Service"}},
      {"@type":"Offer","itemOffered":{"@type":"Service","name":"Lacanche Sully & Chaussin Repair"}}
    ]
  }
}
</script>

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "How much does Lacanche range repair cost in Los Angeles?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Most Lacanche repairs run $195–$620. Brass jet cleaning, thermocouple service, door gasket, or oven temperature calibration is on the lower end. Plancha thermostat, control board, or oven element runs higher. Diagnostic fee is $89, waived when you proceed. Parts costs run approximately 15% higher than domestic brands due to French sourcing. Written flat-rate estimate before work begins."
      }
    },
    {
      "@type": "Question",
      "name": "Where is Lacanche made?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Lacanche ranges are made in Chagny, in the Burgundy region of France — a manufacturing operation with roots going back to 1796. The Chagny foundry has been producing cast iron cookware and ranges in the Burgundy tradition for over two centuries. Every Lacanche range is assembled by hand in Chagny and shipped through Art Culinaire, the US distributor based in California."
      }
    },
    {
      "@type": "Question",
      "name": "What are the most common Lacanche models in Los Angeles?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The most common Lacanche models we service in LA are the Cluny (90cm — the most popular configuration), Chaussin (100cm), Sully (180cm — the largest), and Beaune and Vougeot (90cm and 70cm single-oven models). All share the same Burgundy-made open burner system with brass jets, but differ in oven configuration, width, and optional features like plancha plates and warming cupboards."
      }
    },
    {
      "@type": "Question",
      "name": "Why do Lacanche brass jets block more in LA?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "LA's hard water (250–400 ppm) combined with the cooking oils used in LA cuisine creates a specific deposit pattern in Lacanche brass jets. Hard water mineral deposits combine with oil residue to form a harder blockage than either alone. Weekly brass jet cleaning is the recommended maintenance for LA-installed Lacanche ranges — more frequent than Lacanche's standard French-market interval, which assumes softer European water. Partially blocked brass jets produce the yellow-tipped flames that are the first visible sign of flow restriction."
      }
    },
    {
      "@type": "Question",
      "name": "How long does it take to get Lacanche parts?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Standard Lacanche parts — jets, thermocouples, gaskets, thermostats, igniters — typically arrive 8–10 weeks from Art Culinaire's US inventory (or sooner when in stock). Custom-color enamel doors, brass trim rails, and specialty panels sourced directly from the Chagny factory can take up to five months. We always verify Art Culinaire US stock before quoting timelines and will tell you honestly when a long lead time applies before beginning work."
      }
    },
    {
      "@type": "Question",
      "name": "Why do you need metric tools to service a Lacanche range?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Every fastener on a Lacanche range is metric — the French manufacturing standard. US standard SAE tools don't fit Lacanche fasteners correctly, which means a technician using US tools will strip bolts or damage panels trying to access the burner, oven, or thermostat components. We carry a full metric toolkit specifically for Lacanche and other European range service. Stripped Lacanche fasteners are one of the most frustrating damage patterns we encounter on ranges that were worked on by general technicians."
      }
    }
  ]
}
</script>

<style>
  :root {
    --red: #C8102E;
    --black: #0a0a0a;
    --gray: #f5f5f5;
    --border: #e2e2e2;
    --text: #1a1a1a;
    --muted: #6b6b6b;
  }
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body { font-family: 'Barlow', 'Inter', system-ui, sans-serif; color: var(--text); }

  .top-bar { background: var(--red); padding: 8px 24px; display: flex; justify-content: space-between; align-items: center; font-size: 13px; color: #fff; }
  .top-bar a { color: #fff; text-decoration: none; font-weight: 700; }

  .hero { background: var(--black); padding: 72px 24px 64px; color: #fff; }
  .hero-inner { max-width: 1100px; margin: 0 auto; display: grid; grid-template-columns: 1fr 420px; gap: 48px; align-items: center; }
  .hero-eyebrow { font-size: 11px; font-weight: 700; letter-spacing: 0.15em; text-transform: uppercase; color: var(--red); margin-bottom: 16px; }
  .hero-title { font-size: clamp(32px, 5vw, 52px); font-weight: 900; line-height: 1.05; text-transform: uppercase; letter-spacing: -0.02em; margin-bottom: 20px; }
  .hero-title span { color: var(--red); }
  .hero-sub { font-size: 17px; line-height: 1.6; color: #aaa; margin-bottom: 32px; max-width: 540px; }
  .hero-cta-group { display: flex; gap: 16px; flex-wrap: wrap; }
  .btn-primary { display: inline-block; background: var(--red); color: #fff; padding: 14px 28px; font-size: 15px; font-weight: 700; text-decoration: none; letter-spacing: 0.04em; text-transform: uppercase; }
  .btn-secondary { display: inline-block; border: 1px solid #555; color: #ccc; padding: 14px 28px; font-size: 15px; font-weight: 600; text-decoration: none; letter-spacing: 0.04em; text-transform: uppercase; }
  .hero-badge-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
  .hero-badge { background: #161616; border: 1px solid #2a2a2a; padding: 16px 18px; }
  .badge-num { font-size: 22px; font-weight: 900; color: var(--red); line-height: 1; margin-bottom: 4px; }
  .badge-label { font-size: 12px; color: #888; text-transform: uppercase; letter-spacing: 0.08em; }

  .trust-bar { background: var(--red); padding: 14px 24px; }
  .trust-bar-inner { max-width: 1100px; margin: 0 auto; display: flex; justify-content: space-between; flex-wrap: wrap; gap: 8px; }
  .trust-item { color: #fff; font-size: 13px; font-weight: 600; letter-spacing: 0.04em; text-transform: uppercase; }
  .trust-item::before { content: "✓ "; }

  .section { padding: 64px 24px; }
  .section-gray { background: var(--gray); }
  .section-black { background: var(--black); color: #fff; }
  .section-inner { max-width: 1100px; margin: 0 auto; }
  .section-num { font-size: 11px; font-weight: 700; letter-spacing: 0.15em; text-transform: uppercase; color: var(--red); margin-bottom: 8px; }
  .section-title { font-size: clamp(24px, 3.5vw, 36px); font-weight: 900; text-transform: uppercase; letter-spacing: -0.01em; margin-bottom: 20px; }
  .section-black .section-title { color: #fff; }
  .section-lead { font-size: 17px; line-height: 1.7; color: var(--muted); max-width: 760px; margin-bottom: 40px; }
  .section-black .section-lead { color: #999; }

  .models-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1px; background: #2a2a2a; border: 1px solid #2a2a2a; margin-top: 28px; }
  .model-card { background: #161616; padding: 20px 18px; }
  .model-name { font-size: 16px; font-weight: 900; text-transform: uppercase; letter-spacing: 0.05em; color: #fff; margin-bottom: 4px; }
  .model-size { font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; color: var(--red); margin-bottom: 8px; }
  .model-desc { font-size: 12px; color: #666; line-height: 1.6; }

  .tip-block { border-left: 3px solid var(--red); background: #fff8f8; padding: 18px 20px; margin: 32px 0; max-width: 760px; }
  .tip-label { font-size: 10px; font-weight: 800; text-transform: uppercase; letter-spacing: 0.15em; color: var(--red); margin-bottom: 6px; }
  .tip-text { font-size: 14px; line-height: 1.65; color: var(--text); }
  .tip-france { border-color: #2a5ea5; background: #f0f7ff; }
  .tip-france .tip-label { color: #2a5ea5; }
  .tip-metric { border-color: #c8820a; background: #fff8f0; }
  .tip-metric .tip-label { color: #c8820a; }
  .tip-parts { border-color: #5a2a7a; background: #f8f0ff; }
  .tip-parts .tip-label { color: #5a2a7a; }

  .services-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 1px; background: var(--border); border: 1px solid var(--border); }
  .service-card { background: #fff; padding: 28px 24px; }
  .service-icon { font-size: 28px; margin-bottom: 12px; }
  .service-name { font-size: 16px; font-weight: 800; text-transform: uppercase; letter-spacing: 0.04em; margin-bottom: 10px; color: var(--text); }
  .service-desc { font-size: 14px; line-height: 1.65; color: var(--muted); margin-bottom: 12px; }
  .service-issues { font-size: 12px; color: var(--red); font-weight: 600; text-transform: uppercase; letter-spacing: 0.06em; }

  .features-2col { display: grid; grid-template-columns: 1fr 1fr; gap: 48px; align-items: start; }
  .features-list { list-style: none; }
  .features-list li { padding: 14px 0; border-bottom: 1px solid #2a2a2a; font-size: 15px; color: #ccc; display: flex; gap: 12px; }
  .features-list li::before { content: "→"; color: var(--red); flex-shrink: 0; }

  .problems-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(260px, 1fr)); gap: 16px; margin-top: 32px; }
  .problem-card { border: 1px solid var(--border); background: #fff; padding: 20px; }
  .problem-title { font-size: 14px; font-weight: 800; text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 8px; color: var(--text); }
  .problem-cause { font-size: 13px; color: var(--muted); line-height: 1.6; margin-bottom: 10px; }
  .problem-tag { display: inline-block; font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; padding: 3px 8px; color: #fff; }
  .tag-common { background: var(--red); }
  .tag-jet { background: #c8820a; }
  .tag-plancha { background: #2a5ea5; }
  .tag-enamel { background: #5a2a7a; }

  .pricing-table { width: 100%; border-collapse: collapse; margin-top: 24px; }
  .pricing-table th { background: var(--text); color: #fff; text-align: left; padding: 12px 16px; font-size: 12px; text-transform: uppercase; letter-spacing: 0.08em; }
  .pricing-table td { padding: 14px 16px; border-bottom: 1px solid var(--border); font-size: 14px; }
  .pricing-table tr:last-child td { border-bottom: none; }
  .pricing-table tr:nth-child(even) td { background: var(--gray); }
  .price-range { font-weight: 700; color: var(--red); }

  .why-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: 24px; margin-top: 32px; }
  .why-card { border-left: 3px solid var(--red); padding: 20px; background: #fff; }
  .why-icon { font-size: 24px; margin-bottom: 10px; }
  .why-title { font-size: 14px; font-weight: 800; text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 8px; }
  .why-desc { font-size: 13px; color: var(--muted); line-height: 1.6; }

  .reviews-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 20px; margin-top: 32px; }
  .review-card { background: #fff; border: 1px solid var(--border); padding: 24px; }
  .review-stars { color: var(--red); font-size: 18px; margin-bottom: 10px; }
  .review-text { font-size: 14px; line-height: 1.7; color: var(--text); margin-bottom: 14px; }
  .review-author { font-size: 12px; font-weight: 700; text-transform: uppercase; color: var(--muted); }

  .repairs-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 1px; background: var(--border); border: 1px solid var(--border); margin-top: 32px; }
  .repair-item { background: #fff; padding: 24px; }
  .repair-appliance { font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; color: var(--red); margin-bottom: 6px; }
  .repair-issue { font-size: 15px; font-weight: 800; color: var(--text); margin-bottom: 8px; }
  .repair-detail { font-size: 13px; color: var(--muted); line-height: 1.6; }
  .repair-meta { margin-top: 12px; font-size: 12px; font-weight: 600; color: #aaa; text-transform: uppercase; letter-spacing: 0.06em; }

  .faq-list { margin-top: 32px; }
  .faq-item { border-bottom: 1px solid var(--border); padding: 20px 0; }
  .faq-q { font-size: 16px; font-weight: 800; color: var(--text); margin-bottom: 10px; }
  .faq-a { font-size: 14px; line-height: 1.7; color: var(--muted); max-width: 760px; }

  .nearby-grid { display: flex; flex-wrap: wrap; gap: 8px; margin-top: 20px; }
  .nearby-chip { background: var(--gray); border: 1px solid var(--border); padding: 8px 14px; font-size: 13px; color: var(--muted); text-decoration: none; font-weight: 600; }
  .nearby-chip:hover { border-color: var(--red); color: var(--red); }

  .bottom-cta { background: var(--black); padding: 72px 24px; text-align: center; color: #fff; }
  .bottom-cta-title { font-size: clamp(28px, 4vw, 44px); font-weight: 900; text-transform: uppercase; letter-spacing: -0.01em; margin-bottom: 12px; }
  .bottom-cta-title span { color: var(--red); }
  .bottom-cta-sub { font-size: 17px; color: #888; margin-bottom: 32px; }
  .cta-phone-large { display: inline-block; font-size: clamp(28px, 4vw, 42px); font-weight: 900; color: #fff; text-decoration: none; letter-spacing: -0.01em; margin-bottom: 24px; border-bottom: 2px solid var(--red); padding-bottom: 4px; }

  @media (max-width: 768px) {
    .hero-inner { grid-template-columns: 1fr; }
    .hero-badge-grid { grid-template-columns: 1fr 1fr; }
    .features-2col { grid-template-columns: 1fr; }
    .models-grid { grid-template-columns: 1fr 1fr; }
    .trust-bar-inner { flex-direction: column; gap: 6px; }
  }
</style>

<div class="top-bar">
  <span>Mon–Sat 8am–8pm · Los Angeles &amp; Southern California</span>
  <a href={`tel:${phoneRaw}`}>{phone}</a>
</div>

<section class="hero">
  <div class="hero-inner">
    <div>
      <div class="hero-eyebrow">Lacanche Range Repair — Los Angeles</div>
      <h1 class="hero-title">
        Lacanche Repair.<br/>
        <span>Chagny, Burgundy.</span><br/>
        Brass Jets. Metric Tools.
      </h1>
      <p class="hero-sub">
        Lacanche has been made in Chagny, Burgundy since 1796. The brass jets that make these ranges sing — and block fastest in LA's hard water. The metric fasteners that US tools strip if you don't know what you're doing. The plancha that needs its own thermostat diagnosis. We know all of it. Same day across LA.
      </p>
      <div class="hero-cta-group">
        <a href={`tel:${phoneRaw}`} class="btn-primary">Call {phone}</a>
        <a href="/book/" class="btn-secondary">Book Online</a>
      </div>
    </div>
    <div class="hero-badge-grid">
      <div class="hero-badge">
        <div class="badge-num">Same</div>
        <div class="badge-label">Day Service</div>
      </div>
      <div class="hero-badge">
        <div class="badge-num">OEM</div>
        <div class="badge-label">French Parts</div>
      </div>
      <div class="hero-badge">
        <div class="badge-num">90-Day</div>
        <div class="badge-label">Warranty</div>
      </div>
      <div class="hero-badge">
        <div class="badge-num">$89</div>
        <div class="badge-label">Diagnostic Fee</div>
      </div>
    </div>
  </div>
</section>

<div class="trust-bar">
  <div class="trust-bar-inner">
    <span class="trust-item">Licensed &amp; Insured · CSLB #1138898</span>
    <span class="trust-item">Brass Jet Service</span>
    <span class="trust-item">Full Metric Toolkit</span>
    <span class="trust-item">Plancha Thermostat Service</span>
    <span class="trust-item">Flat-Rate Written Estimate</span>
  </div>
</div>

<section class="section">
  <div class="section-inner">
    <div class="section-num">01 — About Lacanche</div>
    <h2 class="section-title">Chagny, Burgundy. French-Made Since 1796.</h2>
    <p class="section-lead">
      Lacanche ranges are made in Chagny — a small town in Burgundy, France whose foundry heritage dates to 1796. The Chagny manufacturing facility has been producing cast iron cookware and ranges in the Burgundian tradition for over two centuries. Every Lacanche range is assembled by hand in Chagny, customized to the owner's specification in enamel color, trim finish, burner configuration, and optional features, and shipped through Art Culinaire — the US distributor headquartered in California.
    </p>
    <p class="section-lead">
      In Los Angeles, Lacanche occupies the highest tier of residential cooking aspirations. These aren't purchased for kitchen design alone — they're chosen by people who cook seriously, who wanted the range their favorite French restaurant uses, and who are prepared to invest in the maintenance that a handcrafted French range requires. They're positioned explicitly as heirloom appliances: ranges that outlive the kitchen they're installed in, passed from one owner or generation to the next. Service should honor that.
    </p>

    <div class="models-grid">
      <div class="model-card">
        <div class="model-name">Cluny</div>
        <div class="model-size">90cm · Most Popular LA Model</div>
        <div class="model-desc">The quintessential Lacanche — 5 open burners, single large oven, optional plancha or simmer plate. Named after the medieval abbey town in Burgundy. The most common Lacanche we service in LA.</div>
      </div>
      <div class="model-card">
        <div class="model-name">Chaussin</div>
        <div class="model-size">100cm · Dual Oven</div>
        <div class="model-desc">Two oven cavities in 100cm width — a primary oven plus a secondary smaller oven. Popular for entertaining households. Named after the village in Burgundy's Côte de Nuits wine region.</div>
      </div>
      <div class="model-card">
        <div class="model-name">Sully</div>
        <div class="model-size">180cm · Largest Configuration</div>
        <div class="model-desc">Lacanche's largest range — 180cm with up to 7 burners, triple ovens, integrated plancha, warming cupboard. Named for the Duke of Sully, Henry IV's minister. Estate and manor-scale kitchen range.</div>
      </div>
      <div class="model-card">
        <div class="model-name">Beaune</div>
        <div class="model-size">90cm · Single Oven</div>
        <div class="model-desc">Classic single-oven 90cm configuration named after Burgundy's wine capital. Available in Open Cook, Classic, and Modern series. The gateway Lacanche for many LA buyers.</div>
      </div>
      <div class="model-card">
        <div class="model-name">Vougeot</div>
        <div class="model-size">70cm · Compact</div>
        <div class="model-desc">Lacanche's smallest range — 70cm for compact kitchens that still demand French quality. Named for the Clos de Vougeot castle in Burgundy. Available with 4 burners and a single oven.</div>
      </div>
      <div class="model-card">
        <div class="model-name">Savigny</div>
        <div class="model-size">110cm · Mid-Size</div>
        <div class="model-desc">Between the Chaussin and the larger configurations — 6 burners and a dual oven arrangement in 110cm. Named after Savigny-lès-Beaune in the Côte de Beaune. Well-suited for LA cooking homes.</div>
      </div>
    </div>

    <div class="tip-block tip-france" style="margin-top:32px">
      <div class="tip-label">🇫🇷 Art Culinaire USA — The US Lacanche Infrastructure</div>
      <div class="tip-text">Lacanche's US market is managed by Art Culinaire, based in California — the exclusive importer and distributor for Lacanche in North America. Art Culinaire maintains a US parts inventory for common Lacanche components, provides warranty coordination (3-year limited warranty from date of delivery), and maintains a network of preferred service providers across the US. For warranty service, Art Culinaire must be contacted first — a warranty authorization is required before any service is performed. For non-warranty service, owners can use any qualified technician. We are familiar with Art Culinaire's parts ordering system and warranty coordination process.</div>
    </div>
  </div>
</section>

<section class="section section-gray">
  <div class="section-inner">
    <div class="section-num">02 — Services</div>
    <h2 class="section-title">Lacanche Service — Every Model, Every Configuration</h2>
    <p class="section-lead">All Lacanche models — Cluny, Chaussin, Sully, Beaune, Vougeot, Savigny — in all series and configurations. Same-day across Los Angeles County.</p>

    <div class="services-grid">
      <div class="service-card">
        <div class="service-icon">🔧</div>
        <div class="service-name">Brass Jet Service</div>
        <div class="service-desc">Lacanche's open burner system uses brass jets — small threaded brass orifices that meter gas flow to each burner at a specific rate. LA's hard water (250–400 ppm) combined with cooking oil residue creates a specific blocking compound in brass jets that's harder than either deposit alone. The first visible symptom: yellow flame tips rather than the clean blue flame of clear jets. We clean and inspect all brass jets on every Lacanche service call, regardless of whether jet blockage was the stated complaint — because partial jet restriction affects every burner's performance even before it fails completely.</div>
        <div class="service-issues">Common: yellow-tipped flames · weak burner output · uneven flame pattern · jet blockage · jet replacement when worn · LA hard water deposit service</div>
      </div>

      <div class="service-card">
        <div class="service-icon">🥩</div>
        <div class="service-name">Plancha &amp; Simmer Plate Service</div>
        <div class="service-desc">Lacanche's plancha is a cast iron or mild steel cooking plate that replaces one or two burner positions in certain configurations — different from the FiveStar integrated griddle in that it's a surface cooking plate rather than a griddle with burner underneath. The plancha uses a dedicated burner and thermostat to maintain surface temperature. Plancha thermostat drift — where the surface temperature runs inconsistently — is the most common plancha failure. We service the plancha thermostat and dedicated burner as a distinct subsystem.</div>
        <div class="service-issues">Common: plancha thermostat drift · uneven surface temperature · dedicated burner blockage · plancha surface hot spots · simmer plate temperature regulation · burner igniter</div>
      </div>

      <div class="service-card">
        <div class="service-icon">🌡️</div>
        <div class="service-name">Oven Temperature &amp; Calibration</div>
        <div class="service-desc">Lacanche ovens — gas, electric, and dual-fuel configurations — use French-manufactured thermostats and temperature sensors. The Open Cook series uses gas ovens with manual controls; Classic and Modern series add electric oven options and digital controls. Temperature drift on Lacanche ovens is often a thermostat calibration offset rather than a failed component — adjustable without parts replacement. We test with a calibrated probe at multiple setpoints before ordering any oven components.</div>
        <div class="service-issues">Common: oven running hot or cold · thermostat calibration · temperature sensor · convection fan · door gasket · self-clean fault · modern series digital display · control board</div>
      </div>

      <div class="service-card">
        <div class="service-icon">🔩</div>
        <div class="service-name">Metric Fastener Service</div>
        <div class="service-desc">Every Lacanche range uses metric fasteners — French manufacturing standard. Accessing the burner assembly, oven components, thermostat, or back panel requires metric tools only. US technicians without a metric toolkit cannot service a Lacanche correctly. Using SAE tools on metric fasteners strips bolts immediately — and a stripped Lacanche fastener is a significant secondary damage event that requires drilling and replacement. We carry a complete metric toolkit for all Lacanche and European range service.</div>
        <div class="service-issues">All Lacanche service performed exclusively with metric tools. Stripped fastener assessment and repair available if previous service caused damage.</div>
      </div>

      <div class="service-card">
        <div class="service-icon">🏠</div>
        <div class="service-name">Porcelain Enamel Panel Service</div>
        <div class="service-desc">Lacanche's porcelain enamel body panels — available in over 30 colors — require non-abrasive service protocols throughout any repair work. The enamel is vitrified glass fused to steel; it chips at sharp impact and cannot be touched up without professional respray. We use protective felt pads and heat shields on all enamel surfaces during service. The enamel knobs also require specific care — they're porcelain and loosen at the set screw rather than breaking, which owners sometimes mistake for a crack requiring replacement.</div>
        <div class="service-issues">All repairs with enamel-safe protocols. Knob tightening service. Color-matched parts ordering for exterior components. Panel protection throughout all service.</div>
      </div>

      <div class="service-card">
        <div class="service-icon">☕</div>
        <div class="service-name">Warming Cupboard &amp; Accessories</div>
        <div class="service-desc">Larger Lacanche configurations include a warming cupboard — a low-temperature storage area beneath the main oven cavity, heated by the oven's exhaust or a dedicated element. The warming cupboard thermostat, door seal, and heat distribution are separate service points from the main oven. On the Sully and other large configurations, the warming cupboard's independence from the main oven circuit means its failure doesn't affect main oven operation and vice versa.</div>
        <div class="service-issues">Common: warming cupboard temperature inconsistency · door seal · thermostat · heat distribution · control · door hinge wear</div>
      </div>
    </div>

    <div class="tip-block tip-metric" style="margin-top:32px">
      <div class="tip-label">🔧 Metric Fasteners — Why US Tools Destroy Lacanche Ranges</div>
      <div class="tip-text">Lacanche uses metric fasteners throughout — M4, M5, M6, M8 bolts and screws wherever the range is assembled. US SAE (imperial) sockets and screwdrivers are close but not identical to metric sizes — close enough to partially engage a fastener but not enough to turn it cleanly. An M8 bolt accepts a 5/16" US socket loosely; applying torque strips the hex on the bolt head. We regularly encounter Lacanche ranges where a previous general appliance technician stripped multiple fasteners attempting to access the burner assembly or oven components. Stripped fasteners require drilling, extraction, and re-threading — a significant repair that wouldn't have been needed with proper metric tools. We've never stripped a Lacanche fastener. We carry M4 through M12 metric sockets and hex keys specifically for Lacanche and other European range service.</div>
    </div>
  </div>
</section>

<section class="section section-black">
  <div class="section-inner">
    <div class="section-num">03 — Technology</div>
    <h2 class="section-title">What Makes Lacanche Different to Service</h2>
    <p class="section-lead">Lacanche's French manufacturing philosophy, burner system, and metric construction create specific service requirements that US appliance training doesn't cover.</p>

    <div class="features-2col">
      <ul class="features-list">
        <li><strong>Open Burner with Brass Jets</strong> — Lacanche uses an open burner design similar in concept to BlueStar and FiveStar but with a distinct gas metering approach: brass jet orifices that can be sized for different BTU outputs and replaced independently. In LA's hard water environment, regular brass jet cleaning is the most important maintenance task for Lacanche. We clean all jets with specific brass-safe technique and check jet sizes against the Lacanche specification for the model.</li>
        <li><strong>French Metric Construction Throughout</strong> — Every dimension, every fastener, every fitting on a Lacanche range is metric. The gas connections use metric pipe fittings; the burner assembly uses metric machine screws; the oven cavity uses metric mounting hardware. Service requires a complete metric toolkit and awareness of metric gas fitting standards. This is why many general appliance technicians decline Lacanche service — their US tool inventory simply doesn't apply.</li>
        <li><strong>Open Cook / Classic / Modern Series Differences</strong> — Lacanche's three product lines differ in control philosophy. Open Cook uses analog gas controls throughout — no electronics beyond the ignition system. Classic adds analog thermostats for the electric oven option. Modern adds digital controls, programmable timers, and soft-close door mechanisms. Each series has specific diagnostic requirements: Open Cook is mechanical troubleshooting; Modern requires software-based diagnostic access similar to other connected European appliances.</li>
        <li><strong>Plancha as Dedicated Subsystem</strong> — The Lacanche plancha plate is fed by a dedicated gas burner with its own thermostat — not connected to the main burner control system. Plancha failures are plancha-specific: the dedicated thermostat, the dedicated burner, or the plancha jet. When the plancha surface temperature drifts while all main burners perform normally, the diagnosis is in the plancha's independent circuit, not the main range system.</li>
        <li><strong>Porcelain Enamel with 30+ Color Options</strong> — Lacanche's porcelain enamel body is fired at high temperature in the Chagny factory. The 30+ standard colors plus custom options make every Lacanche range essentially unique. Service requires identification of the specific enamel color for any parts that need exterior replacement — ordering the wrong color shade for a knob or trim panel is immediately visible. We confirm color and finish spec before ordering any exterior Lacanche components.</li>
        <li><strong>Parts Sourced Through Art Culinaire</strong> — Non-warranty parts for Lacanche flow through Art Culinaire's US parts program. Standard components — jets, gaskets, thermocouples, igniters, thermostats — typically ship within 1–2 weeks from US stock. Custom-color enamel parts and specialty trim require ordering from the Chagny factory: typically 8–10 weeks standard, up to 5 months for specialty colors. We always verify US stock and quote realistic timelines before beginning any Lacanche repair.</li>
      </ul>
      <div>
        <div class="tip-block" style="background:#0a1015; border-color:#c8820a; margin-top:0">
          <div class="tip-label" style="color:#e8a030">🔥 LA Hard Water + Lacanche Brass Jets</div>
          <div class="tip-text" style="color:#bbb">LA water at 250–400 ppm mineral content is significantly harder than the French water that Lacanche's standard maintenance intervals assume (typically 100–200 ppm in Burgundy). The combination of hard water mineral deposits and cooking oil creates a specific compound in brass jets that's harder than either deposit alone. In France, Lacanche jets might need cleaning every 3–6 months. In LA, weekly brass jet cleaning is the recommended interval for properties in the Valley (hardest water) and monthly for coastal properties (softer but salt-affected). The first sign of jet restriction: yellow flame tips instead of clean blue flame. Don't wait for the burner to fail — yellow tips are the maintenance signal.</div>
        </div>
        <div class="tip-block" style="background:#16100a; border-color:#5a2a7a; margin-top:16px">
          <div class="tip-label" style="color:#c85aa0">🗓️ Parts Lead Times — Honest Conversation</div>
          <div class="tip-text" style="color:#bbb">Lacanche is the most parts-lead-time sensitive brand we service. Standard Art Culinaire US stock: 1–2 weeks. Custom enamel doors, brass rail trim, specialty knob sets: 8–10 weeks. Specific Chagny-made custom components: up to 5 months. We quote parts timelines before beginning any repair — not after. If a component needs 10 weeks from France, you'll know before we start, not when you're waiting. For most common failures (jets, gaskets, thermocouples, igniters), US stock turnaround means same-week completion in most cases.</div>
        </div>
      </div>
    </div>
  </div>
</section>

<section class="section">
  <div class="section-inner">
    <div class="section-num">04 — Common Problems</div>
    <h2 class="section-title">Most Common Lacanche Failures in Los Angeles</h2>

    <div class="problems-grid">
      <div class="problem-card">
        <div class="problem-title">🔥 Yellow Flame Tips — Brass Jet Blockage</div>
        <div class="problem-cause">Hard water mineral deposits combined with cooking oil residue blocking brass jet orifices. Yellow flame tips are the first visible sign — the burner still lights but gas flow is restricted. In LA, this occurs faster than in France due to harder water. Weekly jet cleaning prevents this from progressing to burner failure. We clean and inspect all brass jets on every Lacanche service call.</div>
        <span class="problem-tag tag-jet">Brass Jet</span>
      </div>

      <div class="problem-card">
        <div class="problem-title">🌡️ Oven Temperature Drift</div>
        <div class="problem-cause">Thermostat calibration offset or thermostat wear — Lacanche's French-spec thermostats can drift from calibration over years of use in LA's climate. We test with a calibrated probe at 350°F and 450°F before ordering any parts. Many Lacanche oven temperature complaints resolve with calibration adjustment through the thermostat's trimmer without component replacement. Parts-free fixes for a significant portion of oven temperature calls.</div>
        <span class="problem-tag tag-common">Most Common</span>
      </div>

      <div class="problem-card">
        <div class="problem-title">🥩 Plancha Temperature Inconsistency</div>
        <div class="problem-cause">Plancha dedicated thermostat drift — the independent thermostat that controls the plancha surface temperature gradually loses calibration. Symptom: inconsistent browning across the plancha plate, with one area overcooked while another is underdone. We diagnose the plancha thermostat as a standalone system, independent of the main burner controls.</div>
        <span class="problem-tag tag-plancha">Plancha</span>
      </div>

      <div class="problem-card">
        <div class="problem-title">🔩 Stripped Fasteners from Previous Service</div>
        <div class="problem-cause">A US technician without metric tools attempted Lacanche service. SAE tools on metric fasteners strip bolt heads — a secondary damage event that turns a simple repair into a more complex one. We assess stripped fastener damage, extract where possible, and re-thread when needed. We then complete the original repair correctly with metric tools.</div>
        <span class="problem-tag tag-common">Previous Service Damage</span>
      </div>

      <div class="problem-card">
        <div class="problem-title">🏠 Porcelain Enamel Knob Loosening</div>
        <div class="problem-cause">Porcelain enamel control knobs loosen at the set screw — the knob spins freely without turning the control shaft. This is commonly misidentified as a cracked knob. The knob itself is intact; the set screw needs retightening. We carry metric hex keys for Lacanche knob set screws. Fifteen-minute fix that owners sometimes replace the knob for unnecessarily.</div>
        <span class="problem-tag tag-enamel">Enamel Knob</span>
      </div>

      <div class="problem-card">
        <div class="problem-title">🌊 Coastal Door Gasket Wear</div>
        <div class="problem-cause">Salt air at coastal LA properties (Malibu, Pacific Palisades, Venice, Santa Monica) accelerates oven door gasket compression loss — the gasket loses its seal before inland properties show the same issue. Symptom: oven temperature drift that doesn't resolve with thermostat calibration, and occasionally visible scorch marks on the oven door frame from heat escaping around the gasket. Annual gasket inspection for coastal Lacanche installations.</div>
        <span class="problem-tag tag-common">Coastal LA</span>
      </div>
    </div>
  </div>
</section>

